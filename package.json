{
  "name": "yixin-cui-portfolio",
  "description": "Yixin Cui portfolio and local bilingual Website Studio.",
  "type": "module",
  "main": "apps/desktop/main.cjs",
  "version": "0.1.0",
  "private": true,
  "fileGuide": {
    "purposeZh": "定义项目脚本与直接依赖。",
    "purposeEn": "Defines project scripts and direct dependencies.",
    "caveatZh": "package-lock.json 由 npm 自动生成，不要手动编辑。",
    "caveatEn": "package-lock.json is generated by npm; do not edit it manually."
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "test": "node tests/tools-core.test.mjs && node tests/site-integrity.test.mjs",
    "desktop": "electron apps/desktop/main.cjs",
    "desktop:build": "electron-packager . \"Yixin Studio\" --platform=win32 --arch=x64 --out=desktop-dist --overwrite --ignore=\"^/(content|src|public|scripts|tests|docs|icon-sources|node_modules|dist|desktop-dist|\\.desktop-build|\\.git|\\.astro|\\.claude|\\.github|\\.npm-cache|.*\\.log|\\.publish-source\\..*|\\.pages\\.yml|CNAME|README\\.md|tsconfig\\.json|package-lock\\.json)($|/)\""
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@lezer/highlight": "^1.2.3",
    "astro": "^6.4.6",
    "codemirror": "^6.0.2",
    "katex": "^0.17.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@electron/packager": "^20.0.1",
    "electron": "^42.4.1",
    "esbuild-wasm": "^0.27.7",
    "typescript": "^5.9.3"
  }
}
