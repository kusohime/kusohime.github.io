---
// 中文：《脆熊篇》專用的雙欄閱讀器；左側只保留篇號，右側顯示當前正文。
// English: Two-column reader for Cui Xiong Pian; the left rail contains titles
// only, while the current chapter is rendered in the right reading pane.
import type { CollectionEntry } from "astro:content";
import { formatDate } from "../config/locales";
import LocalizedText from "./LocalizedText.astro";

interface Props {
  writing: CollectionEntry<"writings">;
  chapters: CollectionEntry<"writingChapters">[];
  currentChapter?: CollectionEntry<"writingChapters">;
  contentLang?: string;
  imageLed?: boolean;
}

const {
  writing,
  chapters,
  currentChapter,
  contentLang,
  imageLed = false,
} = Astro.props;
const parentHref = `/writings/${writing.data.slug}/`;
const dateLabel = writing.data.displayDate ?? String(writing.data.date);
---

<div class:list={["cui-reader", { "series-reader--visual": imageLed }]}>
  <aside class="cui-reader-rail">
    <a
      class="cui-reader-title"
      href={parentHref}
    >
      <LocalizedText value={{ en: writing.data.title, zh: writing.data.titleZh }} />
    </a>
    <nav aria-label="脆熊篇目錄">
      <ol>
        <li>
          <a
            href={parentHref}
            lang={contentLang}
            aria-current={!currentChapter ? "page" : undefined}
          >
            0
          </a>
        </li>
        {
          chapters.map((chapter) => (
            <li>
              <a
                href={`${parentHref}${chapter.data.slug}/`}
                lang={contentLang}
                aria-current={currentChapter?.id === chapter.id ? "page" : undefined}
              >
                {chapter.data.title}
              </a>
            </li>
          ))
        }
      </ol>
    </nav>
  </aside>

  <section class="cui-reader-main">
    {
      !currentChapter && (
        <header class="detail-header cui-reader-header">
            <h1><LocalizedText value={{ en: writing.data.title, zh: writing.data.titleZh }} /></h1>
            <p class="writing-metadata">
              <time datetime={String(writing.data.date)} data-i18n-date={dateLabel}>
                {formatDate(dateLabel, "en")}
              </time>
            </p>
        </header>
      )
    }
    <slot />
  </section>
</div>
