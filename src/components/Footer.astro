---
// 中文：公开网站页脚，显示联系邮箱与 RSS 订阅入口。
// English: Public footer with correspondence email and RSS subscription.
// Caveat / 注意：邮箱的唯一来源是 config/site.ts。
// Caveat: Keep the email source centralized in config/site.ts.
import { site } from "../config/site";
---

<footer class="site-footer" data-source-file="src/components/Footer.astro">
  <a href={`mailto:${site.email}`}>{site.email}</a>
  <a class="rss-link" href="/rss.xml" aria-label="Subscribe to RSS feed">
    <svg
      class="rss-icon"
      viewBox="0 0 24 24"
      role="img"
      aria-hidden="true"
      focusable="false"
    >
      <circle cx="6" cy="18" r="1.9"></circle>
      <path d="M4.5 10.5A9 9 0 0 1 13.5 19.5"></path>
      <path d="M4.5 4.5A15 15 0 0 1 19.5 19.5"></path>
    </svg>
    <span>RSS</span>
  </a>
</footer>
