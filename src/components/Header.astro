---
// 中文：公開網站頁首、主導覽與三個偏好選單。
// English: Public header, primary navigation, and three preference menus.
import NamePronunciation from "./NamePronunciation.astro";
import {
  localeCodes,
  localeInfo,
  translate,
  type TranslationKey,
} from "../config/locales";

const { pathname } = Astro.url;
const currentPath = pathname.replace(/\/$/, "") || "/";

const navItems = [
  {
    key: "nav.works" as TranslationKey,
    href: "/works",
  },
  {
    key: "nav.writings" as TranslationKey,
    href: "/writings",
  },
  {
    key: "nav.tools" as TranslationKey,
    href: "/tools",
  },
];
---

<header class="site-header" data-source-file="src/components/Header.astro">
  <div class="header-row">
    <p class="site-name">
      <a
        href="/"
        aria-label="Yixin Cui, home"
        aria-current={currentPath === "/" ? "page" : undefined}
      >
        <NamePronunciation focusable={false} translate />
      </a>
    </p>

    <nav aria-label="Primary navigation">
      <ul class="nav-list">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={currentPath.startsWith(item.href) ? "page" : undefined}
              >
                <span data-i18n-key={item.key}>{translate("en", item.key)}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="header-tools" aria-label="Site preferences">
      <details
        class="preference-menu"
        data-preference-menu
        data-preference-type="language"
      >
        <summary>
          <span
            class="glyph-arrow glyph-arrow--disclosure"
            data-arrow-glyph
            aria-hidden="true"
          ></span>
          <span class="preference-value" data-current-language>EN</span>
        </summary>
        <div class="preference-options" role="group" aria-label="Language">
          {
            localeCodes.map((locale) => (
              <button type="button" data-language-option={locale}>
                {localeInfo[locale].name}
              </button>
            ))
          }
        </div>
      </details>

      <details
        class="preference-menu font-size-menu"
        data-preference-menu
        data-preference-type="font-size"
      >
        <summary>
          <span
            class="glyph-arrow glyph-arrow--disclosure"
            data-arrow-glyph
            aria-hidden="true"
          ></span>
          <span class="preference-value" data-current-font-size>M</span>
        </summary>
        <div class="preference-options font-size-options" role="group" aria-label="Font size">
          <button type="button" data-font-size-option="s" aria-label="Small text">S</button>
          <button type="button" data-font-size-option="m" aria-label="Medium text">M</button>
          <button type="button" data-font-size-option="l" aria-label="Large text">L</button>
        </div>
      </details>

      <button
        type="button"
        class="theme-toggle"
        data-theme-toggle
        aria-label="Switch to dark theme"
        title="Switch to dark theme"
      >
        <span
          class="theme-glyph"
          data-theme-glyph
          aria-hidden="true"
        ></span>
      </button>
    </div>
  </div>
</header>

<script>
  import { initializePreferences } from "../scripts/preferences";

  initializePreferences();
</script>
