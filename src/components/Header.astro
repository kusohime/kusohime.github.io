---
// 中文：公開網站頁首、主導覽與三個偏好選單。
// English: Public header, primary navigation, and three preference menus.
import NamePronunciation from "./NamePronunciation.astro";
import {
  translate,
  type TranslationKey,
} from "../config/locales";

const { pathname } = Astro.url;
const currentPath = pathname.replace(/\/$/, "") || "/";

const isActivePath = (href: string) =>
  currentPath === href || currentPath.startsWith(`${href}/`);

const navGroups = [
  {
    key: "nav.music" as TranslationKey,
    items: [
      { key: "nav.works" as TranslationKey, href: "/works" },
      { key: "nav.events" as TranslationKey, href: "/events" },
      { key: "nav.cv" as TranslationKey, href: "/cv" },
    ],
  },
  {
    key: "nav.blog" as TranslationKey,
    items: [
      { key: "nav.writings" as TranslationKey, href: "/writings" },
      { key: "nav.tools" as TranslationKey, href: "/tools" },
    ],
  },
];
---

<header class="site-header" data-source-file="src/components/Header.astro">
  <div class="header-row">
    <p class="site-name">
      <a
        href="/"
        aria-label="Yixin Cui, home"
        aria-current={currentPath === "/" ? "page" : undefined}
      >
        <NamePronunciation focusable={false} translate />
      </a>
    </p>

    <nav aria-label="Primary navigation">
      <ul class="nav-list">
        {
          navGroups.map((group) => (
            <li class="nav-group">
              <details
                class="nav-dropdown"
                data-nav-menu
                data-active={group.items.some((item) => isActivePath(item.href)) ? "true" : undefined}
              >
                <summary>
                  <span
                    class="glyph-arrow glyph-arrow--disclosure"
                    data-arrow-glyph
                    aria-hidden="true"
                  ></span>
                  <span data-i18n-key={group.key}>{translate("en", group.key)}</span>
                </summary>
                {/* 中文：外层容器负责展开／收拢动画（grid-template-rows），列表在其内被裁切。 */}
                {/* English: The panel animates the unfold (grid-template-rows);
                    the list inside is what gets clipped. */}
                <div class="nav-dropdown-panel">
                  <ul class="nav-dropdown-list">
                    {group.items.map((item) => (
                      <li>
                        <a
                          href={item.href}
                          aria-current={isActivePath(item.href) ? "page" : undefined}
                        >
                          <span data-i18n-key={item.key}>
                            {translate("en", item.key)}
                          </span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </details>
            </li>
          ))
        }
      </ul>
    </nav>

  </div>
</header>
