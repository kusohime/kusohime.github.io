---
// 中文：单语正文的语言可用性提示。当界面语言没有本页的译本时，
// 说明该语言不可用，并指出下方显示的是何种原文。
// 提示由 CSS 依 <html lang> 显示，随语言切换即时出现或消失，无需脚本。
// English: Availability note for a single-language body. When the UI locale has
// no version of this page, say so and name the original shown below. CSS shows
// the note matching <html lang>, so it follows the language toggle without JS.
interface Props {
  // The language the body text actually exists in.
  available: "en" | "zh" | "ja";
}

const { available } = Astro.props;

const notes: { locale: "en" | "zh"; lang: string; text: string }[] = [];
if (available !== "en") {
  const original = available === "ja" ? "Japanese" : "Chinese";
  notes.push({
    locale: "en",
    lang: "en",
    text: `English translation not available — showing the ${original} original.`,
  });
}
if (available !== "zh") {
  const original = available === "ja" ? "日文" : "英文";
  notes.push({
    locale: "zh",
    lang: "zh-Hant-TW",
    text: `本頁暫無中文版——以下為${original}原文。`,
  });
}
---

{
  notes.map((note) => (
    <p
      class="lang-availability-note"
      role="note"
      data-note-locale={note.locale}
      lang={note.lang}
    >
      {note.text}
    </p>
  ))
}

<style>
  .lang-availability-note {
    display: none;
    margin: 0 0 1.1rem;
    border-inline-start: 2px solid var(--color-rule);
    padding-inline-start: 0.6rem;
    color: var(--color-muted);
    font-size: 0.8rem;
    /* 中文：正文容器（如 chicago-prose）会给 <p> 加首行缩进／两端对齐，这里还原。 */
    /* English: Prose containers (e.g. chicago-prose) indent/justify <p>; reset here. */
    text-indent: 0;
    text-align: start;
  }

  :global(:root:lang(en)) .lang-availability-note[data-note-locale="en"],
  :global(:root:lang(zh)) .lang-availability-note[data-note-locale="zh"] {
    display: block;
  }
</style>
