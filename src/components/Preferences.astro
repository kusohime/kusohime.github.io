---
// 中文：浮動偏好控制：語言、字號與深淺主題。
// English: Floating preference controls for language, text size, and theme.
import { translate, type Locale } from "../config/locales";

interface Props {
  unavailableLanguages?: Locale[];
}

const { unavailableLanguages = [] } = Astro.props;
---

<div
  class="header-tools"
  role="group"
  aria-labelledby="site-preferences-label"
>
  <span
    id="site-preferences-label"
    class="visually-hidden"
    data-i18n-key="preferences.group"
  >
    {translate("en", "preferences.group")}
  </span>
  {/* 中文：语言与字号都是「点按即切换」的双态开关——标签本身显示当前状态。 */}
  {/* English: Language and text size are two-state click-to-switch toggles —
      the label itself shows the current state, one click flips it. */}
  <button
    type="button"
    class="preference-toggle"
    data-language-toggle
    aria-label="Switch language"
  >
    <span class="visually-hidden" data-i18n-key="preferences.language">
      {translate("en", "preferences.language")}
    </span>
    <span class="preference-value" data-current-language>EN</span>
  </button>

  <button
    type="button"
    class="preference-toggle"
    data-font-size-toggle
    aria-label="Switch text size"
  >
    <span class="visually-hidden" data-i18n-key="preferences.textSize">
      {translate("en", "preferences.textSize")}
    </span>
    <span class="preference-value" data-current-font-size>L</span>
  </button>

  <button
    type="button"
    class="theme-toggle"
    data-theme-toggle
    aria-label="Switch to dark theme"
    title="Switch to dark theme"
  >
    <span
      class="theme-glyph"
      data-theme-glyph
      aria-hidden="true"
    ></span>
  </button>
</div>

<script>
  import { initializePreferences } from "../scripts/preferences";

  initializePreferences();
</script>
