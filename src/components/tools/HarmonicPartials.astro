---
// 中文：泛音列计算器：表格、梯形图、可选不谐和系数、加法合成试听。
// English: Harmonic partials calculator: table, ladder, optional
// inharmonicity, additive preview.
---

<section class="tool-panel" aria-label="Harmonic partials calculator">
  <span class="tool-panel-label">Series</span>
  <div class="tool-controls">
    <label class="tool-field">
      <span>Fundamental (name or Hz)</span>
      <input type="text" id="hp-f0" value="A2" size="10" />
    </label>
    <label class="tool-field">
      <span>Partials</span>
      <input type="number" id="hp-max" value="16" min="4" max="32" />
    </label>
    <label class="tool-field">
      <span>Inharmonicity B (piano strings ≈ 0.0002–0.001)</span>
      <input type="number" id="hp-b" value="0" min="0" max="0.01" step="0.0001" />
    </label>
    <button type="button" class="tool-primary" id="hp-go">Compute</button>
    <button type="button" id="hp-play-sel">Hear selected</button>
    <button type="button" id="hp-play-seq">Hear series</button>
  </div>
  <p class="tool-error" id="hp-error" hidden></p>

  <div class="tool-result" id="hp-result" hidden>
    <svg id="hp-ladder" class="tool-svg" viewBox="0 0 720 170" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Partial ladder"></svg>
    <div class="tool-table-wrap" style="margin-top: var(--space-md);">
      <table class="tool-table">
        <caption>Check partials to build a chord; deviations are from 12-EDO.</caption>
        <thead>
          <tr><th></th><th>n</th><th>Hz</th><th>Nearest</th><th>Dev.</th><th>Reduced to octave</th></tr>
        </thead>
        <tbody id="hp-table"></tbody>
      </table>
    </div>
    <p class="tool-note" id="hp-note"></p>
  </div>
</section>

<script>
  import { partialTable, reduceToOctave } from "../../lib/partials.js";
  import { midiToHz, nameToMidi } from "../../lib/pitch.js";
  import { sustain, blip, audioContext } from "../../lib/audio.js";

  const byId = (id: string) => document.getElementById(id) as any;
  const SVG_NS = "http://www.w3.org/2000/svg";
  let table: any[] = [];

  function readF0(): number | null {
    const text = byId("hp-f0").value.trim();
    const asName = nameToMidi(text);
    if (asName !== null) return midiToHz(asName);
    const value = Number(text.replace(/hz$/i, ""));
    return value > 0 ? value : null;
  }

  function compute() {
    const f0 = readF0();
    const error = byId("hp-error");
    if (!f0) {
      error.hidden = false;
      error.textContent = "Enter a note name (A2) or a frequency in Hz (110).";
      return;
    }
    error.hidden = true;
    const maxPartial = Math.max(4, Math.min(32, Number(byId("hp-max").value) || 16));
    const B = Math.max(0, Number(byId("hp-b").value) || 0);
    table = partialTable(f0, maxPartial, B);

    byId("hp-table").innerHTML = table
      .map((row) => {
        const reduced = reduceToOctave(row.n);
        return (
          `<tr><td><input type="checkbox" data-partial="${row.n}" ${[4, 5, 6, 7].includes(row.n) ? "checked" : ""}></td>` +
          `<td>${row.n}</td><td>${row.hz.toFixed(2)}</td>` +
          `<td>${row.name}</td><td>${row.centsText}</td>` +
          `<td>${reduced.num}/${reduced.den}</td></tr>`
        );
      })
      .join("");

    const svg = byId("hp-ladder");
    svg.innerHTML = "";
    const el = (name: string, attrs: Record<string, string | number>) => {
      const node = document.createElementNS(SVG_NS, name);
      for (const [key, value] of Object.entries(attrs)) node.setAttribute(key, String(value));
      return node;
    };
    const left = 36, right = 706, bottom = 150, top = 16;
    const logMin = Math.log2(table[0].hz);
    const logMax = Math.log2(table[table.length - 1].hz);
    svg.append(el("line", { x1: left, y1: bottom, x2: right, y2: bottom, stroke: "currentColor", "stroke-width": 0.8 }));
    table.forEach((row, index) => {
      const x = left + ((right - left) * index) / (table.length - 1 || 1);
      const y = bottom - ((bottom - top) * (Math.log2(row.hz) - logMin)) / (logMax - logMin || 1);
      svg.append(el("line", { x1: x, y1: bottom, x2: x, y2: y, stroke: "currentColor", "stroke-width": 0.5, opacity: 0.3 }));
      svg.append(el("circle", { cx: x, cy: y, r: 4, fill: Math.abs(row.cents) > 20 ? "#c81e1e" : "currentColor" }));
      const label = el("text", { x, y: bottom + 11, "font-size": 8.5, "text-anchor": "middle", fill: "currentColor" });
      label.textContent = String(row.n);
      svg.append(label);
    });
    byId("hp-note").textContent =
      "Red dots deviate from 12-EDO by more than 20¢ — the partials a string section can tune to only by ear, not by key. " +
      (Number(byId("hp-b").value) > 0
        ? "Inharmonic mode: upper partials stretch sharp, as on real piano strings."
        : "Ideal harmonic mode (B = 0).");
    byId("hp-result").hidden = false;
  }

  byId("hp-go").addEventListener("click", compute);
  byId("hp-play-sel").addEventListener("click", () => {
    if (!table.length) compute();
    const checked = [...document.querySelectorAll<HTMLInputElement>("[data-partial]:checked")]
      .map((box) => Number(box.dataset.partial));
    const partials = table.filter((row) => checked.includes(row.n));
    if (partials.length) {
      sustain(partials.map((row) => ({ hz: row.hz, amp: 1 / Math.sqrt(row.n) })), { dur: 2.5 });
    }
  });
  byId("hp-play-seq").addEventListener("click", () => {
    if (!table.length) compute();
    const ctx = audioContext();
    const t0 = ctx.currentTime + 0.08;
    table.forEach((row, index) => {
      blip(row.hz, t0 + index * 0.22, { dur: 0.3, gain: 0.5 / Math.sqrt(row.n) });
    });
  });
  compute();
</script>
