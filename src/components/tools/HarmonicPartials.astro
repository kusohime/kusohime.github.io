---
// 中文：泛音列计算器：表格、梯形图、可选不谐和系数、加法合成试听。
// English: Harmonic partials calculator: table, ladder, optional
// inharmonicity, additive preview.
---

<section class="tool-panel" aria-label="Harmonic partials calculator">
  <span class="tool-panel-label">Series</span>
  <div class="tool-controls">
    <label class="tool-field">
      <span>Fundamental (name or Hz)</span>
      <input type="text" id="hp-f0" value="A2" size="10" />
    </label>
    <label class="tool-field">
      <span>Partials</span>
      <input type="number" id="hp-max" value="16" min="4" max="32" />
    </label>
    <label class="tool-field">
      <span>Inharmonicity B (piano strings ≈ 0.0002–0.001)</span>
      <input type="number" id="hp-b" value="0" min="0" max="0.01" step="0.0001" />
    </label>
    <button type="button" class="tool-primary" id="hp-go">Compute</button>
    <button type="button" id="hp-play-sel" aria-pressed="false">Sustain selected</button>
    <button type="button" id="hp-play-seq">Hear series</button>
    <div id="hp-kb" style="width: 100%;"></div>
  </div>
  <p class="tool-error" id="hp-error" hidden></p>

  <div class="tool-result" id="hp-result" hidden>
    <div class="tool-table-wrap">
      <table class="tool-table">
        <caption>Check partials to build a chord; while Sustain is on, checking and unchecking changes the sound live.</caption>
        <thead>
          <tr><th></th><th>n</th><th>Hz</th><th>Nearest</th><th>Dev.</th><th>−50&#162;&#8195;0&#8195;+50&#162;</th><th>Reduced</th></tr>
        </thead>
        <tbody id="hp-table"></tbody>
      </table>
    </div>
    <p class="tool-note" id="hp-note"></p>
  </div>
</section>

<script>
  import { partialTable, reduceToOctave } from "../../lib/partials.js";
  import { midiToHz, nameToMidi } from "../../lib/pitch.js";
  import { tone, createDrone, audioContext } from "../../lib/audio.js";
  import { mountKeyboard } from "../../lib/keyboard.js";

  const byId = (id: string) => document.getElementById(id) as any;
  let table: any[] = [];

  // 行内偏差表：把梯形图的"哪些分音偏离 12-EDO"直接画进每一行。
  // Inline deviation meter: the ladder's only real insight — which partials
  // drift from 12-EDO — drawn straight into each row. Centre line is the
  // tempered pitch; the bar shows cents off, clamped to ±50¢, red past 20¢.
  function meter(cents: number): string {
    const off = Math.abs(cents) > 20;
    const c = Math.max(-50, Math.min(50, cents));
    const x = 50 + c; // ±50¢ → 0..100
    const colour = off ? "#c81e1e" : "currentColor";
    return (
      `<svg class="hp-meter" viewBox="0 0 100 16" preserveAspectRatio="none" aria-hidden="true">` +
      `<line x1="30" y1="3" x2="30" y2="13" stroke="currentColor" stroke-width="0.5" opacity="0.25"/>` +
      `<line x1="70" y1="3" x2="70" y2="13" stroke="currentColor" stroke-width="0.5" opacity="0.25"/>` +
      `<line x1="50" y1="1" x2="50" y2="15" stroke="currentColor" stroke-width="0.8" opacity="0.6"/>` +
      `<line x1="50" y1="8" x2="${x}" y2="8" stroke="${colour}" stroke-width="1.4"/>` +
      `<circle cx="${x}" cy="8" r="2.6" fill="${colour}"/>` +
      `</svg>`
    );
  }

  function readF0(): number | null {
    const text = byId("hp-f0").value.trim();
    const asName = nameToMidi(text);
    if (asName !== null) return midiToHz(asName);
    const value = Number(text.replace(/hz$/i, ""));
    return value > 0 ? value : null;
  }

  function compute() {
    const f0 = readF0();
    const error = byId("hp-error");
    if (!f0) {
      error.hidden = false;
      error.textContent = "Enter a note name (A2) or a frequency in Hz (110).";
      return;
    }
    error.hidden = true;
    const maxPartial = Math.max(4, Math.min(32, Number(byId("hp-max").value) || 16));
    const B = Math.max(0, Number(byId("hp-b").value) || 0);
    table = partialTable(f0, maxPartial, B);

    byId("hp-table").innerHTML = table
      .map((row) => {
        const reduced = reduceToOctave(row.n);
        return (
          `<tr${Math.abs(row.cents) > 20 ? ' class="hp-off"' : ""}>` +
          `<td><input type="checkbox" data-partial="${row.n}" ${[4, 5, 6, 7].includes(row.n) ? "checked" : ""}></td>` +
          `<td>${row.n}</td><td>${row.hz.toFixed(2)}</td>` +
          `<td>${row.name}</td><td>${row.centsText}</td>` +
          `<td class="hp-meter-cell">${meter(row.cents)}</td>` +
          `<td>${reduced.num}/${reduced.den}</td></tr>`
        );
      })
      .join("");

    byId("hp-note").textContent =
      "The meter shows each partial's drift from its nearest tempered pitch (centre line); faint ticks mark ±20¢. Red bars exceed 20¢ — the partials a string section can tune to only by ear, not by key. " +
      (Number(byId("hp-b").value) > 0
        ? "Inharmonic mode: upper partials stretch sharp, as on real piano strings."
        : "Ideal harmonic mode (B = 0).");
    byId("hp-result").hidden = false;
    // 持续发声时，改变基频或 B 会让在响的分音即时改调。
    // While sustaining, changing f0 or B retunes the sounding partials live.
    syncDrone();
  }

  // 持续发声：勾选/取消分音时即时加入或退出，直到再次点击停止。
  // Sustained drone: partials join and leave the sound live as their
  // checkboxes change, until the toggle is clicked off.
  const drone = createDrone();
  let droneActive = false;
  const droneButton = byId("hp-play-sel");

  function syncDrone() {
    if (!droneActive) return;
    const checked = new Set(
      [...document.querySelectorAll<HTMLInputElement>("[data-partial]:checked")]
        .map((box) => Number(box.dataset.partial)),
    );
    for (let n = 1; n <= 32; n++) {
      const row = table.find((entry) => entry.n === n);
      if (row && checked.has(n)) {
        drone.set(`p${n}`, { hz: row.hz, amp: 0.22 / Math.sqrt(n) });
      } else {
        drone.remove(`p${n}`);
      }
    }
  }

  function setDroneActive(active: boolean) {
    droneActive = active;
    droneButton.setAttribute("aria-pressed", String(active));
    droneButton.textContent = active ? "Stop sustain" : "Sustain selected";
    if (active) syncDrone();
    else drone.stop();
  }

  byId("hp-go").addEventListener("click", compute);
  droneButton.addEventListener("click", () => {
    if (!table.length) compute();
    setDroneActive(!droneActive);
  });
  byId("hp-table").addEventListener("change", syncDrone);
  byId("hp-play-seq").addEventListener("click", () => {
    if (!table.length) compute();
    const ctx = audioContext();
    const t0 = ctx.currentTime + 0.08;
    // 泛音上行作持续的旋律线扫过，相邻泛音略叠连成一条线。
    // The partials sweep up as a sustained line, adjacent tones overlapping
    // slightly so it reads as one rising line rather than separate clicks.
    table.forEach((row, index) => {
      tone(row.hz, t0 + index * 0.22, { dur: 0.3, gain: 0.34 / Math.sqrt(row.n) });
    });
  });
  mountKeyboard(byId("hp-kb"), { inputs: [byId("hp-f0")], baseOctave: 2 });
  compute();
</script>
