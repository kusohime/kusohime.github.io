---
// 中文：有限移位调式实验台。
// English: Modes of limited transposition laboratory.
---

<section class="tool-panel" aria-label="Messiaen modes laboratory">
  <span class="tool-panel-label">Mode</span>
  <div class="tool-controls">
    <label class="tool-field">
      <span>Mode</span>
      <select id="mm2-mode"></select>
    </label>
    <label class="tool-field">
      <span>Transposition</span>
      <select id="mm2-trans"></select>
    </label>
    <button type="button" id="mm2-play">Hear ascending</button>
    <button type="button" id="mm2-play-chord">Hear as field</button>
  </div>

  <div class="tool-result">
    <div style="display:flex; flex-wrap:wrap; gap: var(--space-lg); align-items:flex-start;">
      <svg id="mm2-clock" class="tool-svg" viewBox="0 0 240 240" xmlns="http://www.w3.org/2000/svg" style="max-width: 15rem;" role="img" aria-label="Mode on the pitch-class clock"></svg>
      <div style="flex:1; min-width: 16rem;">
        <p class="tool-result-figure" id="mm2-notes"></p>
        <p class="tool-note" id="mm2-facts"></p>
        <p class="tool-note" id="mm2-comment"></p>
      </div>
    </div>
  </div>
</section>

<section class="tool-panel" aria-label="Overlap checker">
  <span class="tool-panel-label">Overlap with your material</span>
  <div class="tool-controls">
    <label class="tool-field">
      <span>Your pitches (pcs or note names)</span>
      <input type="text" id="mm2-material" value="C D E F# G# A#" size="26" />
    </label>
    <button type="button" class="tool-primary" id="mm2-check">Check</button>
  </div>
  <p class="tool-note" id="mm2-overlap"></p>
</section>

<script>
  import {
    MESSIAEN_MODES, allTranspositions, symmetryAxes, uniqueTranspositions, overlap,
  } from "../../lib/modes.js";
  import { transposePcs } from "../../lib/pcset.js";
  import { parsePcList } from "../../lib/parse.js";
  import { PC_NAMES, midiToHz } from "../../lib/pitch.js";
  import { sustain, blip, audioContext } from "../../lib/audio.js";

  const byId = (id: string) => document.getElementById(id) as any;
  const SVG_NS = "http://www.w3.org/2000/svg";

  const modeSelect = byId("mm2-mode");
  MESSIAEN_MODES.forEach((mode, index) => {
    const option = document.createElement("option");
    option.value = String(index);
    option.textContent = mode.name;
    modeSelect.append(option);
  });
  modeSelect.value = "1";

  function refreshTranspositions() {
    const mode = MESSIAEN_MODES[Number(modeSelect.value)];
    const transSelect = byId("mm2-trans");
    transSelect.innerHTML = "";
    for (const { t } of allTranspositions(mode.pcs)) {
      const option = document.createElement("option");
      option.value = String(t);
      option.textContent = `T${t}`;
      transSelect.append(option);
    }
  }

  function currentPcs(): number[] {
    const mode = MESSIAEN_MODES[Number(modeSelect.value)];
    const t = Number(byId("mm2-trans").value || 0);
    return transposePcs(mode.pcs, t);
  }

  function render() {
    const mode = MESSIAEN_MODES[Number(modeSelect.value)];
    const pcs = currentPcs();
    byId("mm2-notes").innerHTML = `<strong>${pcs.map((pc) => PC_NAMES[pc]).join(" ")}</strong>`;
    const axes = symmetryAxes(pcs);
    byId("mm2-facts").textContent =
      `${pcs.length} notes · ${uniqueTranspositions(mode.pcs)} distinct transpositions · ` +
      `inversionally symmetric at ${axes.length} ax${axes.length === 1 ? "is" : "es"} (sums ${axes.join(", ")}).`;
    byId("mm2-comment").textContent = mode.note;

    const svg = byId("mm2-clock");
    svg.innerHTML = "";
    const el = (name: string, attrs: Record<string, string | number>) => {
      const node = document.createElementNS(SVG_NS, name);
      for (const [key, value] of Object.entries(attrs)) node.setAttribute(key, String(value));
      return node;
    };
    const cx = 120, cy = 120, r = 88;
    svg.append(el("circle", { cx, cy, r, fill: "none", stroke: "currentColor", "stroke-width": 0.8 }));
    const point = (pc: number, radius = r) => {
      const angle = (Math.PI * 2 * pc) / 12 - Math.PI / 2;
      return [cx + radius * Math.cos(angle), cy + radius * Math.sin(angle)];
    };
    // symmetry axes as faint diameters
    for (const sum of axes) {
      const [x1, y1] = point(sum / 2, r);
      const [x2, y2] = point(sum / 2 + 6, r);
      svg.append(el("line", { x1, y1, x2, y2, stroke: "currentColor", "stroke-width": 0.5, opacity: 0.3, "stroke-dasharray": "4 3" }));
    }
    const path = pcs
      .map((pc, index) => {
        const [x, y] = point(pc);
        return `${index === 0 ? "M" : "L"}${x.toFixed(1)},${y.toFixed(1)}`;
      })
      .join(" ") + " Z";
    svg.append(el("path", { d: path, fill: "none", stroke: "#c81e1e", "stroke-width": 1.1 }));
    for (let pc = 0; pc < 12; pc++) {
      const [x, y] = point(pc);
      const isMember = pcs.includes(pc);
      svg.append(el("circle", { cx: x, cy: y, r: isMember ? 7 : 3, fill: isMember ? "#c81e1e" : "currentColor", opacity: isMember ? 1 : 0.45 }));
      const [lx, ly] = point(pc, r + 16);
      const label = el("text", { x: lx, y: ly + 3, "font-size": 10, "text-anchor": "middle", fill: "currentColor" });
      label.textContent = String(pc);
      svg.append(label);
    }
  }

  function checkOverlap() {
    const parsed = parsePcList(byId("mm2-material").value);
    if (!parsed.ok) {
      byId("mm2-overlap").textContent = `Could not read: ${parsed.bad.join(", ") || "input"}.`;
      return;
    }
    const { inMode, outside } = overlap(parsed.pcs, currentPcs());
    byId("mm2-overlap").textContent =
      `In mode: ${inMode.map((pc) => PC_NAMES[pc]).join(" ") || "—"} · ` +
      `Outside: ${outside.map((pc) => PC_NAMES[pc]).join(" ") || "—"}` +
      (outside.length === 0 ? " — your material sits entirely inside this transposition." : "");
  }

  modeSelect.addEventListener("change", () => {
    refreshTranspositions();
    render();
  });
  byId("mm2-trans").addEventListener("change", render);
  byId("mm2-check").addEventListener("click", checkOverlap);
  byId("mm2-play").addEventListener("click", () => {
    const pcs = currentPcs();
    const ctx = audioContext();
    const t0 = ctx.currentTime + 0.08;
    [...pcs, pcs[0] + 12].forEach((pc, index) =>
      blip(midiToHz(60 + pc), t0 + index * 0.27, { dur: 0.26, gain: 0.42 }));
  });
  byId("mm2-play-chord").addEventListener("click", () => {
    const pcs = currentPcs();
    sustain(pcs.map((pc) => ({ hz: midiToHz(60 + pc), amp: 0.7 / Math.sqrt(pcs.length) })), { dur: 2.6 });
  });

  refreshTranspositions();
  render();
</script>
