---
// 中文：可演奏的二八度網頁鍵盤。聲音由共用 Web Audio 引擎合成，
// 支援指標多點觸控、電腦鍵盤與漸進增強的 Web MIDI 輸入。
// English: A playable two-octave web keyboard. The shared Web Audio engine
// supplies the sound; pointer multi-touch, computer keys, and optional Web MIDI
// all feed the same ownership-aware note state.
---

<section class="tool-panel mk-instrument" aria-label="Playable MIDI keyboard">
  <span class="tool-panel-label">Keyboard</span>

  <div class="mk-toolbar">
    <label class="tool-field">
      <span>Sound</span>
      <select id="mk-preset">
        <option value="organ" selected>Organ</option>
        <option value="pad">Pad</option>
        <option value="warm">Warm</option>
        <option value="pure">Pure</option>
      </select>
    </label>

    <div class="tool-field">
      <span>Register</span>
      <div class="mk-stepper" role="group" aria-label="Keyboard register">
        <button type="button" id="mk-octave-down" aria-label="Move down one octave">−8va</button>
        <output id="mk-register" class="mk-register-label">C3–B4</output>
        <button type="button" id="mk-octave-up" aria-label="Move up one octave">+8va</button>
      </div>
    </div>

    <label class="tool-field">
      <span>Level</span>
      <span class="mk-range-line">
        <input id="mk-volume" type="range" min="0" max="100" value="70" aria-label="Keyboard volume" />
        <output id="mk-volume-value" for="mk-volume">70%</output>
      </span>
    </label>

    <div class="tool-field">
      <span>Pedal &amp; safety</span>
      <div class="mk-action-row">
        <button type="button" id="mk-sustain" aria-pressed="false">
          <span id="mk-sustain-label">Sustain</span>
          <kbd>Space</kbd>
        </button>
        <button type="button" id="mk-clear">
          <span>Clear</span>
          <kbd>Esc</kbd>
        </button>
      </div>
    </div>
  </div>

  <div class="mk-readout">
    <div class="mk-readout-copy">
      <span class="mk-readout-label">Engine</span>
      <span class="mk-readout-value" id="mk-engine-status" aria-live="polite">
        Organ · sound starts with the first note
      </span>
      <span class="mk-readout-label">Sounding</span>
      <span class="mk-readout-value" id="mk-sounding" aria-live="polite">
        No notes
      </span>
      <span class="mk-readout-label">Input</span>
      <span class="mk-readout-value" id="mk-input-status" aria-live="polite">
        Touch · computer keyboard
      </span>
    </div>
    <button type="button" id="mk-midi-connect" class="mk-midi-connect" hidden>
      Connect MIDI
    </button>
  </div>

  <div class="mk-piano-frame">
    <div
      class="mk-piano-scroll"
      id="mk-piano-scroll"
      tabindex="0"
      aria-label="Scrollable two-octave piano keyboard"
    >
      <div class="mk-keys" id="mk-keys" role="group" aria-label="Piano keys"></div>
    </div>
  </div>

  <p class="mk-instructions" aria-label="Keyboard instructions">
    <span><kbd>Z</kbd>–<kbd>M</kbd> lower octave</span>
    <span><kbd>Q</kbd>–<kbd>U</kbd> upper octave</span>
    <span>Arrow keys move piano-key focus</span>
    <span>Tap Sustain to build a chord one note at a time</span>
  </p>

  <p class="tool-note" id="mk-preset-note">
    A steady additive organ that keeps harmonic lines distinct.
  </p>

  <noscript>
    <p class="mk-noscript">This instrument needs JavaScript in order to make sound.</p>
  </noscript>
</section>

<script>
  import { POLY_SYNTH_PRESETS, createPolySynth } from "../../lib/audio.js";
  import {
    COMPUTER_KEYBOARD_MAP,
    buildKeyboardNotes,
    decodeMidiMessage,
    midiToKeyboardLabel,
  } from "../../lib/midi-keyboard.js";

  const byId = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;

  const presetSelect = byId<HTMLSelectElement>("mk-preset");
  const presetNote = byId<HTMLElement>("mk-preset-note");
  const octaveDown = byId<HTMLButtonElement>("mk-octave-down");
  const octaveUp = byId<HTMLButtonElement>("mk-octave-up");
  const registerOutput = byId<HTMLOutputElement>("mk-register");
  const volume = byId<HTMLInputElement>("mk-volume");
  const volumeOutput = byId<HTMLOutputElement>("mk-volume-value");
  const sustainButton = byId<HTMLButtonElement>("mk-sustain");
  const sustainLabel = byId<HTMLElement>("mk-sustain-label");
  const clearButton = byId<HTMLButtonElement>("mk-clear");
  const engineStatus = byId<HTMLElement>("mk-engine-status");
  const soundingOutput = byId<HTMLElement>("mk-sounding");
  const inputStatus = byId<HTMLElement>("mk-input-status");
  const midiConnect = byId<HTMLButtonElement>("mk-midi-connect");
  const pianoScroll = byId<HTMLElement>("mk-piano-scroll");
  const keysHost = byId<HTMLElement>("mk-keys");

  const synth = createPolySynth({ preset: "organ", maxVoices: 24, volume: 0.7 });
  const heldByOwner = new Map<string, number>();
  const ownersByMidi = new Map<number, Set<string>>();
  const sustainedNotes = new Set<number>();
  const sustainSources = new Set<string>();
  let baseMidi = 48; // C3
  let audioReady = false;
  let midiAccess: any = null;
  let destroyed = false;

  const presetCatalog = POLY_SYNTH_PRESETS as unknown as Record<
    string,
    { label: string; description: string }
  >;
  const presetInfo = () =>
    presetCatalog[presetSelect.value] ?? presetCatalog.organ;

  function codeToComputerKey(code: string) {
    if (code.startsWith("Key")) return code.slice(3);
    if (code.startsWith("Digit")) return code.slice(5);
    return null;
  }

  function isEditableTarget(target: EventTarget | null) {
    if (!(target instanceof Element)) return false;
    return Boolean(target.closest("input, select, textarea, button, [contenteditable='true']"));
  }

  function soundKey(midi: number) {
    return `note:${midi}`;
  }

  function effectiveSustain() {
    return sustainSources.size > 0;
  }

  function soundingMidis() {
    const notes = new Set<number>(sustainedNotes);
    for (const [midi, owners] of ownersByMidi) {
      if (owners.size > 0) notes.add(midi);
    }
    return [...notes].sort((a, b) => a - b);
  }

  function updateReadout() {
    const sounding = soundingMidis();
    soundingOutput.textContent = sounding.length
      ? sounding.map(midiToKeyboardLabel).join(" · ")
      : "No notes";
    soundingOutput.classList.toggle("is-sounding", sounding.length > 0);

    for (const key of keysHost.querySelectorAll<HTMLButtonElement>(".mk-key")) {
      const active = sounding.includes(Number(key.dataset.midi));
      key.setAttribute("aria-pressed", String(active));
    }
  }

  function releaseSustainedNotes() {
    for (const midi of sustainedNotes) {
      if (!ownersByMidi.get(midi)?.size) synth.noteOff(soundKey(midi));
    }
    sustainedNotes.clear();
    updateReadout();
  }

  function updateSustainUI() {
    const active = effectiveSustain();
    sustainButton.setAttribute("aria-pressed", String(active));
    sustainButton.setAttribute("aria-label", active ? "Turn sustained hold off" : "Turn sustained hold on");
    sustainLabel.textContent = active ? "Sustain on" : "Sustain";
  }

  function setSustainSource(source: string, active: boolean) {
    const wasActive = effectiveSustain();
    if (active) sustainSources.add(source);
    else sustainSources.delete(source);
    const isActive = effectiveSustain();
    if (wasActive && !isActive) releaseSustainedNotes();
    updateSustainUI();
  }

  function markAudioReady() {
    if (audioReady || destroyed) return;
    audioReady = true;
    engineStatus.textContent = `${presetInfo().label} · sound ready`;
  }

  function unlockSound() {
    if (destroyed) return;
    try {
      const ready = synth.unlock();
      markAudioReady();
      Promise.resolve(ready).then((running) => {
        if (!running && !destroyed) engineStatus.textContent = `${presetInfo().label} · select a key to enable sound`;
      }).catch(() => {
        if (!destroyed) engineStatus.textContent = `${presetInfo().label} · sound could not start`;
      });
    } catch {
      engineStatus.textContent = `${presetInfo().label} · sound is unavailable`;
    }
  }

  function pressNote(owner: string, midi: number, velocity = 0.82) {
    if (destroyed || midi < 0 || midi > 127) return;
    const previous = heldByOwner.get(owner);
    if (previous === midi) return;
    if (previous !== undefined) releaseNote(owner);

    unlockSound();
    let owners = ownersByMidi.get(midi);
    if (!owners) {
      owners = new Set<string>();
      ownersByMidi.set(midi, owners);
    }

    const alreadyHeld = owners.size > 0;
    if (!alreadyHeld && sustainedNotes.has(midi)) {
      synth.noteOff(soundKey(midi), { release: 0.025 });
      sustainedNotes.delete(midi);
    }
    if (!alreadyHeld) synth.noteOn(soundKey(midi), midi, { velocity });

    owners.add(owner);
    heldByOwner.set(owner, midi);
    updateReadout();
  }

  function releaseNote(owner: string) {
    const midi = heldByOwner.get(owner);
    if (midi === undefined) return;
    heldByOwner.delete(owner);
    const owners = ownersByMidi.get(midi);
    owners?.delete(owner);
    if (owners && owners.size === 0) ownersByMidi.delete(midi);

    if (!ownersByMidi.get(midi)?.size) {
      if (effectiveSustain()) sustainedNotes.add(midi);
      else synth.noteOff(soundKey(midi));
    }
    updateReadout();
  }

  function panic({ resetSustain = true } = {}) {
    synth.panic({ release: 0.045 });
    heldByOwner.clear();
    ownersByMidi.clear();
    sustainedNotes.clear();
    if (resetSustain) sustainSources.clear();
    updateSustainUI();
    updateReadout();
  }

  function releaseOwnersWithPrefix(prefix: string) {
    for (const owner of [...heldByOwner.keys()]) {
      if (owner.startsWith(prefix)) releaseNote(owner);
    }
    for (const source of [...sustainSources]) {
      if (source.startsWith(prefix)) setSustainSource(source, false);
    }
  }

  function accessibleNoteName(label: string) {
    return label.replace("#", " sharp ");
  }

  function renderKeyboard() {
    const notes = buildKeyboardNotes(baseMidi, { semitones: 24 });
    keysHost.replaceChildren();
    keysHost.style.width = "42rem";
    registerOutput.value = `${notes[0].name}–${notes.at(-1)?.name ?? ""}`;
    registerOutput.textContent = registerOutput.value;
    octaveDown.disabled = baseMidi <= 24;
    octaveUp.disabled = baseMidi >= 84;

    notes.forEach((note: any, index: number) => {
      const button = document.createElement("button");
      button.type = "button";
      button.className = `mk-key ${note.isBlack ? "mk-black" : "mk-white"}`;
      button.dataset.midi = String(note.midi);
      button.dataset.computerKey = note.computerKey ?? "";
      button.style.left = note.isBlack
        ? `${(note.whiteIndex + 1) * 3 - 0.9}rem`
        : `${note.whiteIndex * 3}rem`;
      button.tabIndex = index === 0 ? 0 : -1;
      button.setAttribute("aria-label", `${accessibleNoteName(note.name)}${note.computerKey ? `, computer key ${note.computerKey}` : ""}`);
      button.setAttribute("aria-pressed", "false");
      button.title = note.computerKey ? `${note.name} · ${note.computerKey}` : note.name;

      const noteLabel = document.createElement("span");
      noteLabel.className = "mk-key-note";
      noteLabel.textContent = note.name;
      const shortcut = document.createElement("span");
      shortcut.className = "mk-key-shortcut";
      shortcut.textContent = note.computerKey ?? "";
      shortcut.setAttribute("aria-hidden", "true");
      button.append(noteLabel, shortcut);

      button.addEventListener("pointerdown", (event) => {
        if (event.pointerType === "mouse" && event.button !== 0) return;
        // Keep touch panning available: a drag scrolls the wide keyboard and
        // naturally emits pointercancel, while a stationary touch plays.
        if (event.pointerType !== "touch") event.preventDefault();
        button.dataset.suppressClick = "true";
        try { button.setPointerCapture(event.pointerId); } catch {}
        pressNote(`pointer:${event.pointerId}`, note.midi, event.pointerType === "mouse" ? 0.82 : 0.74);
      });

      const releasePointer = (event: PointerEvent) => {
        releaseNote(`pointer:${event.pointerId}`);
      };
      button.addEventListener("pointerup", releasePointer);
      button.addEventListener("pointercancel", (event) => {
        delete button.dataset.suppressClick;
        releasePointer(event);
      });
      button.addEventListener("lostpointercapture", releasePointer);

      button.addEventListener("keydown", (event) => {
        if ((event.key !== "Enter" && event.key !== " ") || event.repeat) return;
        event.preventDefault();
        button.dataset.suppressClick = "true";
        pressNote(`focused:${note.midi}`, note.midi, 0.82);
      });
      button.addEventListener("keyup", (event) => {
        if (event.key !== "Enter" && event.key !== " ") return;
        event.preventDefault();
        releaseNote(`focused:${note.midi}`);
      });

      // Screen readers can dispatch click without a pointer or key sequence.
      button.addEventListener("click", () => {
        if (button.dataset.suppressClick === "true") {
          delete button.dataset.suppressClick;
          return;
        }
        const owner = `assistive:${note.midi}:${performance.now()}`;
        pressNote(owner, note.midi, 0.78);
        window.setTimeout(() => releaseNote(owner), 550);
      });

      keysHost.append(button);
    });
    updateReadout();
    pianoScroll.scrollLeft = 0;
  }

  keysHost.addEventListener("keydown", (event) => {
    const current = (event.target as Element | null)?.closest<HTMLButtonElement>(".mk-key");
    if (!current) return;
    const keys = [...keysHost.querySelectorAll<HTMLButtonElement>(".mk-key")];
    const currentIndex = keys.indexOf(current);
    let nextIndex: number | null = null;
    if (event.key === "ArrowRight") nextIndex = Math.min(keys.length - 1, currentIndex + 1);
    if (event.key === "ArrowLeft") nextIndex = Math.max(0, currentIndex - 1);
    if (event.key === "ArrowUp") nextIndex = Math.min(keys.length - 1, currentIndex + 12);
    if (event.key === "ArrowDown") nextIndex = Math.max(0, currentIndex - 12);
    if (event.key === "Home") nextIndex = 0;
    if (event.key === "End") nextIndex = keys.length - 1;
    if (nextIndex === null) return;
    event.preventDefault();
    current.tabIndex = -1;
    keys[nextIndex].tabIndex = 0;
    keys[nextIndex].focus();
  });

  presetSelect.addEventListener("change", () => {
    panic();
    synth.setPreset(presetSelect.value);
    const info = presetInfo();
    presetNote.textContent = info.description;
    engineStatus.textContent = audioReady
      ? `${info.label} · sound ready`
      : `${info.label} · sound starts with the first note`;
  });

  volume.addEventListener("input", () => {
    const percent = Math.max(0, Math.min(100, Number(volume.value) || 0));
    synth.setVolume(percent / 100);
    volumeOutput.value = `${percent}%`;
    volumeOutput.textContent = volumeOutput.value;
  });

  octaveDown.addEventListener("click", () => {
    panic();
    baseMidi = Math.max(24, baseMidi - 12);
    renderKeyboard();
  });

  octaveUp.addEventListener("click", () => {
    panic();
    baseMidi = Math.min(84, baseMidi + 12);
    renderKeyboard();
  });

  sustainButton.addEventListener("click", () => {
    setSustainSource("button", !sustainSources.has("button"));
  });
  clearButton.addEventListener("click", () => panic());

  document.addEventListener("keydown", (event) => {
    if (event.code === "Escape") {
      const isEditing = event.target instanceof Element
        && Boolean(event.target.closest("input, select, textarea, [contenteditable='true']"));
      if (!isEditing) {
        event.preventDefault();
        panic();
      }
      return;
    }
    if (isEditableTarget(event.target) || event.ctrlKey || event.metaKey || event.altKey) return;
    if (event.code === "Space") {
      event.preventDefault();
      if (!event.repeat) setSustainSource("space", true);
      return;
    }
    if (event.repeat) return;
    const key = codeToComputerKey(event.code);
    const offset = key ? COMPUTER_KEYBOARD_MAP[key] : undefined;
    if (offset === undefined) return;
    event.preventDefault();
    pressNote(`computer:${event.code}`, baseMidi + offset, 0.82);
  });

  document.addEventListener("keyup", (event) => {
    if (event.code === "Space" && sustainSources.has("space")) {
      event.preventDefault();
      setSustainSource("space", false);
    }
    releaseNote(`computer:${event.code}`);
  });

  function handleMidiMessage(event: any, inputId: string) {
    const message = decodeMidiMessage(event.data) as any;
    if (!message) return;
    const prefix = `midi:${inputId}:${message.channel}:`;
    if (message.type === "note-on") {
      pressNote(`${prefix}${message.midi}`, message.midi, message.velocity / 127);
    } else if (message.type === "note-off") {
      releaseNote(`${prefix}${message.midi}`);
    } else if (message.type === "sustain") {
      setSustainSource(`${prefix}pedal`, message.active);
    } else if (message.type === "panic") {
      panic();
    }
  }

  function refreshMidiInputs() {
    if (!midiAccess) return;
    const inputs = [...midiAccess.inputs.values()] as any[];
    const connected = inputs.filter((input) => input.state === "connected");
    for (const input of inputs) {
      input.onmidimessage = (event: any) => handleMidiMessage(event, input.id);
    }
    inputStatus.textContent = connected.length
      ? `Touch · computer keyboard · ${connected.length} MIDI ${connected.length === 1 ? "input" : "inputs"}`
      : "Touch · computer keyboard · waiting for MIDI";
  }

  if (typeof (navigator as any).requestMIDIAccess === "function") {
    midiConnect.hidden = false;
    inputStatus.textContent = "Touch · computer keyboard · MIDI available";
    midiConnect.addEventListener("click", async () => {
      unlockSound();
      midiConnect.disabled = true;
      midiConnect.textContent = "Connecting…";
      try {
        midiAccess = await (navigator as any).requestMIDIAccess({ sysex: false });
        midiConnect.textContent = "MIDI connected";
        refreshMidiInputs();
        midiAccess.onstatechange = (event: any) => {
          if (event.port?.state === "disconnected") {
            releaseOwnersWithPrefix(`midi:${event.port.id}:`);
          }
          refreshMidiInputs();
        };
      } catch {
        midiConnect.disabled = false;
        midiConnect.textContent = "Try MIDI again";
        inputStatus.textContent = "MIDI permission was not granted · touch and computer keys still work";
      }
    });
  }

  window.addEventListener("blur", () => panic());
  document.addEventListener("visibilitychange", () => {
    if (document.hidden) panic();
  });
  window.addEventListener("pagehide", () => {
    if (destroyed) return;
    destroyed = true;
    synth.destroy();
  });

  renderKeyboard();
</script>
