---
// 中文：音级集合分析器：标准序、原型、Forte 名称、音程向量、时钟图。
// English: Pitch-class set analyzer: normal order, prime form, Forte
// label, interval vector, clockface.
---

<section class="tool-panel" aria-label="Pitch-class set analysis">
  <span class="tool-panel-label">Set input</span>
  <div class="tool-controls">
    <label class="tool-field">
      <span>Pitch classes (0–11, T/E, or note names)</span>
      <input type="text" id="pcs-input" value="0 1 4 6" size="24" />
    </label>
    <button type="button" class="tool-primary" id="pcs-go">Analyze</button>
    <button type="button" id="pcs-play-chord">Hear as chord</button>
    <button type="button" id="pcs-play-asc">Hear ascending</button>
  </div>
  <p class="tool-error" id="pcs-error" hidden></p>

  <div class="tool-result" id="pcs-result" hidden>
    <div style="display:flex; flex-wrap:wrap; gap: var(--space-lg); align-items:flex-start;">
      <svg id="pcs-clock" class="tool-svg" viewBox="0 0 240 240" xmlns="http://www.w3.org/2000/svg" style="max-width: 15rem;" role="img" aria-label="Pitch-class clockface"></svg>
      <div class="tool-table-wrap" style="flex:1; min-width: 16rem;">
        <table class="tool-table">
          <tbody id="pcs-table"></tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<script>
  import { analyzeSet } from "../../lib/pcset.js";
  import { parsePcList } from "../../lib/parse.js";
  import { PC_NAMES, midiToHz } from "../../lib/pitch.js";
  import { sustain, blip, audioContext } from "../../lib/audio.js";

  const byId = (id: string) => document.getElementById(id) as any;
  const SVG_NS = "http://www.w3.org/2000/svg";
  let currentPcs: number[] = [];

  function analyze() {
    const parsed = parsePcList(byId("pcs-input").value);
    const error = byId("pcs-error");
    if (!parsed.ok) {
      error.hidden = false;
      error.textContent = `Could not read: ${parsed.bad.join(", ") || "input"}. Use integers (0–11, T/E) or note names (C E G).`;
      byId("pcs-result").hidden = true;
      return;
    }
    error.hidden = true;
    const analysis = analyzeSet(parsed.pcs);
    currentPcs = analysis.pcs;

    const zText = analysis.zPartners.length
      ? analysis.zPartners.map((z: any) => `${z.forte} ${z.primeFormString}`).join(", ")
      : "—";
    const rows: [string, string][] = [
      ["Input (as pcs)", analysis.pcs.join(" ")],
      ["Normal order", `[${analysis.normalOrder.join(", ")}]`],
      ["Prime form (Rahn)", analysis.primeFormString],
      ["Forte class", analysis.forte ?? "—"],
      ["Interval vector", analysis.intervalVectorString],
      ["Z-partner", zText],
      ["Complement", `${analysis.complement.forte ?? "—"} ${analysis.complement.primeFormString}`],
    ];
    byId("pcs-table").innerHTML = rows
      .map(([k, v]) => `<tr><th scope="row">${k}</th><td${k === "Forte class" ? ' class="is-accent"' : ""}>${v}</td></tr>`)
      .join("");

    // clockface
    const svg = byId("pcs-clock");
    svg.innerHTML = "";
    const el = (name: string, attrs: Record<string, string | number>) => {
      const node = document.createElementNS(SVG_NS, name);
      for (const [key, value] of Object.entries(attrs)) node.setAttribute(key, String(value));
      return node;
    };
    const cx = 120, cy = 120, r = 88;
    svg.append(el("circle", { cx, cy, r, fill: "none", stroke: "currentColor", "stroke-width": 0.8 }));
    const point = (pc: number, radius = r) => {
      const angle = (Math.PI * 2 * pc) / 12 - Math.PI / 2;
      return [cx + radius * Math.cos(angle), cy + radius * Math.sin(angle)];
    };
    // polygon connecting members
    if (currentPcs.length > 1) {
      const path = currentPcs
        .map((pc, index) => {
          const [x, y] = point(pc);
          return `${index === 0 ? "M" : "L"}${x.toFixed(1)},${y.toFixed(1)}`;
        })
        .join(" ") + " Z";
      svg.append(el("path", { d: path, fill: "none", stroke: "#c81e1e", "stroke-width": 1.1 }));
    }
    for (let pc = 0; pc < 12; pc++) {
      const [x, y] = point(pc);
      const isMember = currentPcs.includes(pc);
      svg.append(el("circle", { cx: x, cy: y, r: isMember ? 7 : 3, fill: isMember ? "#c81e1e" : "currentColor", opacity: isMember ? 1 : 0.45 }));
      const [lx, ly] = point(pc, r + 16);
      const label = el("text", { x: lx, y: ly + 3, "font-size": 10, "text-anchor": "middle", fill: "currentColor" });
      label.textContent = String(pc);
      svg.append(label);
    }
    byId("pcs-result").hidden = false;
  }

  byId("pcs-go").addEventListener("click", analyze);
  byId("pcs-play-chord").addEventListener("click", () => {
    analyze();
    if (currentPcs.length) {
      sustain(currentPcs.map((pc) => ({ hz: midiToHz(60 + pc), amp: 0.8 / Math.sqrt(currentPcs.length) })), { dur: 2 });
    }
  });
  byId("pcs-play-asc").addEventListener("click", () => {
    analyze();
    const ctx = audioContext();
    const t0 = ctx.currentTime + 0.08;
    currentPcs.forEach((pc, index) => blip(midiToHz(60 + pc), t0 + index * 0.3, { dur: 0.28, gain: 0.45 }));
  });
  analyze();
</script>
