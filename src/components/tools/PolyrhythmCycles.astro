---
// 中文：节奏实验台：复节奏重合点、相位卡农（Reich 式连续相移）、多轨节拍器。
// English: Rhythm lab: polyrhythm coincidences, phase canon with a
// continuous entry offset (Reich-style), and a multi-track metronome.
---

<section class="tool-panel" aria-label="Polyrhythm laboratory">
  <span class="tool-panel-label">Layers &amp; coincidences</span>

  <div class="tool-controls">
    <label class="tool-field">
      <span>Attacks per cycle (up to 4 layers)</span>
      <input type="text" id="pr-counts" value="3, 4" size="14" />
    </label>
    <label class="tool-field">
      <span>Cycle length (seconds)</span>
      <input type="number" id="pr-seconds" value="3" min="0.5" max="20" step="0.5" />
    </label>
    <button type="button" class="tool-primary" id="pr-play">Play</button>
    <button type="button" id="pr-play-coincidence">Coincidences only</button>
    <button type="button" id="pr-stop">Stop</button>
  </div>

  <p class="tool-error" id="pr-error" hidden></p>

  <div class="tool-result">
    <p class="tool-note" id="pr-summary"></p>
    <svg id="pr-linear" class="tool-svg" viewBox="0 0 720 150" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Linear attack grid with playhead; drag to reposition while playing" style="touch-action: none; cursor: ew-resize;"></svg>
    <svg id="pr-circle" class="tool-svg" viewBox="0 0 240 240" xmlns="http://www.w3.org/2000/svg" style="max-width: 16rem; margin-top: var(--space-md);" role="img" aria-label="Cyclic view"></svg>
    <p class="tool-note">
      Playback loops until Stop. While playing, drag anywhere on the linear
      grid to move the playhead — the loop continues from where you put it.
    </p>
  </div>
</section>

<section class="tool-panel" aria-label="Phase canon">
  <span class="tool-panel-label">Canon &amp; phase</span>

  <div class="tool-controls">
    <label class="tool-field">
      <span>Pattern (note names or x · . rest · _ hold)</span>
      <input type="text" id="cn-pattern" value="E4 F#4 B4 C#5 D5 F#4 E4 C#5 B4 F#4 D5 C#5" size="44" />
    </label>
    <label class="tool-field">
      <span>Preset</span>
      <select id="cn-preset"><option value="">—</option></select>
    </label>
    <div id="cn-kb" style="width: 100%;"></div>
  </div>

  <div class="tool-controls" style="margin-top: var(--space-sm);">
    <label class="tool-field">
      <span>Tempo (quarter = BPM)</span>
      <input type="number" id="cn-bpm" value="72" min="20" max="240" />
    </label>
    <label class="tool-field">
      <span>Steps per quarter</span>
      <select id="cn-spq">
        <option value="2">2 (eighths)</option>
        <option value="3">3 (triplets)</option>
        <option value="4" selected>4 (sixteenths)</option>
        <option value="6">6 (sextuplets)</option>
      </select>
    </label>
    <label class="tool-field">
      <span>Voice 2 transposition (semitones)</span>
      <input type="number" id="cn-transpose" value="0" min="-24" max="24" />
    </label>
    <button type="button" class="tool-primary" id="cn-play">Play</button>
    <button type="button" id="cn-stop">Stop</button>
  </div>

  <div class="tool-controls" style="margin-top: var(--space-sm);">
    <label class="tool-field">
      <span><input type="radio" name="cn-mode" id="cn-mode-locked" checked /> Locked offset (canon)</span>
    </label>
    <label class="tool-field" style="flex: 1; min-width: 16rem;">
      <span>Entry offset — continuous, 0 to 1 cycle</span>
      <span class="range-pair">
        <input type="range" id="cn-offset" min="0" max="1" step="0.001" value="0.25" />
        <output id="cn-offset-out"></output>
      </span>
    </label>
  </div>

  <div class="tool-controls" style="margin-top: var(--space-sm);">
    <label class="tool-field">
      <span><input type="radio" name="cn-mode" id="cn-mode-phasing" /> Gradual phasing (Reich)</span>
    </label>
    <label class="tool-field" style="flex: 1; min-width: 16rem;">
      <span>Voice 2 tempo ratio</span>
      <span class="range-pair">
        <input type="range" id="cn-rate" min="0.94" max="1.06" step="0.001" value="1.01" />
        <output id="cn-rate-out"></output>
      </span>
    </label>
  </div>

  <p class="tool-error" id="cn-error" hidden></p>
  <p class="tool-note" id="cn-readout"></p>

  <div class="tool-result">
    <div class="tool-controls" style="margin-bottom: var(--space-sm);">
      <button type="button" id="cn-view-lines" aria-pressed="true">Lines</button>
      <button type="button" id="cn-view-rings" aria-pressed="false">Rings</button>
    </div>
    <svg id="cn-lines" class="tool-svg" viewBox="0 0 720 130" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Two voices as rows; the lower row slides by the current displacement"></svg>
    <svg id="cn-rings" class="tool-svg" viewBox="0 0 240 240" xmlns="http://www.w3.org/2000/svg" style="max-width: 16rem;" role="img" aria-label="Two voices on the cycle; the inner ring is rotated by the current offset"></svg>
    <p class="tool-note">
      Voice 1 above (or outer ring), voice 2 below (or inner ring), slid by
      the current displacement; the hollow halo marks where voice 2's
      pattern begins. While playing, a red line sweeps the cycle — the
      playhead is the only line in these views.
    </p>
  </div>
</section>

<section class="tool-panel" aria-label="Multi-track metronome">
  <span class="tool-panel-label">Multi-track metronome</span>

  <div class="tool-table-wrap">
    <table class="tool-table" id="mt-table">
      <thead>
        <tr>
          <th>On</th><th>Tempo (♩/min)</th><th>Clicks every</th>
          <th>Beats per bar</th><th>Sound</th>
        </tr>
      </thead>
      <tbody id="mt-tracks"></tbody>
    </table>
  </div>

  <div class="tool-controls" style="margin-top: var(--space-sm);">
    <button type="button" class="tool-primary" id="mt-start">Start</button>
    <button type="button" id="mt-stop">Stop</button>
  </div>

  <div class="tool-result">
    <svg id="mt-grid" class="tool-svg" viewBox="0 0 720 40" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Click grid of the active tracks over six seconds"></svg>
    <p class="tool-note" id="mt-grid-note"></p>
  </div>
  <p class="tool-note">
    Each track may run at its own quarter-note tempo, or share a tempo while
    clicking a different note value (a dotted-eighth track against a quarter
    track at the same ♩ gives the 3:4 of a metric modulation in sound).
    The first beat of each bar is accented. Tempo and meter changes apply
    live, on the next scheduled click.
  </p>
</section>

<script>
  import { cycleAttacks } from "../../lib/tempo.js";
  import { fnum } from "../../lib/fraction.js";
  import { parseCountList } from "../../lib/parse.js";
  import { parsePattern, driftPeriodSeconds, attackDurationSteps, PRESETS } from "../../lib/canon.js";
  import { midiToHz } from "../../lib/pitch.js";
  import { blip, tone, createClock, stopAll, audioContext } from "../../lib/audio.js";
  import { mountKeyboard } from "../../lib/keyboard.js";

  const byId = (id: string) => document.getElementById(id) as any;
  const SVG_NS = "http://www.w3.org/2000/svg";
  const LAYER_FREQS = [880, 587.33, 392, 261.63];

  function el(name: string, attrs: Record<string, string | number>) {
    const node = document.createElementNS(SVG_NS, name);
    for (const [key, value] of Object.entries(attrs)) node.setAttribute(key, String(value));
    return node;
  }

  /* ---------- Panel 1: polyrhythm cycles ---------- */

  function currentCounts() {
    const parsed = parseCountList(byId("pr-counts").value, { min: 1, max: 48 });
    const error = byId("pr-error");
    if (!parsed.ok || parsed.values.length > 4) {
      error.hidden = false;
      error.textContent = parsed.values.length > 4
        ? "Use at most 4 layers."
        : `Could not read: ${parsed.bad.join(", ") || "input"}. Enter integers like “3, 4, 5”.`;
      return null;
    }
    error.hidden = true;
    return parsed.values;
  }

  function draw() {
    const counts = currentCounts();
    if (!counts) return;
    const { positions, coincidences } = cycleAttacks(counts);

    const lcm = counts.reduce((a, b) => {
      const gcd = (x: number, y: number): number => (y ? gcd(y, x % y) : x);
      return (a / gcd(a, b)) * b;
    });
    byId("pr-summary").textContent =
      `${counts.join(" : ")} — smallest common grid: ${lcm} divisions; ` +
      `${positions.length} distinct attack points; ${coincidences.length} coincidence${coincidences.length === 1 ? "" : "s"} per cycle.`;

    // 重合点不再画成竖线（避免与播放指针混淆）：参与重合的点本身
    // 涂红，时间轴上加红色菱形。线条只属于播放指针。
    // Coincidences are no longer vertical lines (those read as playheads):
    // the coinciding attack dots themselves turn red, with a red diamond
    // on the time axis. Lines belong to the playhead alone.
    const redSteps = counts.map(() => new Set<number>());
    for (const c of coincidences) {
      for (const layer of c.layers) {
        redSteps[layer].add(Math.round(fnum(c.at) * counts[layer]));
      }
    }

    const linear = byId("pr-linear");
    linear.innerHTML = "";
    const left = 30, right = 700, top = 18, rowGap = 30;
    counts.forEach((count, layer) => {
      const y = top + layer * rowGap;
      linear.append(el("line", { x1: left, y1: y, x2: right, y2: y, stroke: "currentColor", "stroke-width": 0.6, opacity: 0.45 }));
      for (let k = 0; k < count; k++) {
        const x = left + ((right - left) * k) / count;
        const coincides = redSteps[layer].has(k);
        linear.append(el("circle", { cx: x, cy: y, r: coincides ? 4.8 : 4.2, fill: coincides ? "#c81e1e" : "currentColor" }));
      }
      const label = el("text", { x: 6, y: y + 3.5, "font-size": 10, fill: "currentColor" });
      label.textContent = String(count);
      linear.append(label);
    });
    const axisY = top + counts.length * rowGap;
    linear.append(el("line", { x1: left, y1: axisY, x2: right, y2: axisY, stroke: "currentColor", "stroke-width": 1 }));
    for (const c of coincidences) {
      const x = left + (right - left) * fnum(c.at);
      linear.append(el("rect", {
        x: x - 4.4, y: axisY - 4.4, width: 8.8, height: 8.8,
        fill: "#c81e1e", transform: `rotate(45 ${x} ${axisY})`,
      }));
    }
    linear.setAttribute("viewBox", `0 0 720 ${axisY + 18}`);

    const circle = byId("pr-circle");
    circle.innerHTML = "";
    const cx = 120, cy = 120;
    circle.append(el("circle", { cx, cy, r: 95, fill: "none", stroke: "currentColor", "stroke-width": 0.6, opacity: 0.4 }));
    counts.forEach((count, layer) => {
      const r = 95 - layer * 18;
      circle.append(el("circle", { cx, cy, r, fill: "none", stroke: "currentColor", "stroke-width": 0.5, opacity: 0.25 }));
      for (let k = 0; k < count; k++) {
        const angle = (2 * Math.PI * k) / count - Math.PI / 2;
        const coincides = redSteps[layer].has(k);
        circle.append(el("circle", {
          cx: cx + r * Math.cos(angle),
          cy: cy + r * Math.sin(angle),
          r: coincides ? 4.2 : 3.6,
          fill: coincides ? "#c81e1e" : "currentColor",
        }));
      }
    });

    // 播放指针：线性图上一条可拖动的竖线，圆图上一条转动的半径。
    // Playheads: a draggable vertical line on the grid, a turning radius
    // on the circle. Hidden until playback starts.
    linear.append(el("line", {
      x1: left, y1: top - 12, x2: left, y2: axisY,
      stroke: "#c81e1e", "stroke-width": 1.8, opacity: 0, id: "pr-ph-line",
    }));
    circle.append(el("line", {
      x1: cx, y1: cy, x2: cx, y2: cy - 100,
      stroke: "#c81e1e", "stroke-width": 1.4, opacity: 0, id: "pr-ph-radius",
    }));
  }

  /* 连续循环播放：look-ahead 时钟逐拍调度，直到 Stop。 */
  /* Continuous looped playback: the look-ahead clock schedules attack by
     attack until Stop. The playhead is draggable mid-flight: scrubbing
     re-anchors the cycle origin, and future events follow. */
  const cycleClock = createClock();
  let cycleEvents: { frac: number; layers: number[] }[] = [];
  let cyclePhaseOrigin = 0;
  let cycleSeconds = 3;
  let cycleEventPtr = 0;
  let cycleCoincOnly = false;
  let cyclePlayheadTimer: number | null = null;

  const cyclePhaseNow = () => {
    const elapsed = audioContext().currentTime - cyclePhaseOrigin;
    return ((elapsed / cycleSeconds) % 1 + 1) % 1;
  };

  const seekCyclePhase = (phase: number) => {
    cyclePhaseOrigin = audioContext().currentTime - phase * cycleSeconds;
    cycleEventPtr = cycleEvents.findIndex((event) => event.frac >= phase);
    if (cycleEventPtr < 0) cycleEventPtr = cycleEvents.length; // next cycle
  };

  function tickCycle(from: number, to: number) {
    if (!cycleEvents.length) return;
    let guard = 0;
    while (guard++ < 4000) {
      const event = cycleEvents[cycleEventPtr % cycleEvents.length];
      const cycleNumber = Math.floor(cycleEventPtr / cycleEvents.length);
      const when = cyclePhaseOrigin + (cycleNumber + event.frac) * cycleSeconds;
      if (when >= to) break;
      if (when >= from) {
        const isCoincidence = event.layers.length > 1;
        if (!cycleCoincOnly || isCoincidence) {
          for (const layer of event.layers) {
            blip(LAYER_FREQS[layer % LAYER_FREQS.length], when, {
              dur: 0.12,
              gain: isCoincidence ? 0.65 : 0.4,
              type: layer % 2 === 0 ? "sine" : "triangle",
            });
          }
        }
      }
      cycleEventPtr += 1;
    }
  }

  function updateCyclePlayhead() {
    const line = document.getElementById("pr-ph-line");
    const radius = document.getElementById("pr-ph-radius");
    const playing = cycleClock.running();
    if (line) {
      line.setAttribute("opacity", playing ? "1" : "0");
      if (playing) {
        const x = 30 + (700 - 30) * cyclePhaseNow();
        line.setAttribute("x1", String(x));
        line.setAttribute("x2", String(x));
      }
    }
    if (radius) {
      radius.setAttribute("opacity", playing ? "1" : "0");
      if (playing) {
        const angle = 2 * Math.PI * cyclePhaseNow() - Math.PI / 2;
        radius.setAttribute("x2", String(120 + 100 * Math.cos(angle)));
        radius.setAttribute("y2", String(120 + 100 * Math.sin(angle)));
      }
    }
  }

  function startCycle(coincidencesOnly: boolean) {
    const counts = currentCounts();
    if (!counts) return;
    const { positions } = cycleAttacks(counts);
    cycleEvents = positions.map((position) => ({
      frac: fnum(position.at),
      layers: position.layers,
    }));
    cycleCoincOnly = coincidencesOnly;
    cycleSeconds = Number(byId("pr-seconds").value) || 3;
    cyclePhaseOrigin = audioContext().currentTime + 0.1;
    cycleEventPtr = 0;
    stopAll();
    cycleClock.start(tickCycle);
    if (cyclePlayheadTimer) window.clearInterval(cyclePlayheadTimer);
    cyclePlayheadTimer = window.setInterval(updateCyclePlayhead, 50);
  }

  function stopCycle() {
    cycleClock.stop();
    if (cyclePlayheadTimer) window.clearInterval(cyclePlayheadTimer);
    cyclePlayheadTimer = null;
    stopAll();
    updateCyclePlayhead();
  }

  // 拖动线性图即移动指针；松手后循环从新位置继续。
  // Dragging the linear grid moves the playhead; the loop continues
  // from wherever you release it.
  const linearSvg = byId("pr-linear");
  let scrubbing = false;
  const scrubTo = (clientX: number) => {
    if (!cycleClock.running()) return;
    const rect = linearSvg.getBoundingClientRect();
    const viewX = ((clientX - rect.left) / rect.width) * 720;
    const phase = Math.min(0.999, Math.max(0, (viewX - 30) / (700 - 30)));
    seekCyclePhase(phase);
    updateCyclePlayhead();
  };
  linearSvg.addEventListener("pointerdown", (event: PointerEvent) => {
    if (!cycleClock.running()) return;
    scrubbing = true;
    scrubTo(event.clientX);
    try {
      linearSvg.setPointerCapture(event.pointerId);
    } catch {}
  });
  linearSvg.addEventListener("pointermove", (event: PointerEvent) => {
    if (scrubbing) scrubTo(event.clientX);
  });
  linearSvg.addEventListener("pointerup", (event: PointerEvent) => {
    scrubbing = false;
    try {
      linearSvg.releasePointerCapture(event.pointerId);
    } catch {}
  });

  // 播放中更改周期时长时保持当前相位不跳变。
  // Changing the cycle length mid-playback preserves the current phase.
  byId("pr-seconds").addEventListener("input", () => {
    if (!cycleClock.running()) return;
    const phase = cyclePhaseNow();
    cycleSeconds = Number(byId("pr-seconds").value) || cycleSeconds;
    seekCyclePhase(phase);
  });

  byId("pr-counts").addEventListener("input", () => {
    const wasPlaying = cycleClock.running();
    const wasCoincOnly = cycleCoincOnly;
    if (wasPlaying) stopCycle();
    draw();
    if (wasPlaying) startCycle(wasCoincOnly);
  });
  byId("pr-play").addEventListener("click", () => startCycle(false));
  byId("pr-play-coincidence").addEventListener("click", () => startCycle(true));
  byId("pr-stop").addEventListener("click", stopCycle);
  draw();

  /* ---------- Panel 2: canon & phase ---------- */

  const presetSelect = byId("cn-preset");
  for (const preset of PRESETS) {
    const option = document.createElement("option");
    option.value = preset.id;
    option.textContent = preset.label;
    presetSelect.append(option);
  }
  presetSelect.addEventListener("change", () => {
    const preset = PRESETS.find((p) => p.id === presetSelect.value);
    if (preset) {
      byId("cn-pattern").value = preset.pattern;
      updateCanonReadout();
    }
  });

  const canonClock = createClock();
  // 每个声部都用增量时间推进；改变 offset / ratio 只影响未来的事件，
  // 因此滑杆在播放中是“连续可调”的，正如 Reich 的渐进过程。
  // Each voice advances by incremental time; offset/ratio changes affect
  // only future events, so the sliders are continuously adjustable during
  // playback — the gradual process itself.
  interface CanonVoice {
    nextTime: number;
    stepIndex: number;
  }
  let canonVoices: CanonVoice[] = [];
  let appliedOffset = 0;

  const canonParams = () => {
    const bpm = Math.min(300, Math.max(20, Number(byId("cn-bpm").value) || 72));
    const spq = Number(byId("cn-spq").value) || 4;
    const stepDur = 60 / bpm / spq;
    const parsed = parsePattern(byId("cn-pattern").value);
    const offset = Number(byId("cn-offset").value);
    const rate = Number(byId("cn-rate").value);
    const phasing = byId("cn-mode-phasing").checked;
    const transpose = Number(byId("cn-transpose").value) || 0;
    return { stepDur, parsed, offset, rate, phasing, transpose };
  };

  function updateCanonReadout() {
    const { stepDur, parsed, offset, rate, phasing } = canonParams();
    byId("cn-offset-out").textContent =
      `${offset.toFixed(3)} ≈ ${(offset * (parsed.steps.length || 0)).toFixed(2)} steps`;
    byId("cn-rate-out").textContent = `× ${rate.toFixed(3)}`;
    const error = byId("cn-error");
    if (!parsed.ok) {
      error.hidden = false;
      error.textContent = `Could not read pattern: ${parsed.bad.join(", ") || "empty"}. Use note names (E4 F#4 …) or x / . steps.`;
      byId("cn-readout").textContent = "";
      return;
    }
    error.hidden = true;
    const patternDur = stepDur * parsed.steps.length;
    const drift = driftPeriodSeconds(patternDur, rate);
    byId("cn-readout").textContent =
      `${parsed.steps.length}-step ${parsed.pitched ? "pitched" : "rhythm"} pattern, ` +
      `one cycle = ${patternDur.toFixed(2)} s. ` +
      (phasing
        ? Number.isFinite(drift)
          ? `Phasing: voice 2 laps the pattern once every ${drift.toFixed(1)} s.`
          : "Phasing ratio 1.000: the voices stay locked."
        : `Locked canon at ${(offset * parsed.steps.length).toFixed(2)} steps.`);
  }

  function scheduleCanon(from: number, to: number) {
    const { stepDur, parsed, offset, rate, phasing, transpose } = canonParams();
    if (!parsed.ok) return;
    const steps = parsed.steps;
    const patternDur = stepDur * steps.length;

    // Apply live offset changes as a delta to voice 2's next event time.
    if (!phasing) {
      const delta = (offset - appliedOffset) * patternDur;
      if (Math.abs(delta) > 1e-9 && canonVoices[1]) {
        canonVoices[1].nextTime += delta;
        appliedOffset = offset;
      }
    }

    canonVoices.forEach((voice, index) => {
      const voiceRate = index === 1 && phasing ? rate : 1;
      const voiceStep = stepDur / voiceRate;
      // Skip anything pushed behind the horizon (e.g. offset slid backward).
      while (voice.nextTime < from) {
        voice.nextTime += voiceStep;
        voice.stepIndex += 1;
      }
      while (voice.nextTime < to) {
        const position = voice.stepIndex % steps.length;
        const step = steps[position];
        if (!step.rest && !step.hold) {
          if (parsed.pitched && step.midi !== null) {
            // 音高卡农奏持续音：时值 = 本步 + 后续 "_" 延音步。
            // Pitched canons sustain: duration = this step plus "_" holds.
            const holdSteps = attackDurationSteps(steps, position);
            tone(midiToHz(step.midi + (index === 1 ? transpose : 0)), voice.nextTime, {
              dur: holdSteps * voiceStep * 0.96,
              gain: index === 0 ? 0.34 : 0.28,
              type: index === 0 ? "sine" : "triangle",
            });
          } else {
            blip(index === 0 ? 880 : 660, voice.nextTime, {
              dur: Math.min(0.22, voiceStep * 0.9),
              gain: index === 0 ? 0.45 : 0.38,
              type: index === 0 ? "sine" : "triangle",
            });
          }
        }
        voice.nextTime += voiceStep;
        voice.stepIndex += 1;
      }
    });
  }

  /* Two views of the same displacement: sliding rows (cf. the familiar
     Clapping Music videos) or concentric rings. The red playhead sweeps
     voice 1's cycle during playback. */
  let canonStartTime = 0;
  let phaseTimer: number | null = null;
  let canonView: "lines" | "rings" = "lines";

  function currentPhaseFraction() {
    const { stepDur, parsed, offset, rate, phasing } = canonParams();
    if (!phasing || !canonClock.running()) return offset;
    const patternDur = stepDur * parsed.steps.length;
    const elapsed = audioContext().currentTime - canonStartTime;
    return (((elapsed * (rate - 1)) / patternDur) % 1 + 1) % 1;
  }

  function canonPlayheadPhase() {
    if (!canonClock.running()) return null;
    const { stepDur, parsed } = canonParams();
    const patternDur = stepDur * parsed.steps.length;
    const elapsed = audioContext().currentTime - canonStartTime;
    return ((elapsed / patternDur) % 1 + 1) % 1;
  }

  function drawRings() {
    const { parsed } = canonParams();
    const svg = byId("cn-rings");
    svg.innerHTML = "";
    if (!parsed.ok) return;
    const steps = parsed.steps;
    const cx = 120, cy = 120;
    const phase = currentPhaseFraction();

    const drawRing = (radius: number, rotation: number, accent: boolean) => {
      svg.append(el("circle", { cx, cy, r: radius, fill: "none", stroke: "currentColor", "stroke-width": 0.5, opacity: 0.3 }));
      steps.forEach((step, index) => {
        const angle = (2 * Math.PI * (index / steps.length + rotation)) - Math.PI / 2;
        const x = cx + radius * Math.cos(angle);
        const y = cy + radius * Math.sin(angle);
        if (step.rest) {
          svg.append(el("circle", { cx: x, cy: y, r: 1.2, fill: "currentColor", opacity: 0.3 }));
        } else if (step.hold) {
          svg.append(el("circle", { cx: x, cy: y, r: 2.4, fill: "none", stroke: accent ? "#c81e1e" : "currentColor", "stroke-width": 1 }));
        } else {
          svg.append(el("circle", { cx: x, cy: y, r: 4, fill: accent ? "#c81e1e" : "currentColor" }));
        }
      });
    };
    drawRing(96, 0, false);
    drawRing(66, phase, true);
    // 声部二起点用空心光环标记，而非中心射线（易被误读为指针）。
    // Voice 2's pattern start is haloed, not drawn as a center radius
    // (which read as a stray playhead).
    const startAngle = 2 * Math.PI * phase - Math.PI / 2;
    svg.append(el("circle", {
      cx: cx + 66 * Math.cos(startAngle),
      cy: cy + 66 * Math.sin(startAngle),
      r: 8, fill: "none", stroke: "#c81e1e", "stroke-width": 1,
    }));
    // playhead radius (voice 1's position in its cycle)
    const playhead = canonPlayheadPhase();
    if (playhead !== null) {
      const playheadAngle = 2 * Math.PI * playhead - Math.PI / 2;
      svg.append(el("line", {
        x1: cx, y1: cy,
        x2: cx + 104 * Math.cos(playheadAngle),
        y2: cy + 104 * Math.sin(playheadAngle),
        stroke: "#c81e1e", "stroke-width": 1.6, opacity: 0.85,
      }));
    }
  }

  function drawLines() {
    const { parsed } = canonParams();
    const svg = byId("cn-lines");
    svg.innerHTML = "";
    if (!parsed.ok) return;
    const steps = parsed.steps;
    const left = 30, right = 706, width = right - left;
    const rows = [
      { y: 38, rotation: 0, accent: false },
      { y: 92, rotation: currentPhaseFraction(), accent: true },
    ];

    for (const row of rows) {
      svg.append(el("line", { x1: left, y1: row.y, x2: right, y2: row.y, stroke: "currentColor", "stroke-width": 0.5, opacity: 0.35 }));
      steps.forEach((step, index) => {
        const position = ((index / steps.length + row.rotation) % 1 + 1) % 1;
        const x = left + position * width;
        if (step.rest) {
          svg.append(el("line", { x1: x, y1: row.y - 2.5, x2: x, y2: row.y + 2.5, stroke: "currentColor", "stroke-width": 0.7, opacity: 0.3 }));
        } else if (step.hold) {
          svg.append(el("circle", { cx: x, cy: row.y, r: 2.6, fill: "none", stroke: row.accent ? "#c81e1e" : "currentColor", "stroke-width": 1 }));
        } else {
          svg.append(el("circle", { cx: x, cy: row.y, r: 4.6, fill: row.accent ? "#c81e1e" : "currentColor" }));
        }
      });
    }
    const v1 = el("text", { x: 4, y: 41, "font-size": 9, fill: "currentColor" });
    v1.textContent = "V1";
    const v2 = el("text", { x: 4, y: 95, "font-size": 9, fill: "#c81e1e" });
    v2.textContent = "V2";
    svg.append(v1, v2);
    // halo on voice 2's pattern start
    const startX = left + (((rows[1].rotation % 1) + 1) % 1) * width;
    svg.append(el("circle", {
      cx: startX, cy: 92, r: 8.5, fill: "none", stroke: "#c81e1e", "stroke-width": 1,
    }));
    // playhead sweeping voice 1's cycle
    const playhead = canonPlayheadPhase();
    if (playhead !== null) {
      const x = left + playhead * width;
      svg.append(el("line", {
        x1: x, y1: 16, x2: x, y2: 114,
        stroke: "#c81e1e", "stroke-width": 1.6, opacity: 0.85,
      }));
    }
  }

  function drawCanonViz() {
    if (canonView === "rings") drawRings();
    else drawLines();
  }

  function setCanonView(view: "lines" | "rings") {
    canonView = view;
    // SVG 元素不支持 hidden 属性，须用 style.display 切换。
    // SVG elements ignore the hidden property; toggle style.display.
    byId("cn-lines").style.display = view === "lines" ? "" : "none";
    byId("cn-rings").style.display = view === "rings" ? "" : "none";
    byId("cn-view-lines").setAttribute("aria-pressed", String(view === "lines"));
    byId("cn-view-rings").setAttribute("aria-pressed", String(view === "rings"));
    drawCanonViz();
  }
  byId("cn-view-lines").addEventListener("click", () => setCanonView("lines"));
  byId("cn-view-rings").addEventListener("click", () => setCanonView("rings"));

  byId("cn-play").addEventListener("click", () => {
    const { parsed, offset, phasing, stepDur } = canonParams();
    if (!parsed.ok) {
      updateCanonReadout();
      return;
    }
    const ctx = audioContext();
    const start = ctx.currentTime + 0.1;
    const patternDur = stepDur * parsed.steps.length;
    appliedOffset = phasing ? 0 : offset;
    canonStartTime = start;
    canonVoices = [
      { nextTime: start, stepIndex: 0 },
      { nextTime: start + (phasing ? 0 : offset * patternDur), stepIndex: 0 },
    ];
    canonClock.start(scheduleCanon);
    // 播放期间持续重绘：指针扫过周期，相移模式下位移环/行也随之转动。
    // Redraw continuously while playing: the playhead sweeps the cycle,
    // and in phasing mode the displacement turns with it.
    if (phaseTimer) window.clearInterval(phaseTimer);
    phaseTimer = window.setInterval(drawCanonViz, 80);
    updateCanonReadout();
    drawCanonViz();
  });
  byId("cn-stop").addEventListener("click", () => {
    canonClock.stop();
    if (phaseTimer) window.clearInterval(phaseTimer);
    phaseTimer = null;
    stopAll();
    drawCanonViz();
  });

  for (const id of ["cn-pattern", "cn-bpm", "cn-spq", "cn-offset", "cn-rate", "cn-transpose"]) {
    byId(id).addEventListener("input", () => {
      updateCanonReadout();
      drawCanonViz();
    });
  }
  byId("cn-mode-locked").addEventListener("change", () => {
    updateCanonReadout();
    drawCanonViz();
  });
  byId("cn-mode-phasing").addEventListener("change", () => {
    updateCanonReadout();
    drawCanonViz();
  });
  presetSelect.addEventListener("change", drawCanonViz);
  mountKeyboard(byId("cn-kb"), { inputs: [byId("cn-pattern")] });
  updateCanonReadout();
  setCanonView("lines");

  /* ---------- Panel 3: multi-track metronome ---------- */

  const UNIT_OPTIONS = [
    { label: "whole", quarters: 4 },
    { label: "dotted half", quarters: 3 },
    { label: "half", quarters: 2 },
    { label: "dotted quarter", quarters: 1.5 },
    { label: "quarter", quarters: 1 },
    { label: "triplet quarter", quarters: 2 / 3 },
    { label: "dotted eighth", quarters: 0.75 },
    { label: "eighth", quarters: 0.5 },
    { label: "triplet eighth", quarters: 1 / 3 },
    { label: "sixteenth", quarters: 0.25 },
  ];
  const SOUND_OPTIONS = [
    { label: "high tick", freq: 1318.5 },
    { label: "ping", freq: 880 },
    { label: "mid", freq: 587.33 },
    { label: "low", freq: 392 },
  ];
  const TRACK_DEFAULTS = [
    { on: true, bpm: 120, unit: "quarter", beats: 4, sound: "ping" },
    { on: false, bpm: 120, unit: "dotted eighth", beats: 4, sound: "mid" },
    { on: false, bpm: 90, unit: "quarter", beats: 3, sound: "high tick" },
    { on: false, bpm: 60, unit: "quarter", beats: 1, sound: "low" },
  ];

  const trackBody = byId("mt-tracks");
  TRACK_DEFAULTS.forEach((defaults, index) => {
    const row = document.createElement("tr");
    row.innerHTML =
      `<td><input type="checkbox" data-mt-on="${index}" ${defaults.on ? "checked" : ""}></td>` +
      `<td><input type="number" data-mt-bpm="${index}" value="${defaults.bpm}" min="20" max="300" style="width:5em"></td>` +
      `<td><select data-mt-unit="${index}">${UNIT_OPTIONS.map((u) =>
        `<option ${u.label === defaults.unit ? "selected" : ""}>${u.label}</option>`).join("")}</select></td>` +
      `<td><input type="number" data-mt-beats="${index}" value="${defaults.beats}" min="1" max="13" style="width:4em"></td>` +
      `<td><select data-mt-sound="${index}">${SOUND_OPTIONS.map((s) =>
        `<option ${s.label === defaults.sound ? "selected" : ""}>${s.label}</option>`).join("")}</select></td>`;
    trackBody.append(row);
  });

  const metronomeClock = createClock();
  interface MetronomeTrack {
    nextTime: number;
    beatIndex: number;
  }
  let metronomeTracks: MetronomeTrack[] = [];

  const trackParams = (index: number) => {
    const on = (document.querySelector(`[data-mt-on="${index}"]`) as HTMLInputElement).checked;
    const bpm = Math.min(300, Math.max(20, Number((document.querySelector(`[data-mt-bpm="${index}"]`) as HTMLInputElement).value) || 120));
    const unitLabel = (document.querySelector(`[data-mt-unit="${index}"]`) as HTMLSelectElement).value;
    const quarters = UNIT_OPTIONS.find((u) => u.label === unitLabel)?.quarters ?? 1;
    const beats = Math.min(13, Math.max(1, Number((document.querySelector(`[data-mt-beats="${index}"]`) as HTMLInputElement).value) || 4));
    const soundLabel = (document.querySelector(`[data-mt-sound="${index}"]`) as HTMLSelectElement).value;
    const freq = SOUND_OPTIONS.find((s) => s.label === soundLabel)?.freq ?? 880;
    return { on, interval: (60 / bpm) * quarters, beats, freq };
  };

  function scheduleMetronome(from: number, to: number) {
    metronomeTracks.forEach((track, index) => {
      const params = trackParams(index);
      if (!params.on) {
        // Keep silent tracks aligned with the clock so re-enabling is sane.
        while (track.nextTime < to) {
          track.nextTime += params.interval;
          track.beatIndex += 1;
        }
        return;
      }
      while (track.nextTime < from) {
        track.nextTime += params.interval;
        track.beatIndex += 1;
      }
      while (track.nextTime < to) {
        const accent = track.beatIndex % params.beats === 0;
        blip(accent ? params.freq * 1.5 : params.freq, track.nextTime, {
          dur: 0.09,
          gain: accent ? 0.6 : 0.35,
          type: "sine",
        });
        track.nextTime += params.interval;
        track.beatIndex += 1;
      }
    });
  }

  /* Grid view: each active track's clicks across a six-second window. */
  function drawMetronomeGrid() {
    const svg = byId("mt-grid");
    svg.innerHTML = "";
    const windowSeconds = 6;
    const left = 30, right = 700, rowGap = 26, top = 16;
    const activeTracks = TRACK_DEFAULTS
      .map((_, index) => ({ index, params: trackParams(index) }))
      .filter((track) => track.params.on);

    activeTracks.forEach((track, row) => {
      const y = top + row * rowGap;
      svg.append(el("line", { x1: left, y1: y, x2: right, y2: y, stroke: "currentColor", "stroke-width": 0.5, opacity: 0.4 }));
      const label = el("text", { x: 4, y: y + 3.5, "font-size": 9, fill: "currentColor" });
      label.textContent = String(track.index + 1);
      svg.append(label);
      for (let k = 0; k * track.params.interval <= windowSeconds; k++) {
        const x = left + ((right - left) * (k * track.params.interval)) / windowSeconds;
        const accent = k % track.params.beats === 0;
        if (accent) {
          svg.append(el("line", { x1: x, y1: y - 8, x2: x, y2: y + 8, stroke: "#c81e1e", "stroke-width": 1.6 }));
        } else {
          svg.append(el("line", { x1: x, y1: y - 4.5, x2: x, y2: y + 4.5, stroke: "currentColor", "stroke-width": 1 }));
        }
      }
    });
    // seconds axis
    const axisY = top + Math.max(activeTracks.length, 1) * rowGap;
    svg.append(el("line", { x1: left, y1: axisY, x2: right, y2: axisY, stroke: "currentColor", "stroke-width": 0.8 }));
    for (let second = 0; second <= windowSeconds; second++) {
      const x = left + ((right - left) * second) / windowSeconds;
      svg.append(el("line", { x1: x, y1: axisY - 3, x2: x, y2: axisY + 3, stroke: "currentColor", "stroke-width": 0.8 }));
      const tick = el("text", { x, y: axisY + 13, "font-size": 8.5, "text-anchor": "middle", fill: "currentColor" });
      tick.textContent = `${second}s`;
      svg.append(tick);
    }
    svg.setAttribute("viewBox", `0 0 720 ${axisY + 20}`);
    byId("mt-grid-note").textContent = activeTracks.length
      ? "Tall red marks are bar downbeats; where they line up across rows, the tracks agree."
      : "Enable a track to see its click grid.";
  }

  trackBody.addEventListener("input", drawMetronomeGrid);
  trackBody.addEventListener("change", drawMetronomeGrid);

  byId("mt-start").addEventListener("click", () => {
    const ctx = audioContext();
    const start = ctx.currentTime + 0.1;
    metronomeTracks = TRACK_DEFAULTS.map(() => ({ nextTime: start, beatIndex: 0 }));
    metronomeClock.start(scheduleMetronome);
  });
  byId("mt-stop").addEventListener("click", () => {
    metronomeClock.stop();
    stopAll();
  });
  drawMetronomeGrid();
</script>

<style>
  .range-pair {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.5rem;
    align-items: center;
  }

  .range-pair output {
    font-size: 0.78rem;
    color: var(--color-muted);
    min-width: 7.5rem;
    text-align: right;
  }
</style>
