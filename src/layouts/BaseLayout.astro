---
// 中文：公開頁面共用的 HTML 外殼，包含頁首、主體、頁尾和偏好預載。
// English: Shared public-page shell with header, body, footer, and preference preload.
// Caveat / 注意：此處改動會影響除管理器之外的全部公開頁面。
// Caveat: Changes here affect every public page except the Studio.
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Preferences from "../components/Preferences.astro";
import { translate, type Locale, type TranslationKey } from "../config/locales";
import siteDefaults from "../config/siteDefaults.json";
import { site } from "../config/site";
import "katex/dist/katex.min.css";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  adminOnly?: boolean;
  unavailableLanguages?: Locale[];
}

const {
  title,
  description = site.description,
  noindex = false,
  adminOnly = false,
  unavailableLanguages = [],
} = Astro.props;

const pageTitle = title ? `${title} | ${site.name}` : site.name;
const defaultLanguage = siteDefaults.defaultLanguage;

interface HierarchyBackLink {
  href: string;
  labelKey: TranslationKey;
}

const currentPath = Astro.url.pathname.replace(/\/+$/, "") || "/";
const pathParts = currentPath.split("/").filter(Boolean);

const hierarchyBack = (() => {
  if (currentPath === "/") return undefined;

  if (currentPath === "/admin/guide") {
    return {
      href: "/admin/",
      labelKey: "common.backStudio",
    } satisfies HierarchyBackLink;
  }

  if (currentPath.startsWith("/admin/guide/")) {
    return {
      href: "/admin/guide/",
      labelKey: "common.backGuide",
    } satisfies HierarchyBackLink;
  }

  if (pathParts[0] === "writings" && pathParts.length >= 3) {
    return {
      href: `/writings/${pathParts[1]}/`,
      labelKey: "common.backContents",
    } satisfies HierarchyBackLink;
  }

  const collectionParents: Record<string, TranslationKey> = {
    works: "common.backWorks",
    events: "common.backEvents",
    writings: "common.backWritings",
    tools: "common.backTools",
  };
  const collectionLabel = collectionParents[pathParts[0] ?? ""];

  if (collectionLabel && pathParts.length >= 2) {
    return {
      href: `/${pathParts[0]}/`,
      labelKey: collectionLabel,
    } satisfies HierarchyBackLink;
  }

  return {
    href: "/",
    labelKey: "common.backHome",
  } satisfies HierarchyBackLink;
})();
---

<!doctype html>
<html
  lang="en"
  data-unavailable-languages={unavailableLanguages.length > 0
    ? unavailableLanguages.join(" ")
    : undefined}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon-32.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${site.name} RSS`}
      href="/rss.xml"
    />
    {
      adminOnly && (
        <>
          <style is:inline>
            html {"{"} visibility: hidden; {"}"}
          </style>
          <script is:inline>
            // 管理指南只在本地開發時顯示；這不是線上帳戶系統。
            // The guide appears only in local development; this is not online authentication.
            try {
              const isLocal =
                location.hostname === "localhost" ||
                location.hostname === "127.0.0.1";

              if (!isLocal) {
                location.replace("/admin/");
              } else {
                document.documentElement.style.visibility = "visible";
              }
            } catch {
              location.replace("/admin/");
            }
          </script>
        </>
      )
    }
    <script is:inline define:vars={{ defaultLanguage }}>
      // 在頁面繪製前恢復偏好設定，避免深淺色或字號短暫閃爍。
      // Restore preferences before paint to prevent a theme or font-size flash.
      try {
        const theme = localStorage.getItem("yc-theme");
        const fontSize = localStorage.getItem("yc-font-size");
        const storedLanguage = localStorage.getItem("yc-language");
        const language = storedLanguage ?? defaultLanguage;

        if (theme === "light" || theme === "dark") {
          document.documentElement.dataset.theme = theme;
        }

        if (fontSize === "s" || fontSize === "m" || fontSize === "l") {
          document.documentElement.dataset.fontSize = fontSize;
        }

        if (language === "en" || language === "zh") {
          document.documentElement.lang = language === "zh" ? "zh-Hant-TW" : language;
        }
      } catch {}
    </script>
    <title>{pageTitle}</title>
  </head>
  <body data-style-source="src/styles/global.css">
    <a class="skip-link" href="#main-content" data-i18n-key="common.skip">
      {translate("en", "common.skip")}
    </a>
    <div class="site-shell">
      <Header />
      <div class="site-preferences-rail">
        <Preferences unavailableLanguages={unavailableLanguages} />
      </div>
      <main id="main-content">
        {
          hierarchyBack && (
            <nav class="hierarchy-back-nav" aria-label="Hierarchy navigation">
              <a class="hierarchy-back" href={hierarchyBack.href}>
                <span
                  class="glyph-arrow glyph-arrow--back"
                  data-arrow-glyph
                  aria-hidden="true"
                ></span>
                <span data-i18n-key={hierarchyBack.labelKey}>
                  {translate("en", hierarchyBack.labelKey)}
                </span>
              </a>
            </nav>
          )
        }
        <slot />
      </main>
      <Footer />
    </div>
    <script>
      import { initializeDecorativeGlyphs } from "../scripts/decorativeGlyphs";

      initializeDecorativeGlyphs();
    </script>
    <script>
      import { initializeFootnoteSidenotes } from "../scripts/footnoteSidenotes";

      initializeFootnoteSidenotes();
    </script>
    <script>
      import { initializeEditionVariants } from "../scripts/editionVariants";

      initializeEditionVariants();
    </script>
    <script>
      import { initializeCjkTypography } from "../scripts/cjkTypography";

      initializeCjkTypography();
    </script>
  </body>
</html>
