---
// 中文：本地 Website Studio 的界面结构；功能逻辑在 scripts/admin.ts。
// English: Markup for the local Website Studio; behavior lives in scripts/admin.ts.
// Caveat / 注意：这是本地工具，不是部署后的线上 CMS。
// Caveat: This is a local tool, not a deployed online CMS.
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Website Studio | Yixin Cui">
  <!--
    本地管理入口：通过后只在当前浏览器标签页内记住口令。
    Local admin gate: the passcode is remembered only for this browser tab.
  -->
  <section class="admin-gate" data-admin-gate>
    <form class="gate-card" data-passcode-form>
      <p class="gate-kicker">Yixin Cui</p>
      <h1>Website Studio</h1>
      <label>
        Passcode
        <input
          type="password"
          inputmode="numeric"
          autocomplete="current-password"
          data-passcode-input
          autofocus
        />
      </label>
      <button type="submit">Enter</button>
      <p class="gate-message" data-passcode-message aria-live="polite"></p>
    </form>
  </section>

  <main class="studio" data-admin-studio hidden>
    <header class="studio-toolbar">
      <div class="studio-identity">
        <h1>Website Studio</h1>
        <p>Local editing workspace for content, code, design, and images.</p>
      </div>

      <div class="toolbar-actions">
        <button type="button" data-open-folder>Connect project</button>
        <button type="button" data-save-file disabled>Save</button>
        <label>
          <input type="checkbox" data-auto-save />
          Auto-save and compile
        </label>
        <label>
          <input type="checkbox" data-auto-refresh checked />
          Refresh preview after save
        </label>
        <button type="button" data-lock-studio>Lock</button>
      </div>

      <div class="studio-links">
        <a href="/admin/guide/" target="studio-preview">
          Admin guide / 管理指南
        </a>
      </div>

      <p class="studio-status" data-status>
        Connecting to the local project…
      </p>
    </header>

    <section class="studio-workspace" aria-label="Website editing workspace">
      <aside class="studio-sidebar">
        <div class="sidebar-tabs" role="tablist" aria-label="Project browser">
          <button
            type="button"
            role="tab"
            aria-selected="true"
            data-sidebar-tab="files"
          >
            Files
          </button>
          <button
            type="button"
            role="tab"
            aria-selected="false"
            data-sidebar-tab="images"
          >
            Images
          </button>
          <button
            type="button"
            role="tab"
            aria-selected="false"
            data-sidebar-tab="find"
          >
            Find
          </button>
          <button
            type="button"
            role="tab"
            aria-selected="false"
            data-sidebar-tab="design"
          >
            Design
          </button>
        </div>

        <!--
          文件树按目录分组；输入框只筛选文件名和路径。
          The directory tree groups files by folder; this filter searches paths and names.
        -->
        <section class="sidebar-panel" data-sidebar-panel="files">
          <label class="filter-field">
            Filter files
            <input type="search" data-file-filter placeholder="works, CSS, Astro…" />
          </label>
          <nav aria-label="Project files">
            <ul class="file-list file-tree" data-file-list></ul>
          </nav>
        </section>

        <section
          class="sidebar-panel"
          data-sidebar-panel="images"
          hidden
        >
          <p>Select an image to copy its public URL or insert Markdown.</p>
          <div class="image-library" data-image-library></div>
        </section>

        <!--
          Find 会在整个项目的可编辑文本文件中查找内容。
          Find searches the contents of every editable text file in the project.
        -->
        <section class="sidebar-panel" data-sidebar-panel="find" hidden>
          <form class="global-search" data-search-form>
            <label class="filter-field">
              Find throughout project
              <input
                type="search"
                data-global-search
                placeholder="Text, title, CSS variable…"
              />
            </label>
            <button type="submit">Find</button>
          </form>
          <p class="search-summary" data-search-summary>
            Search file contents across the project.
          </p>
          <ol class="search-results" data-search-results></ol>
        </section>

        <!--
          设计面板只编辑 global.css 顶部已记录的变量。
          The Design dashboard edits only the documented variables near the top of global.css.
        -->
        <section class="sidebar-panel design-panel" data-sidebar-panel="design" hidden>
          <header class="panel-introduction">
            <h2>Design / 设计</h2>
            <p>Changes save immediately to the public site.</p>
            <div class="design-mode" aria-label="Design editing mode">
              <button type="button" aria-pressed="true">
                Dashboard / 面板
              </button>
              <button type="button" data-open-theme-css disabled>
                Manual CSS / 手动 CSS
              </button>
            </div>
          </header>

          <form class="design-dashboard" data-design-dashboard>
            <label>
              Theme color / 主题色
              <span class="color-control">
                <input type="color" value="#c81e1e" data-theme-color />
                <output data-theme-color-output>#c81e1e</output>
              </span>
            </label>

            <label>
              Font / 字体
              <select data-design-font>
                <option value="system-sans">System Sans / 系统无衬线</option>
                <option value="humanist-sans">Source Sans 3</option>
                <option value="system-serif">Times / 系统衬线</option>
                <option value="garamond">EB Garamond</option>
                <option value="typewriter">Classic Typewriter / 经典打字机</option>
                <option value="modern-mono">IBM Plex Mono</option>
              </select>
            </label>

            <label>
              Base text size / 基础字号
              <span class="range-control">
                <input
                  type="range"
                  min="14"
                  max="22"
                  step="1"
                  value="17"
                  data-design-font-size
                />
                <output data-design-font-size-output>17px</output>
              </span>
            </label>

            <label>
              Global spacing / 全局间距
              <select data-design-spacing>
                <option value="compact">Compact / 紧凑</option>
                <option value="standard" selected>Standard / 标准</option>
                <option value="open">Open / 舒展</option>
                <option value="generous">Generous / 宽松</option>
              </select>
            </label>

            <label>
              Line height / 行距
              <span class="range-control">
                <input
                  type="range"
                  min="1.3"
                  max="1.9"
                  step="0.05"
                  value="1.55"
                  data-design-line-height
                />
                <output data-design-line-height-output>1.55</output>
              </span>
            </label>

            <label>
              Paragraph spacing / 段落间距
              <span class="range-control">
                <input
                  type="range"
                  min="0"
                  max="2"
                  step="0.1"
                  value="0"
                  data-design-paragraph-spacing
                />
                <output data-design-paragraph-spacing-output>0rem</output>
              </span>
            </label>

            <label>
              Reading width / 阅读宽度
              <select data-design-width>
                <option value="narrow">Narrow / 窄</option>
                <option value="standard" selected>Standard / 标准</option>
                <option value="wide">Wide / 宽</option>
              </select>
            </label>

            <label class="design-check">
              <input type="checkbox" data-design-indent checked />
              Paragraph indentation / 段落首行缩进
            </label>

            <fieldset class="design-presets">
              <legend>Presets / 预设</legend>
              <label>
                Slot / 槽位
                <select data-design-preset-slot>
                  <option value="1">Preset 1 / 预设 1</option>
                  <option value="2">Preset 2 / 预设 2</option>
                  <option value="3">Preset 3 / 预设 3</option>
                </select>
              </label>
              <p data-design-preset-status>Preset 1 is empty. / 预设 1 为空。</p>
              <div>
                <button type="button" data-design-preset-save>Save / 保存</button>
                <button type="button" data-design-preset-apply>Apply / 应用</button>
                <button type="button" data-design-preset-clear>Clear / 清除</button>
              </div>
            </fieldset>

            <div class="design-actions">
              <button type="button" data-design-reset>
                Reset dashboard defaults / 恢复面板默认值
              </button>
            </div>
          </form>
        </section>
      </aside>

      <!--
        CodeMirror 自己滚动；页面不会随着长文件继续向下增长。
        CodeMirror owns the scrolling, so long files do not extend the whole page.
      -->
      <section class="studio-editor-pane" aria-label="Code editor">
        <header class="pane-heading editor-heading">
          <div class="editor-file-state">
            <strong data-current-file>No file selected</strong>
            <span data-dirty-state></span>
          </div>
          <label class="editor-option">
            <input type="checkbox" data-line-wrap />
            Wrap lines
          </label>
        </header>
        <div class="code-editor" data-code-editor></div>
      </section>

      <!--
        预览可切换为完整宽度或常见手机视口。
        The preview switches between the full pane and a common phone viewport.
      -->
      <section class="studio-preview-pane" aria-label="Website preview">
        <header class="pane-heading preview-controls">
          <label>
            Preview path
            <input type="text" value="/" data-preview-path />
          </label>
          <button type="button" data-load-preview>Load</button>
          <button type="button" data-refresh-preview>Refresh</button>
          <label class="inspect-control">
            <input type="checkbox" data-preview-inspector />
            Inspect
          </label>
          <div class="preview-size" aria-label="Preview size">
            <button
              type="button"
              aria-pressed="true"
              data-preview-size="desktop"
            >
              Desktop
            </button>
            <button
              type="button"
              aria-pressed="false"
              data-preview-size="phone"
            >
              Phone
            </button>
          </div>
          <a href="/" target="_blank" data-open-preview>Open tab</a>
        </header>
        <div class="preview-stage" data-preview-stage="desktop">
          <iframe
            src="/"
            name="studio-preview"
            title="Live website preview"
            data-preview-frame
          ></iframe>
        </div>
      </section>
    </section>

    <div class="local-only-message" data-local-only hidden>
      <h1>Website Studio is local only</h1>
      <p>
        Run <code>npm run dev</code> and open <code>/admin/</code> on
        <code>localhost</code> or <code>127.0.0.1</code>.
      </p>
    </div>
  </main>

  <script>
    import { initializeAdminStudio } from "../../scripts/admin";

    initializeAdminStudio();
  </script>
</AdminLayout>
