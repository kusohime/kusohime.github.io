---
// 中文：本地 Website Studio 的介面結構；功能邏輯在 scripts/admin.ts。
// English: Markup for the local Website Studio; behavior lives in scripts/admin.ts.
// Caveat / 注意：這是本地工具，不是部署後的線上 CMS。
// Caveat: This is a local tool, not a deployed online CMS.
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Website Studio | Yixin Cui">
  <main class="studio" data-admin-studio hidden>
    <header class="studio-toolbar">
      <div class="toolbar-actions">
        <button type="button" data-open-folder>Connect project</button>
        <button type="button" data-save-file disabled>Save</button>
        <label>
          <input type="checkbox" data-auto-save />
          Auto-save and compile
        </label>
        <label>
          <input type="checkbox" data-auto-refresh checked />
          Refresh preview after save
        </label>
      </div>

      <p class="studio-status" data-status>
        Connecting to the local project…
      </p>

      <div class="studio-links">
        <a href="/admin/guide/" target="studio-preview">
          Admin guide / 管理指南
        </a>
      </div>
    </header>

    <section
      class="studio-workspace"
      aria-label="Website editing workspace"
      data-studio-workspace
    >
      <aside class="studio-sidebar" data-studio-pane="sidebar">
        <header class="pane-heading pane-title">
          <strong>Project</strong>
          <button
            type="button"
            class="pane-toggle"
            data-pane-toggle="sidebar"
            aria-label="Collapse project pane"
            title="Collapse project pane"
          >-</button>
        </header>
        <div class="sidebar-tabs" role="tablist" aria-label="Project browser">
          <button
            type="button"
            role="tab"
            aria-selected="true"
            data-sidebar-tab="files"
          >
            Files
          </button>
          <button
            type="button"
            role="tab"
            aria-selected="false"
            data-sidebar-tab="images"
          >
            Images
          </button>
          <button
            type="button"
            role="tab"
            aria-selected="false"
            data-sidebar-tab="design"
          >
            Design
          </button>
          <button
            type="button"
            role="tab"
            aria-selected="false"
            data-sidebar-tab="library"
          >
            Library
          </button>
          <button
            type="button"
            role="tab"
            aria-selected="false"
            data-sidebar-tab="new"
          >
            New
          </button>
          <button
            type="button"
            role="tab"
            aria-selected="false"
            data-sidebar-tab="publish"
          >
            Publish
          </button>
        </div>

        <!--
          檔案頁籤同時提供檔名篩選與全文搜尋（原 Find 頁籤已併入此處）。
          The Files tab offers both name filtering and full-text search
          (the former Find tab now lives here).
        -->
        <section class="sidebar-panel" data-sidebar-panel="files">
          <label class="filter-field">
            Filter files
            <input type="search" data-file-filter placeholder="works, CSS, Astro…" />
          </label>
          <form class="global-search" data-search-form>
            <label class="filter-field">
              Find in files
              <input
                type="search"
                data-global-search
                placeholder="Text, title, CSS variable…"
              />
            </label>
            <button type="submit">Find</button>
          </form>
          <div class="search-block" data-search-block hidden>
            <p class="search-summary" data-search-summary></p>
            <ol class="search-results" data-search-results></ol>
            <button type="button" class="search-clear" data-search-clear>
              Clear results
            </button>
          </div>
          <nav aria-label="Project files">
            <ul class="file-list file-tree" data-file-list></ul>
          </nav>
        </section>

        <!--
          圖片按資料夾分為相簿；打開相簿時才載入縮圖。
          Images group into folder albums; thumbnails load when an album opens.
        -->
        <section
          class="sidebar-panel"
          data-sidebar-panel="images"
          hidden
        >
          <p class="panel-hint">
            Albums follow the project folders. Open one to load thumbnails,
            then copy the URL, insert Markdown, or delete. Add new images into a
            folder under <code>public/images</code>. Needs the local dev server.
          </p>
          <div class="image-uploader" data-image-uploader>
            <label class="image-upload-folder">
              <span>Folder</span>
              <input
                type="text"
                data-image-upload-folder
                value="public/images"
                spellcheck="false"
                autocomplete="off"
              />
            </label>
            <button type="button" data-image-add>Add images…</button>
            <input
              type="file"
              accept="image/*"
              multiple
              hidden
              data-image-input
            />
            <p class="image-upload-message" data-image-message aria-live="polite"></p>
          </div>
          <div class="image-library" data-image-library></div>
        </section>

        <!--
          Design 直接改寫 global.css 的 :root 變數與 config JSON，並即時預覽。
          Design rewrites global.css :root variables and config JSON, with
          live preview before the file save round-trips.
        -->
        <section class="sidebar-panel design-panel" data-sidebar-panel="design" hidden>
          <button type="button" class="css-file-button" data-open-theme-css disabled>
            Open global.css
          </button>

          <fieldset class="design-group" data-site-defaults disabled>
            <legend>Site defaults</legend>
            <label>
              Default language for new visitors
              <select data-default-language>
                <option value="en">English</option>
                <option value="zh">中文</option>
              </select>
            </label>
          </fieldset>

          <fieldset class="design-group" data-design-settings disabled>
            <legend>Typography</legend>
            <label>
              Body font
              <select data-design-var="--font-body" data-design-kind="raw">
                <option value="var(--font-typewriter)">Classic typewriter</option>
                <option value="var(--font-modern-mono)">Modern mono</option>
                <option value="var(--font-system-sans)">System sans</option>
                <option value="var(--font-humanist-sans)">Humanist sans</option>
                <option value="var(--font-system-serif)">Traditional serif</option>
                <option value="var(--font-garamond)">Garamond</option>
                <option value="var(--font-stix-serif)">STIX Two + 思源宋体</option>
              </select>
            </label>
            <label>
              Heading font
              <select data-design-var="--font-heading" data-design-kind="raw">
                <option value="var(--font-body)">Same as body</option>
                <option value="var(--font-typewriter)">Classic typewriter</option>
                <option value="var(--font-modern-mono)">Modern mono</option>
                <option value="var(--font-system-sans)">System sans</option>
                <option value="var(--font-humanist-sans)">Humanist sans</option>
                <option value="var(--font-system-serif)">Traditional serif</option>
                <option value="var(--font-garamond)">Garamond</option>
                <option value="var(--font-stix-serif)">STIX Two + 思源宋体</option>
              </select>
            </label>
            <label>
              Base font size
              <span class="range-control">
                <input type="range" min="14" max="22" step="0.5"
                  data-design-var="--base-font-size" data-design-unit="px" />
                <output data-design-output="--base-font-size"></output>
              </span>
            </label>
            <label>
              Line height
              <span class="range-control">
                <input type="range" min="1.15" max="1.9" step="0.05"
                  data-design-var="--line-height" data-design-unit="" />
                <output data-design-output="--line-height"></output>
              </span>
            </label>
            <label>
              Heading size
              <span class="range-control">
                <input type="range" min="0.9" max="1.8" step="0.05"
                  data-design-var="--heading-size" data-design-unit="rem" />
                <output data-design-output="--heading-size"></output>
              </span>
            </label>
            <label>
              Heading line height
              <span class="range-control">
                <input type="range" min="0.9" max="1.7" step="0.05"
                  data-design-var="--heading-line-height" data-design-unit="" />
                <output data-design-output="--heading-line-height"></output>
              </span>
            </label>
          </fieldset>

          <fieldset class="design-group" data-design-settings-2 disabled>
            <legend>Spacing &amp; paragraphs</legend>
            <label>
              <input type="checkbox" data-indent-toggle />
              Paragraph first-line indent
            </label>
            <label>
              Indent width
              <span class="range-control">
                <input type="range" min="0.5" max="3" step="0.25"
                  data-design-var="--paragraph-indent" data-design-unit="em"
                  data-indent-width />
                <output data-design-output="--paragraph-indent"></output>
              </span>
            </label>
            <label>
              Paragraph spacing
              <span class="range-control">
                <input type="range" min="0" max="2.5" step="0.1"
                  data-design-var="--paragraph-spacing" data-design-unit="rem" />
                <output data-design-output="--paragraph-spacing"></output>
              </span>
            </label>
          </fieldset>

          <fieldset class="design-group" data-design-settings-3 disabled>
            <legend>Page layout</legend>
            <label>
              Overall page width
              <span class="range-control">
                <input type="range" min="42" max="76" step="1"
                  data-design-var="--page-width" data-design-unit="rem" />
                <output data-design-output="--page-width"></output>
              </span>
            </label>
            <label>
              Content column width
              <span class="range-control">
                <input type="range" min="30" max="46" step="1"
                  data-design-var="--content-width" data-design-unit="rem" />
                <output data-design-output="--content-width"></output>
              </span>
            </label>
            <label>
              Reading column width
              <span class="range-control">
                <input type="range" min="24" max="40" step="1"
                  data-design-var="--reading-width" data-design-unit="rem" />
                <output data-design-output="--reading-width"></output>
              </span>
            </label>
            <label>
              Page gutter
              <span class="range-control">
                <input type="range" min="0.5" max="3" step="0.25"
                  data-design-var="--page-gutter" data-design-unit="rem" />
                <output data-design-output="--page-gutter"></output>
              </span>
            </label>
            <label>
              Home image edge fade
              <span class="range-control">
                <input type="range" min="0" max="30" step="1"
                  data-design-var="--home-image-fade-width" data-design-unit="%" />
                <output data-design-output="--home-image-fade-width"></output>
              </span>
            </label>
          </fieldset>

          <fieldset class="design-group" data-design-settings-4 disabled>
            <legend>Advanced spacing</legend>
            <label>
              Compact gap
              <span class="range-control">
                <input type="range" min="0.15" max="0.8" step="0.05"
                  data-design-var="--space-xs" data-design-unit="rem" />
                <output data-design-output="--space-xs"></output>
              </span>
            </label>
            <label>
              Standard gap
              <span class="range-control">
                <input type="range" min="0.35" max="1.5" step="0.05"
                  data-design-var="--space-sm" data-design-unit="rem" />
                <output data-design-output="--space-sm"></output>
              </span>
            </label>
            <label>
              Section gap
              <span class="range-control">
                <input type="range" min="0.8" max="3" step="0.1"
                  data-design-var="--space-md" data-design-unit="rem" />
                <output data-design-output="--space-md"></output>
              </span>
            </label>
            <label>
              Major section gap
              <span class="range-control">
                <input type="range" min="1.5" max="6" step="0.25"
                  data-design-var="--space-lg" data-design-unit="rem" />
                <output data-design-output="--space-lg"></output>
              </span>
            </label>
            <label>
              Header padding
              <span class="range-control">
                <input type="range" min="0.25" max="2" step="0.05"
                  data-design-var="--header-padding" data-design-unit="rem" />
                <output data-design-output="--header-padding"></output>
              </span>
            </label>
          </fieldset>

          <fieldset class="design-group typography-settings" data-typography-settings disabled>
            <legend>Advanced typography</legend>
            <label for="cjk-letter-spacing">
              East Asian character spacing
              <span class="range-control">
                <input
                  id="cjk-letter-spacing"
                  type="range"
                  min="-0.08"
                  max="0.08"
                  step="0.005"
                  value="0"
                  data-cjk-letter-spacing
                />
                <output for="cjk-letter-spacing" data-cjk-letter-spacing-output>
                  0.000em
                </output>
              </span>
            </label>
            <p>Applies when the site is shown in Traditional Chinese or Japanese.</p>
          </fieldset>

          <fieldset class="design-group motion-settings" data-motion-settings disabled>
            <legend>Animations</legend>
            <label>
              <input type="checkbox" data-motion-setting="languageFlap" />
              Language glyph flaps
            </label>
            <label>
              <input type="checkbox" data-motion-setting="themeFade" />
              Theme dim/fade
            </label>
            <label>
              <input type="checkbox" data-motion-setting="fontSizeScale" />
              Font-size swell/shrink
            </label>
            <label>
              <input type="checkbox" data-motion-setting="glyphRotation" />
              Arrow and sun/moon rotation
            </label>
            <label>
              <input type="checkbox" data-motion-setting="interfaceMotion" />
              Tooltip and smooth-scroll motion
            </label>
            <p data-motion-settings-status>All animations are off.</p>
          </fieldset>
        </section>

        <!--
          Library 頁籤：整理作品、文章與活動的 metadata，並可安全移入 trash。
          The Library tab edits works/writings/events metadata and safely moves pages to trash.
        -->
        <section class="sidebar-panel library-panel" data-sidebar-panel="library" hidden>
          <div class="library-controls">
            <label>
              Collection
              <select data-library-kind>
                <option value="works">Works</option>
                <option value="events">Events</option>
                <option value="writings">Writings</option>
              </select>
            </label>
            <label>
              Filter
              <input type="search" data-library-filter placeholder="title, slug, draft…" />
            </label>
            <div class="library-create-actions">
              <button type="button" data-library-create="work">New work</button>
              <button type="button" data-library-create="event">New event</button>
              <button type="button" data-library-create="writing">New writing</button>
            </div>
          </div>

          <details class="taxonomy-manager">
            <summary>Manage categories</summary>
            <label>
              Set
              <select data-taxonomy-kind>
                <option value="workCategories">Work categories</option>
                <option value="writingTypes">Writing tags</option>
              </select>
            </label>
            <label>
              Existing values
              <select size="6" data-taxonomy-list></select>
            </label>
            <label>
              Value
              <input type="text" data-taxonomy-value placeholder="Category name" />
            </label>
            <div class="library-actions">
              <button type="button" data-taxonomy-add>Add</button>
              <button type="button" data-taxonomy-rename>Rename</button>
              <button type="button" data-taxonomy-delete data-danger>Delete</button>
            </div>
            <p class="panel-hint" data-taxonomy-message aria-live="polite"></p>
          </details>

          <ol class="library-list" data-library-list></ol>

          <form class="library-editor" data-library-form hidden>
            <fieldset class="design-group">
              <legend>Catalog fields</legend>
              <p class="library-path" data-library-path></p>
              <label>
                Title
                <input type="text" data-library-field="title" />
              </label>
              <label>
                Slug
                <input type="text" data-library-field="slug" />
              </label>
              <label data-library-non-event>
                Subtitle
                <input type="text" data-library-field="subtitle" />
              </label>
              <label data-library-work-only>
                Year
                <input type="number" min="1900" max="2100" data-library-field="year" />
              </label>
              <label data-library-work-only>
                Category
                <select data-library-field="category" data-library-category></select>
              </label>
              <label data-library-work-only>
                Instrumentation
                <input type="text" data-library-field="instrumentation" />
              </label>
              <label data-library-work-only>
                Duration, minutes
                <input type="number" min="0" step="0.5" data-library-field="duration" />
              </label>
              <details class="video-fields" data-library-work-only>
                <summary>PeerTube video</summary>
                <label>
                  Embed URL
                  <input
                    type="text"
                    inputmode="url"
                    data-library-field="videoEmbedUrl"
                    placeholder="https://example.org/videos/embed/..."
                  />
                </label>
                <label>
                  PeerTube page URL
                  <input
                    type="text"
                    inputmode="url"
                    data-library-field="videoWatchUrl"
                    placeholder="https://example.org/w/..."
                  />
                </label>
                <label>
                  Poster image
                  <input
                    type="text"
                    inputmode="url"
                    data-library-field="videoPoster"
                    placeholder="/images/video-poster.webp"
                  />
                </label>
                <label>
                  Poster alt text
                  <input type="text" data-library-field="videoPosterAlt" />
                </label>
                <label>
                  Caption, English
                  <textarea rows="2" data-library-field="videoCaption"></textarea>
                </label>
                <label>
                  Caption, Chinese
                  <textarea rows="2" data-library-field="videoCaptionZh"></textarea>
                </label>
                <label>
                  Video title, English
                  <input type="text" data-library-field="videoTitle" />
                </label>
                <label>
                  Video title, Chinese
                  <input type="text" data-library-field="videoTitleZh" />
                </label>
                <label>
                  Aspect ratio
                  <input
                    type="text"
                    data-library-field="videoAspectRatio"
                    placeholder="16 / 9"
                  />
                </label>
              </details>
              <label data-library-writing-or-event hidden>
                Date
                <input type="text" data-library-field="date" />
              </label>
              <div class="tag-picker" data-library-writing-only hidden>
                <span class="tag-picker-label">Tags (choose any)</span>
                <div class="tag-options" data-library-tags></div>
              </div>
              <label data-library-event-only hidden>
                Time
                <input type="text" data-library-field="time" placeholder="7:30 PM" />
              </label>
              <label data-library-event-only hidden>
                Venue
                <input type="text" data-library-field="venue" />
              </label>
              <label data-library-event-only hidden>
                Location
                <input type="text" data-library-field="location" />
              </label>
              <label data-library-event-only hidden>
                Role
                <input type="text" data-library-field="role" placeholder="composer, pianist..." />
              </label>
              <label>
                Summary
                <textarea rows="3" data-library-field="summary"></textarea>
              </label>
              <label data-library-event-only hidden>
                Links
                <textarea
                  rows="3"
                  data-library-field="links"
                  placeholder="Program | https://example.com"
                ></textarea>
              </label>
              <label>
                Order
                <input type="number" data-library-field="order" />
              </label>
              <label>
                <input type="checkbox" data-library-field="draft" />
                Draft
              </label>
              <label data-library-comments-control>
                <input type="checkbox" data-library-field="comments" />
                Comments open
              </label>
              <div class="library-actions">
                <button type="submit" data-library-save>Save catalog</button>
                <button type="button" data-library-open>Open content</button>
                <button type="button" data-library-preview>Preview</button>
                <button type="button" data-library-trash data-danger>Move to trash</button>
              </div>
              <p class="panel-hint" data-library-message aria-live="polite"></p>
            </fieldset>
          </form>
        </section>

        <!--
          New 頁籤：以表單建立新的作品、文章或活動草稿，存於 content/ 之下。
          The New tab creates a fresh work, writing, or event draft under content/.
        -->
        <section class="sidebar-panel new-page-panel" data-sidebar-panel="new" hidden>
          <form data-new-page-form>
            <fieldset class="design-group">
              <legend>Add a page</legend>
              <label>
                Kind
                <select data-new-kind>
                  <option value="work">Work (composition)</option>
                  <option value="event">Event</option>
                  <option value="writing">Writing (text)</option>
                </select>
              </label>
              <label>
                Title
                <input type="text" data-new-title placeholder="Still Water, Turning" required />
              </label>
              <label>
                Slug (folder and URL name)
                <input type="text" data-new-slug placeholder="still-water-turning" required />
              </label>

              <div data-new-work-fields>
                <label>
                  Year
                  <input type="number" data-new-year min="1900" max="2100" />
                </label>
                <label>
                  Category
                  <select data-new-category></select>
                </label>
                <label>
                  Instrumentation
                  <input type="text" data-new-instrumentation placeholder="Solo piano" />
                </label>
                <label>
                  Duration (minutes)
                  <input type="number" data-new-duration min="0" step="0.5" />
                </label>
                <details class="video-fields">
                  <summary>PeerTube video</summary>
                  <label>
                    Embed URL
                    <input
                      type="text"
                      inputmode="url"
                      data-new-video-embed-url
                      placeholder="https://example.org/videos/embed/..."
                    />
                  </label>
                  <label>
                    PeerTube page URL
                    <input
                      type="text"
                      inputmode="url"
                      data-new-video-watch-url
                      placeholder="https://example.org/w/..."
                    />
                  </label>
                  <label>
                    Poster image
                    <input
                      type="text"
                      inputmode="url"
                      data-new-video-poster
                      placeholder="/images/video-poster.webp"
                    />
                  </label>
                  <label>
                    Poster alt text
                    <input type="text" data-new-video-poster-alt />
                  </label>
                  <label>
                    Caption, English
                    <textarea rows="2" data-new-video-caption></textarea>
                  </label>
                  <label>
                    Caption, Chinese
                    <textarea rows="2" data-new-video-caption-zh></textarea>
                  </label>
                  <label>
                    Video title, English
                    <input type="text" data-new-video-title />
                  </label>
                  <label>
                    Video title, Chinese
                    <input type="text" data-new-video-title-zh />
                  </label>
                  <label>
                    Aspect ratio
                    <input type="text" data-new-video-aspect-ratio placeholder="16 / 9" />
                  </label>
                </details>
              </div>

              <div data-new-writing-fields hidden>
                <label>
                  Date (YYYY or YYYY-MM-DD)
                  <input type="text" data-new-date placeholder="2026-06" />
                </label>
                <div class="tag-picker">
                  <span class="tag-picker-label">Tags (choose any)</span>
                  <div class="tag-options" data-new-tags></div>
                </div>
              </div>

              <div data-new-event-fields hidden>
                <label>
                  Date (YYYY-MM-DD)
                  <input type="text" data-new-event-date placeholder="2026-09-20" />
                </label>
                <label>
                  Time
                  <input type="text" data-new-event-time placeholder="7:30 PM" />
                </label>
                <label>
                  Venue
                  <input type="text" data-new-event-venue placeholder="Eastman School of Music" />
                </label>
                <label>
                  Location
                  <input type="text" data-new-event-location placeholder="Rochester, NY" />
                </label>
                <label>
                  Role
                  <input type="text" data-new-event-role placeholder="composer" />
                </label>
              </div>

              <label>
                One-line summary
                <input type="text" data-new-summary placeholder="Shown in lists and search results" />
              </label>
              <label>
                <input type="checkbox" data-new-draft checked />
                Start as draft (unlisted; preview at /drafts/)
              </label>
              <button type="submit" class="new-page-submit" data-new-submit disabled>
                Create page
              </button>
              <button type="button" class="draft-shelf-button" data-draft-shelf>
                Preview draft shelf
              </button>
              <p class="panel-hint" data-new-message aria-live="polite"></p>
            </fieldset>
          </form>
        </section>

        <!--
          Publish 頁籤：只提交被勾選的檔案，避免把無關修改一起推送。
          The Publish tab commits only checked files, keeping unrelated local
          edits out of a push.
        -->
        <section class="sidebar-panel publish-panel" data-sidebar-panel="publish" hidden>
          <form data-publish-form>
            <fieldset class="design-group">
              <legend>Publish to GitHub</legend>
              <div class="publish-actions">
                <button type="button" data-publish-refresh>
                  Refresh
                </button>
                <button type="button" data-publish-select-all>
                  Select all
                </button>
              </div>
              <p class="panel-hint" data-publish-summary aria-live="polite">
                Refresh to inspect local changes.
              </p>
              <ol class="publish-file-list" data-publish-file-list></ol>
              <label>
                Commit message
                <input
                  type="text"
                  data-publish-commit-message
                  placeholder="Update website"
                  autocomplete="off"
                />
              </label>
              <button type="submit" class="publish-submit" data-publish-submit disabled>
                Commit and push selected
              </button>
              <p class="panel-hint" data-publish-message aria-live="polite"></p>
            </fieldset>
          </form>
        </section>
      </aside>

      <div
        class="pane-resizer"
        role="separator"
        aria-label="Resize project and code panes"
        aria-orientation="vertical"
        tabindex="0"
        data-pane-resizer="sidebar"
      ></div>

      <!--
        CodeMirror 自己滾動；頁面不會隨著長檔案繼續向下增長。
        CodeMirror owns the scrolling, so long files do not extend the whole page.
      -->
      <section
        class="studio-editor-pane"
        aria-label="Code editor"
        data-studio-pane="editor"
      >
        <header class="pane-heading editor-heading">
          <div class="editor-file-state">
            <strong data-current-file>No file selected</strong>
            <span data-dirty-state></span>
          </div>
          <div class="pane-actions">
            <label class="editor-option">
              <input type="checkbox" data-line-wrap />
              Wrap lines
            </label>
            <button
              type="button"
              class="pane-toggle"
              data-pane-toggle="editor"
              aria-label="Collapse code pane"
              title="Collapse code pane"
            >-</button>
          </div>
        </header>
        <div class="markdown-toolbar" data-md-toolbar hidden>
          <button type="button" data-md-insert="h2">H2</button>
          <button type="button" data-md-insert="h3">H3</button>
          <button type="button" data-md-insert="bold">B</button>
          <button type="button" data-md-insert="italic">I</button>
          <button type="button" data-md-insert="link">Link</button>
          <button type="button" data-md-insert="quote">Quote</button>
          <button type="button" data-md-insert="list">List</button>
          <button type="button" data-md-insert="footnote">Footnote</button>
          <button type="button" data-md-insert="no-indent">No indent</button>
          <button type="button" data-md-insert="lang">Lang</button>
          <button
            type="button"
            data-md-insert="zh-em"
            title="Chinese emphasis dots (着重号)"
          >着重</button>
          <button type="button" data-md-insert="ruby">Ruby</button>
        </div>
        <div class="code-editor" data-code-editor></div>
      </section>

      <div
        class="pane-resizer"
        role="separator"
        aria-label="Resize code and preview panes"
        aria-orientation="vertical"
        tabindex="0"
        data-pane-resizer="editor"
      ></div>

      <!--
        預覽可切換為完整寬度或常見手機視口。
        The preview switches between the full pane and a common phone viewport.
      -->
      <section
        class="studio-preview-pane"
        aria-label="Website preview"
        data-studio-pane="preview"
      >
        <header class="pane-heading preview-controls">
          <label>
            Preview path
            <input type="text" value="/" data-preview-path />
          </label>
          <button type="button" data-load-preview>Load</button>
          <button type="button" data-refresh-preview>Refresh</button>
          <label class="inspect-control">
            <input type="checkbox" data-preview-inspector />
            Inspect
          </label>
          <label class="inspect-control">
            <input type="checkbox" data-preview-visual-editor />
            Edit text
          </label>
          <div class="preview-size" aria-label="Preview size">
            <button
              type="button"
              aria-pressed="true"
              data-preview-size="desktop"
            >
              Desktop
            </button>
            <button
              type="button"
              aria-pressed="false"
              data-preview-size="phone"
            >
              Phone
            </button>
          </div>
          <a href="/" target="_blank" data-open-preview>Open tab</a>
          <button
            type="button"
            class="pane-toggle"
            data-pane-toggle="preview"
            aria-label="Collapse preview pane"
            title="Collapse preview pane"
          >-</button>
        </header>
        <div class="preview-stage" data-preview-stage="desktop">
          <iframe
            src="/"
            name="studio-preview"
            title="Live website preview"
            data-preview-frame
          ></iframe>
        </div>
      </section>
    </section>

    <div class="local-only-message" data-local-only hidden>
      <h1>Website Studio is local only</h1>
      <p>
        Run <code>npm run dev</code> and open <code>/admin/</code> on
        <code>localhost</code> or <code>127.0.0.1</code>.
      </p>
    </div>
  </main>

  <script>
    const START_RETRY_KEY = "yixin-cui-studio-start-retried";

    const showStartupError = (error: unknown) => {
      const studio = document.querySelector("[data-admin-studio]");
      const status = document.querySelector("[data-status]");
      if (studio instanceof HTMLElement) studio.hidden = false;
      if (status instanceof HTMLElement) {
        const message =
          error instanceof Error ? error.message : "Studio could not start.";
        status.dataset.kind = "error";
        status.textContent = `Studio could not start: ${message}`;
      }
    };

    const startStudio = async () => {
      try {
        const { initializeAdminStudio } = await import("../../scripts/admin");
        await initializeAdminStudio();
        sessionStorage.removeItem(START_RETRY_KEY);
      } catch (error) {
        const message = error instanceof Error ? error.message : String(error);
        if (
          message.includes("Failed to fetch dynamically imported module") &&
          sessionStorage.getItem(START_RETRY_KEY) !== "true"
        ) {
          sessionStorage.setItem(START_RETRY_KEY, "true");
          location.reload();
          return;
        }
        showStartupError(error);
      }
    };

    startStudio();
  </script>
</AdminLayout>
