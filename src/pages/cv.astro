  roderickWilliams: "https://www.grovesartists.com/artist/roderick-williams/",
  jasperQuartet: "https://www.jasperquartet.com/",
  wildflowerLab: "https://wildflowercomposers.org/lab",
  relache: "https://www.relachemusic.org/about",
  tamaraLukasheva: "https://tamaralukasheva.de/about",
  hansLuedemann: "https://www.hansluedemann.de/english/",
  peggyDettwiler: "https://peggydettwiler.com/",
  antonArmstrong: "https://www.stolaf.edu/profile/armstron",
  passacaglia: "https://westsidemusicfoundation.org/passacaglia/",
};

const compositions = [
