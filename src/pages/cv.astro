          <li><a href={hrefs.markLoria}>Mark Loria</a>, <LocalizedText value={t("organ", "管風琴")} /> (2023)</li>
          <li>Violafest <LocalizedText value={t("with", "偕")} /> <a href={hrefs.hannahRoseNicholas}>Hannah Rose Nicholas</a>, <LocalizedText value={t("composition", "作曲")} /> (2023)</li>
          <li><a href={hrefs.roderickWilliams}>Roderick Williams OBE</a>, <LocalizedText value={t("composition", "作曲")} /> (2024)</li>
          <li><a href={hrefs.jasperQuartet}>Jasper String Quartet</a>, <LocalizedText value={t("conducting", "指揮")} /> (2024)</li>
          <li><a href={hrefs.wildflowerLab}>Wildflower Lab</a> <LocalizedText value={t("with", "偕")} /> <a href={hrefs.relache}>Relâche Ensemble</a>, <LocalizedText value={t("composition", "作曲")} /> (2025)</li>
          <li><a href={hrefs.roderickWilliams}>Roderick Williams OBE</a>, <LocalizedText value={t("voice", "聲樂")} /> (2025)</li>
          <li><a href={hrefs.tamaraLukasheva}>Tamara Lukasheva</a> <LocalizedText value={t("and", "與")} /> <a href={hrefs.hansLuedemann}>Hans Lüdemann</a>, <LocalizedText value={t("voice and composition", "聲樂與作曲")} /> (2025)</li>
          <li>American Choral Directors Association, Pennsylvania, <LocalizedText value={t("conducting", "指揮")} /> (2025)</li>
          <li><a href={hrefs.peggyDettwiler}>Peggy Dettwiler</a> <LocalizedText value={t("and", "與")} /> <a href={hrefs.antonArmstrong}>Anton Armstrong</a>, <LocalizedText value={t("conducting", "指揮")} /> (2025)</li>
        </ul>
      </section>

      <section class="cv-section" aria-labelledby="cv-experience">
        <h2 id="cv-experience"><LocalizedText value={L["cv-experience"]} /></h2>

        <div class="cv-entry">
          <div class="cv-entry-head">
            <h3>Eastman School of Music Instrument Office</h3>
            <p><LocalizedText value={t("Rochester, NY", "紐約州羅徹斯特")} /></p>
          </div>
          <div class="cv-entry-subhead">
            <p><em><LocalizedText value={t("Piano Technology Apprentice", "鋼琴技術學徒")} /></em></p>
            <p><LocalizedText value={t("2026-present", "2026 至今")} /></p>
          </div>
          <ul>
            <li><LocalizedText value={t("Apprenticeship in piano technology through Eastman's instrument office.", "透過 Eastman 樂器辦公室進行的鋼琴技術學徒訓練。")} /></li>
          </ul>
        </div>

        <div class="cv-entry">
          <div class="cv-entry-head">
            <h3>Pagoda Artworks, Inc., <a href={hrefs.westside}>Westside Music Conservatory</a></h3>
            <p><LocalizedText value={t("Los Angeles, CA", "加州洛杉磯")} /></p>
          </div>
          <div class="cv-entry-subhead">
            <p><em><LocalizedText value={t("Intern", "實習生")} /></em></p>
            <p>2025-2026</p>
          </div>
          <ul>
            <li><LocalizedText value={t("Illustrator and designer for a young children's piano pedagogy book republishing project.", "為一個幼兒鋼琴教學書再版計畫擔任插畫與設計。")} /></li>
            <li><LocalizedText value={t("Maintenance of professional composer's website.", "維護一位職業作曲家的網站。")} /></li>
          </ul>
        </div>

        <div class="cv-entry">
          <div class="cv-entry-head">
            <h3><a href={hrefs.cooper}>Cooper Series, Swarthmore College</a></h3>
            <p><LocalizedText value={t("Swarthmore, PA", "賓州斯沃斯莫爾")} /></p>
          </div>
          <div class="cv-entry-subhead">
            <p><em><LocalizedText value={t("Tenor", "男高音")} /></em></p>
            <p>2025-2026</p>
          </div>
          <ul>
            <li><LocalizedText value={t("Soloist for a newly commissioned cantata by ", "新受委約清唱劇的獨唱，作曲為 ")} /><a href={hrefs.raybon}>C. Leonard Raybon</a>.</li>
          </ul>
        </div>

        <div class="cv-entry">
          <div class="cv-entry-head">
            <h3><a href={hrefs.garnetSingers}>Swarthmore Garnet Singers</a></h3>
            <p><LocalizedText value={t("Swarthmore, PA", "賓州斯沃斯莫爾")} /></p>
          </div>
          <div class="cv-entry-subhead">
            <p><em><LocalizedText value={t("Conductor and Pianist", "指揮與鋼琴")} /></em></p>
            <p>2026</p>
          </div>
        </div>

        <div class="cv-entry">
          <div class="cv-entry-head">
            <h3><LocalizedText value={t("Concert Musician", "音樂會演奏者")} /></h3>
            <p><LocalizedText value={t("Swarthmore, PA", "賓州斯沃斯莫爾")} /></p>
          </div>
          <div class="cv-entry-subhead">
            <p><LocalizedText value={t("2025-present", "2025 至今")} /></p>
          </div>
          <ul>
            <li><LocalizedText value={t("Collaborative keyboard work for rehearsal, sight-reading, and concert performance for Choir, Orchestra, and other ensembles.", "為合唱團、管弦樂團及其他樂團擔任排練、視奏與音樂會演出的合作鍵盤。")} /></li>
          </ul>
        </div>

        <div class="cv-entry">
          <div class="cv-entry-head">
            <h3><a href={hrefs.swarthmore}>Swarthmore College</a></h3>
            <p><LocalizedText value={t("Swarthmore, PA", "賓州斯沃斯莫爾")} /></p>
          </div>
          <div class="cv-entry-subhead">
            <p><em><LocalizedText value={t("Tutor, Grader", "助教、評分員")} /></em></p>
            <p>2021-2024</p>
          </div>
          <ul>
            <li><LocalizedText value={t("Tutoring and grading for mathematics, modern languages, and music theory.", "為數學、現代語言與音樂理論提供輔導與評分。")} /></li>
          </ul>
        </div>
      </section>

      <section class="cv-section" aria-labelledby="cv-ensembles">
        <h2 id="cv-ensembles"><LocalizedText value={L["cv-ensembles"]} /></h2>
        <ul class="cv-dot-list">
          <li><a href={hrefs.garnetSingers}>Swarthmore Chorus</a>, <LocalizedText value={t("section leader, soloist, octet singer", "聲部長、獨唱、八重唱團員")} /></li>
          <li><a href={hrefs.garnetSingers}>Swarthmore Garnet Singers</a>, <LocalizedText value={t("senior student conductor, composer, pianist", "高年級學生指揮、作曲、鋼琴")} /></li>
          <li><a href={hrefs.orchestra}>Swarthmore Orchestra</a>, <LocalizedText value={t("celesta, piano, organ, percussion, composer", "鋼片琴、鋼琴、管風琴、打擊樂、作曲")} /></li>
          <li><a href={hrefs.labOrchestra}>Swarthmore Lab Orchestra</a>, <LocalizedText value={t("senior student conductor, percussion", "高年級學生指揮、打擊樂")} /></li>
          <li><a href={hrefs.theaterDepartment}>Swarthmore Theatre Department</a>, <LocalizedText value={t("student keyboardist", "學生鍵盤手")} /></li>
          <li><a href={hrefs.chineseMusicEnsemble}>Swarthmore Chinese Music Ensemble</a>, <LocalizedText value={t("erhu, zheng, voice, yangqin, conducting assistant", "二胡、箏、人聲、揚琴、指揮助理")} /></li>
        </ul>
      </section>

      <section class="cv-section" aria-labelledby="cv-compositions">
        <h2 id="cv-compositions"><LocalizedText value={L["cv-compositions"]} /></h2>
