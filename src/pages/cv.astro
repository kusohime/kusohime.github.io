        <p>
          <LocalizedText
            value={t(
              "Mandarin, English, Japanese, Classical Chinese, French, German, Chinese Sign Language (PRC standard), Classical Japanese, Tibetan.",
              "官話、英語、日語、古典漢語、法語、德語、中國手語（中國大陸標準）、古典日語、藏語。",
            )}
          />
        </p>
      </section>

      <section class="cv-section cv-fold-section" aria-labelledby="cv-repertoire">
        <details class="cv-fold">
          <summary id="cv-repertoire">
            <span><LocalizedText value={L["cv-repertoire"]} /></span>
          </summary>
          <div class="cv-repertoire-groups">
            {
              repertoire.map((group) => (
                <section class="cv-subsection" aria-label={group.heading.en}>
                  <h3><LocalizedText value={group.heading} /></h3>
                  <ul>
                    {group.items.map((item) => <li>{item}</li>)}
                  </ul>
                </section>
              ))
            }
          </div>
        </details>
      </section>
    </article>
  </div>
</BaseLayout>
