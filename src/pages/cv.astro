    heading: "Chamber and Instrumental",
    works: [
      ["Bayanbulak", "2023", "8'20, solo viola", "/works/bayanbulak/"],
      ["Urtonforschungen I", "2024", "5', piano and vibraphone", "/works/urtonforschungen-i/"],
      ["Urtonforschungen II", "2024", "4', chamber ensemble", "/works/urtonforschungen-ii/"],
      ["A Song in the Winter", "2025", "6', soprano and piano", "/works/a-song-in-the-winter/"],
      ["A Past Life", "2025", "5', solo sign-singer in CSL", "/works/a-past-life/"],
      ["Saijōtai Yamata[i]-K[h]itan No. 2", "2025", "9', percussion and voice", "/works/saijotai-yamatai-khitan-no-2/"],
      ["Phalanx Break", "2025", "6'30, piccolo and piano; commissioned by Passacaglia Chamber Music Collective", "/works/phalanx-break/"],
    ],
  },
  {
    heading: "Large Ensemble",
    works: [
      ["Twink Death", "2025", "circa 65', two actors, high voice, and large ensemble", "/works/twink-death/"],
