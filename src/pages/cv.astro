---

<BaseLayout
  title="C.V."
  description="Curriculum vitae for Yixin Cui, as of June 2026"
>
  <div class="index-page cv-index" data-source-file="src/pages/cv.astro">
    <nav class="catalog-rail cv-rail" aria-label="C.V. contents">
      <ul>
        {
          sections.map((section) => (
            <li>
              <a href={`#${section.id}`}>
                <LocalizedText value={section.label} />
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <article class="detail-page cv-page">
      <header class="detail-header cv-header">
        <p class="detail-kicker">
          <LocalizedText value={t("Curriculum vitae", "履歷")} />
        </p>
        <h1><NamePronunciation /></h1>
        <p>
          <LocalizedText
            value={t("tenor, composer, keyboardist, conductor", "男高音、作曲家、鍵盤演奏家、指揮")}
          />
        </p>
        <nav class="detail-actions" aria-label="CV downloads">
          <a href="/files/yixin-cui-cv.pdf" download data-i18n-key="resource.cvPdf">
            {translate("en", "resource.cvPdf")}
          </a>
        </nav>
      </header>

      <section class="cv-section" aria-labelledby="cv-education">
        <h2 id="cv-education"><LocalizedText value={L["cv-education"]} /></h2>

        <div class="cv-entry">
          <div class="cv-entry-head">
            <h3><a href={hrefs.eastman}>Eastman School of Music</a></h3>
            <p><LocalizedText value={t("Rochester, NY", "紐約州羅徹斯特")} /></p>
          </div>
          <div class="cv-entry-subhead">
            <p><em><LocalizedText value={t("Master of Arts, Composition", "文學碩士，作曲")} /></em></p>
            <p><LocalizedText value={t("2026-2028, anticipated", "2026–2028（預計）")} /></p>
          </div>
        </div>

        <div class="cv-entry">
          <div class="cv-entry-head">
            <h3><a href={hrefs.swarthmore}>Swarthmore College</a></h3>
            <p><LocalizedText value={t("Swarthmore, PA", "賓州斯沃斯莫爾")} /></p>
          </div>
          <div class="cv-entry-subhead">
            <p><em><LocalizedText value={t("Bachelor of Arts, Philosophy; minor in Music", "文學學士，哲學；輔修音樂")} /></em></p>
            <p>2021-2025</p>
          </div>
          <ul>
            <li><LocalizedText value={t("Cumulative GPA 3.97/4.00.", "累計 GPA 3.97／4.00。")} /></li>
            <li>
              <LocalizedText value={t("Senior theses: ", "畢業論文：")} />
              <em>Contingency, Difference, and Reproducibility in the Ontological Problems of Aleatoric Music</em>; <em>The Archaeology of Olympics: On Instrumentalized Bodies</em>.
            </li>
          </ul>
        </div>
      </section>

      <section class="cv-section" aria-labelledby="cv-teachers">
        <h2 id="cv-teachers"><LocalizedText value={L["cv-teachers"]} /></h2>
        <div class="cv-lines">
          <p><span><LocalizedText value={t("Voice", "聲樂")} /></span><span><a href={hrefs.laraNie}>Lara Nie</a></span></p>
          <p><span><LocalizedText value={t("Vocal Coach", "聲樂指導")} /></span><span><a href={hrefs.debraScurtoDavis}>Debra Scurto-Davis</a></span></p>
          <p><span><LocalizedText value={t("Piano", "鋼琴")} /></span><span><a href={hrefs.marcantonio}>Marcantonio Barone</a>; <a href={hrefs.keikoSato}>Keiko Sato</a></span></p>
          <p><span><LocalizedText value={t("Organ", "管風琴")} /></span><span><a href={hrefs.edwardSenn}>Edward Landin Senn</a></span></p>
          <p><span><LocalizedText value={t("Composition", "作曲")} /></span><span><a href={hrefs.geraldLevinson}>Gerald Levinson</a>; <a href={hrefs.tomWhitman}>Thomas Whitman</a>; <a href={hrefs.erinBusch}>Erin Busch</a></span></p>
          <p><span><LocalizedText value={t("Conducting", "指揮")} /></span><span><a href={hrefs.andrewHauze}>Andrew Hauze</a>; <a href={hrefs.nathanReiff}>Nathan Reiff</a></span></p>
        </div>
      </section>

      <section class="cv-section" aria-labelledby="cv-masterclasses">
        <h2 id="cv-masterclasses"><LocalizedText value={L["cv-masterclasses"]} /></h2>
