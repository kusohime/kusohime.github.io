          {
            compositions.map((group) => (
              <section class="cv-subsection" aria-label={group.heading.en}>
                <h3><LocalizedText value={group.heading} /></h3>
                <ul class="cv-dot-list">
                  {group.works.map(([title, year, detail, href]) => (
                    <li><a href={href}>{title}</a> ({year}), <LocalizedText value={detail} /></li>
                  ))}
