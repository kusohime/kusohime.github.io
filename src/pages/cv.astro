      <section class="cv-section" aria-labelledby="cv-languages">
        <h2 id="cv-languages"><LocalizedText value={L["cv-languages"]} /></h2>
        <p class="cv-note">
          <LocalizedText value={t("Listed from higher to lower proficiency.", "依熟練度由高至低排列。")} />
