---

<BaseLayout
  title="C.V."
  description="Curriculum vitae for Yixin Cui."
>
  <div class="index-page cv-index" data-source-file="src/pages/cv.astro">
    <nav class="catalog-rail cv-rail" aria-label="C.V. contents">
      <ul>
        {
          sections.map((section) => (
            <li>
              <a href={`#${section.id}`}>{section.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <article class="detail-page cv-page">
      <header class="detail-header cv-header">
        <p class="detail-kicker">Curriculum vitae</p>
        <h1><NamePronunciation /></h1>
        <p>tenor, composer, keyboardist, conductor</p>
        <nav class="detail-actions" aria-label="CV downloads">
          <a href="/files/yixin-cui-cv.pdf" download data-i18n-key="resource.cvPdf">
            {translate("en", "resource.cvPdf")}
          </a>
        </nav>
      </header>

      <section class="cv-section" aria-labelledby="cv-education">
        <h2 id="cv-education">Education</h2>

        <div class="cv-entry">
          <div class="cv-entry-head">
            <h3><a href={hrefs.eastman}>Eastman School of Music</a></h3>
            <p>Rochester, NY</p>
          </div>
          <div class="cv-entry-subhead">
            <p><em>Master of Arts, Composition</em></p>
            <p>2026-2028, anticipated</p>
          </div>
        </div>

        <div class="cv-entry">
          <div class="cv-entry-head">
            <h3><a href={hrefs.swarthmore}>Swarthmore College</a></h3>
            <p>Swarthmore, PA</p>
          </div>
          <div class="cv-entry-subhead">
            <p><em>Bachelor of Arts, Philosophy; minor in Music</em></p>
            <p>2021-2025</p>
          </div>
          <ul>
            <li>Cumulative GPA 3.97/4.00.</li>
            <li>Senior theses: <em>Contingency, Difference, and Reproducibility in the Ontological Problems of Aleatoric Music</em>; <em>The Archaeology of Olympics: On Instrumentalized Bodies</em>.</li>
          </ul>
        </div>
      </section>

      <section class="cv-section" aria-labelledby="cv-teachers">
        <h2 id="cv-teachers">Teachers</h2>
        <div class="cv-lines">
          <p><span>Voice</span><span><a href={hrefs.laraNie}>Lara Nie</a></span></p>
          <p><span>Vocal Coach</span><span><a href={hrefs.debraScurtoDavis}>Debra Scurto-Davis</a></span></p>
          <p><span>Piano</span><span><a href={hrefs.marcantonio}>Marcantonio Barone</a>; <a href={hrefs.keikoSato}>Keiko Sato</a></span></p>
          <p><span>Organ</span><span><a href={hrefs.edwardSenn}>Edward Landin Senn</a></span></p>
          <p><span>Composition</span><span><a href={hrefs.geraldLevinson}>Gerald Levinson</a>; <a href={hrefs.tomWhitman}>Thomas Whitman</a>; <a href={hrefs.erinBusch}>Erin Busch</a></span></p>
          <p><span>Conducting</span><span><a href={hrefs.andrewHauze}>Andrew Hauze</a>; <a href={hrefs.nathanReiff}>Nathan Reiff</a></span></p>
        </div>
      </section>

      <section class="cv-section" aria-labelledby="cv-masterclasses">
        <h2 id="cv-masterclasses">Masterclass and Workshop Appearances</h2>
        <ul class="cv-dot-list">
          <li>American Guild of Organists, Philadelphia Chapter, organ (2023)</li>
          <li><a href={hrefs.daminSpritzer}>Damin Spritzer</a>, organ (2023)</li>
          <li><a href={hrefs.markLoria}>Mark Loria</a>, organ (2023)</li>
          <li>Violafest with <a href={hrefs.hannahRoseNicholas}>Hannah Rose Nicholas</a>, composition (2023)</li>
          <li><a href={hrefs.roderickWilliams}>Roderick Williams OBE</a>, composition (2024)</li>
          <li><a href={hrefs.jasperQuartet}>Jasper String Quartet</a>, conducting (2024)</li>
          <li><a href={hrefs.wildflowerLab}>Wildflower Lab</a> with <a href={hrefs.relache}>Relâche Ensemble</a>, composition (2025)</li>
          <li><a href={hrefs.roderickWilliams}>Roderick Williams OBE</a>, voice (2025)</li>
          <li><a href={hrefs.tamaraLukasheva}>Tamara Lukasheva</a> and <a href={hrefs.hansLuedemann}>Hans Lüdemann</a>, voice and composition (2025)</li>
          <li>American Choral Directors Association, Pennsylvania, conducting (2025)</li>
          <li><a href={hrefs.peggyDettwiler}>Peggy Dettwiler</a> and <a href={hrefs.antonArmstrong}>Anton Armstrong</a>, conducting (2025)</li>
        </ul>
      </section>

      <section class="cv-section" aria-labelledby="cv-experience">
        <h2 id="cv-experience">Professional Experience</h2>

        <div class="cv-entry">
          <div class="cv-entry-head">
            <h3>Eastman School of Music Instrument Office</h3>
            <p>Rochester, NY</p>
          </div>
          <div class="cv-entry-subhead">
            <p><em>Piano Technology Apprentice</em></p>
            <p>2026-present</p>
          </div>
          <ul>
            <li>Apprenticeship in piano technology through Eastman's instrument office.</li>
          </ul>
        </div>

        <div class="cv-entry">
          <div class="cv-entry-head">
            <h3>Pagoda Artworks, Inc., <a href={hrefs.westside}>Westside Music Conservatory</a></h3>
            <p>Los Angeles, CA</p>
          </div>
          <div class="cv-entry-subhead">
            <p><em>Intern</em></p>
            <p>2025-2026</p>
          </div>
          <ul>
            <li>Illustrator and designer for a young children's piano pedagogy book republishing project.</li>
            <li>Maintenance of professional composer's website.</li>
          </ul>
        </div>

        <div class="cv-entry">
          <div class="cv-entry-head">
            <h3><a href={hrefs.cooper}>Cooper Series, Swarthmore College</a></h3>
            <p>Swarthmore, PA</p>
          </div>
          <div class="cv-entry-subhead">
            <p><em>Tenor</em></p>
            <p>2025-2026</p>
          <ul>
             <li>Soloist for a newly commissioned cantata by <a href={hrefs.raybon}>C. Leonard Raybon</a>.</li>
          </ul>
          </div>
        </div>

        <div class="cv-entry">
          <div class="cv-entry-head">
            <h3><a href={hrefs.garnetSingers}>Swarthmore Garnet Singers</a></h3>
            <p>Swarthmore, PA</p>
          </div>
          <div class="cv-entry-subhead">
            <p><em>Conductor and Pianist</em></p>
            <p>2026</p>
          </div>
        </div>

        <div class="cv-entry">
          <div class="cv-entry-head">
            <h3>Concert Musician</h3>
            <p>Swarthmore, PA</p>
          </div>
          <div class="cv-entry-subhead">
            <p>2025-present</p>
          </div>
          <ul>
            <li>Collaborative keyboard work for rehearsal, sight-reading, and concert performance for Choir, Orchestra, and other ensembles.</li>
          </ul>
        </div>

        <div class="cv-entry">
          <div class="cv-entry-head">
            <h3><a href={hrefs.swarthmore}>Swarthmore College</a></h3>
            <p>Swarthmore, PA</p>
          </div>
          <div class="cv-entry-subhead">
            <p><em>Tutor, Grader</em></p>
            <p>2021-2024</p>
          </div>
          <ul>
            <li>Tutoring and grading for mathematics, modern languages, and music theory.</li>
          </ul>
        </div>
      </section>

      <section class="cv-section" aria-labelledby="cv-ensembles">
        <h2 id="cv-ensembles">Music Ensemble Experience</h2>
        <ul class="cv-dot-list">
          <li><a href={hrefs.garnetSingers}>Swarthmore Chorus</a>, section leader, soloist, octet singer</li>
          <li><a href={hrefs.garnetSingers}>Swarthmore Garnet Singers</a>, senior student conductor, composer, pianist</li>
          <li><a href={hrefs.orchestra}>Swarthmore Orchestra</a>, celesta, piano, organ, percussion, composer</li>
          <li><a href={hrefs.labOrchestra}>Swarthmore Lab Orchestra</a>, senior student conductor, percussion</li>
          <li><a href={hrefs.theaterDepartment}>Swarthmore Theatre Department</a>, student keyboardist</li>
          <li><a href={hrefs.chineseMusicEnsemble}>Swarthmore Chinese Music Ensemble</a>, erhu, zheng, voice, yangqin, conducting assistant</li>
        </ul>
      </section>

      <section class="cv-section" aria-labelledby="cv-compositions">
        <h2 id="cv-compositions">Selected Compositions</h2>
        <div class="cv-composition-groups">
          {
            compositions.map((group) => (
              <section class="cv-subsection" aria-label={group.heading}>
                <h3>{group.heading}</h3>
                <ul class="cv-dot-list">
                  {group.works.map(([title, year, detail, href]) => (
                    <li><a href={href}>{title}</a> ({year}), {detail}</li>
                  ))}
                </ul>
              </section>
            ))
          }
        </div>
      </section>

      <section class="cv-section" aria-labelledby="cv-scholarships">
        <h2 id="cv-scholarships">Scholarships and Fellowships</h2>

        <div class="cv-lines">
          <p>
            <span>Hannah A. Leedom Fellowship, Swarthmore College</span>
            <span>2026-2027</span>
          </p>
          <p>
            <span>Merit Scholarships, University of Rochester</span>
            <span>2026-present</span>
          </p>
          <p>
            <span>Freeman Scholars, Swarthmore College Music Department</span>
            <span>2024-2025</span>
          </p>
        </div>
      </section>

      <section class="cv-section" aria-labelledby="cv-languages">
        <h2 id="cv-languages">Languages</h2>
        <p class="cv-note">Listed from higher to lower proficiency.</p>
        <p>Mandarin, English, Japanese, Classical Chinese, Classical Japanese, French, Chinese Sign Language (PRC standard), German, Tibetan.</p>
      </section>

      <section class="cv-section cv-fold-section" aria-labelledby="cv-repertoire">
        <details class="cv-fold">
          <summary id="cv-repertoire">
            <span>Selected Performance Repertoire</span>
          </summary>
          <div class="cv-repertoire-groups">
            {
              repertoire.map((group) => (
                <section class="cv-subsection" aria-label={group.heading}>
                  <h3>{group.heading}</h3>
                  <ul>
                    {group.items.map((item) => <li>{item}</li>)}
                  </ul>
                </section>
              ))
            }
          </div>
        </details>
      </section>
    </article>
  </div>
</BaseLayout>
