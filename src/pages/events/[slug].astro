---
// 中文：根据活动 Markdown 生成单个活动详情页。
// English: Generates an individual event detail page from its Markdown file.
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LocalizedText from "../../components/LocalizedText.astro";
import { formatDate, translate } from "../../config/locales";
import { dominantContentLang } from "../../utils/cjkLanguage";

export async function getStaticPaths() {
  const events = await getCollection(
    "events",
    ({ data }) => import.meta.env.DEV || !data.draft,
  );

  return events.map((event) => ({
    params: { slug: event.data.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
const { Content } = await render(event);
const eventsZh = await getCollection("eventsZh");
const zhEntry = eventsZh.find((entry) => entry.id === event.id);
const { Content: ContentZh } = zhEntry
  ? await render(zhEntry)
  : { Content: null as any };
// 中文：没有中文正文文件时按正文主导语言提示另一语言不可用（无正文则不提示）。
// English: Without a Chinese body, note the unavailable locale from the body's
// dominant language (undefined when there is no prose — no note).
const bodyLang = zhEntry ? undefined : dominantContentLang(event.body ?? "");
const unavailableLanguages: ("en" | "zh")[] = bodyLang
  ? bodyLang === "en"
    ? ["zh"]
    : bodyLang === "zh"
      ? ["en"]
      : ["en", "zh"]
  : [];
const {
  title,
  date,
  time,
  venue,
  venueZh,
  location,
  locationZh,
  role,
  roleZh,
  brief,
  briefZh,
  links,
} = event.data;
const facts = [
  { en: time, zh: time },
  { en: venue, zh: venueZh },
  { en: location, zh: locationZh },
  { en: role, zh: roleZh },
].filter((fact) => fact.en);
---

<BaseLayout
  title={title}
  description={brief}
  noindex={event.data.draft}
  unavailableLanguages={unavailableLanguages}
>
  <article
    class="detail-page event-detail"
    data-source-file={`content/events/${event.id}/index.md`}
  >
    <header class="detail-header event-detail-header">
      {event.data.draft && <p class="draft-flag">Draft - not listed publicly</p>}
      <p class="detail-kicker" data-i18n-key="nav.events">
        {translate("en", "nav.events")}
      </p>
      <div class="event-title-line">
        <h1>{title}</h1>
        <p>
          <time datetime={date} data-i18n-date={date}>
            {formatDate(date, "en")}
          </time>
        </p>
      </div>
      <p><LocalizedText value={{ en: brief, zh: briefZh }} /></p>
      <p class="event-facts">
        {facts.map((fact) => (
          <span><LocalizedText value={{ en: fact.en as string, zh: fact.zh }} /></span>
        ))}
      </p>

      {
        links.length > 0 && (
          <nav class="resource-links" aria-label="Event links">
            <ul>
              {links.map((link) => (
                <li>
                  <a href={link.url}>{link.label}</a>
                </li>
              ))}
            </ul>
          </nav>
        )
      }
    </header>

    <div class="prose event-notes">
      {ContentZh ? (
        <>
          <div class="lang-block" data-lang="en">
            <Content />
          </div>
          <div class="lang-block" data-lang="zh">
            <ContentZh />
          </div>
        </>
      ) : (
        <Content />
      )}
    </div>

    <nav class="back-link" aria-label="Footer navigation">
      <a href="/events/">
        <span
          class="glyph-arrow glyph-arrow--back"
          data-arrow-glyph
          aria-hidden="true"
        ></span>
        <span data-i18n-key="common.backEvents">
          {translate("en", "common.backEvents")}
        </span>
      </a>
    </nav>
  </article>
</BaseLayout>
