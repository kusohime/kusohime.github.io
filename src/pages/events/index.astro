---
// 中文：按年份与月份列出活动，默认显示近期活动，并在同页侧栏切换历史月份。
// English: Lists events by year and month, defaulting to upcoming events with same-page archive navigation.
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LocalizedText from "../../components/LocalizedText.astro";
import { formatDate, translate } from "../../config/locales";

type EventEntry = CollectionEntry<"events">;

const eventDate = (event: EventEntry) => {
  const [year, month = "1", day = "1"] = event.data.date.split("-");
  return new Date(Date.UTC(Number(year), Number(month) - 1, Number(day)));
};

const today = new Date();
const todayUtc = new Date(
  Date.UTC(today.getFullYear(), today.getMonth(), today.getDate()),
);

const monthFormatter = new Intl.DateTimeFormat("en-US", {
  month: "long",
  timeZone: "UTC",
});

const yearAnchor = (period: "future" | "past", year: string) =>
  `events-${period}-${year}`;

const monthAnchor = (period: "future" | "past", year: string, month: string) =>
  `events-${period}-${year}-${month}`;

const sortEventsAscending = (a: EventEntry, b: EventEntry) =>
  eventDate(a).getTime() - eventDate(b).getTime() ||
  a.data.order - b.data.order ||
  a.data.title.localeCompare(b.data.title);

const sortEventsDescending = (a: EventEntry, b: EventEntry) =>
  eventDate(b).getTime() - eventDate(a).getTime() ||
  a.data.order - b.data.order ||
  a.data.title.localeCompare(b.data.title);

const groupEvents = (eventsToGroup: EventEntry[]) => {
  const groupedEvents = eventsToGroup.reduce((years, event) => {
    const date = eventDate(event);
    const year = String(date.getUTCFullYear());
    const month = String(date.getUTCMonth() + 1).padStart(2, "0");
    const yearGroup = years.get(year) ?? new Map<string, EventEntry[]>();
    const monthGroup = yearGroup.get(month) ?? [];

    monthGroup.push(event);
    yearGroup.set(month, monthGroup);
    years.set(year, yearGroup);
    return years;
  }, new Map<string, Map<string, EventEntry[]>>());

  return Array.from(groupedEvents.entries()).map(([year, months]) => ({
    year,
    count: Array.from(months.values()).reduce((total, group) => total + group.length, 0),
    months: Array.from(months.entries()).map(([month, monthEvents]) => ({
      month,
      label: monthFormatter.format(new Date(Date.UTC(Number(year), Number(month) - 1, 1))),
      events: monthEvents,
    })),
  }));
};

const events = await getCollection("events", ({ data }) => import.meta.env.DEV || !data.draft);

const upcomingEvents = events
  .filter((event) => eventDate(event) >= todayUtc)
  .sort(sortEventsAscending);

const pastEvents = events
  .filter((event) => eventDate(event) < todayUtc)
  .sort(sortEventsDescending);

const upcomingYearGroups = groupEvents(upcomingEvents);
const pastYearGroups = groupEvents(pastEvents);
const hasUpcomingEvents = upcomingYearGroups.length > 0;
const hasEvents = hasUpcomingEvents || pastYearGroups.length > 0;
---

<BaseLayout
  title="Events"
  description="Upcoming performances and events by Yixin Cui."
>
  <div
    class={`index-page events-index${hasEvents ? "" : " events-index--empty"}`}
    data-source-file="src/pages/events/index.astro"
  >
    <h1 class="visually-hidden" data-i18n-key="nav.events">
      {translate("en", "nav.events")}
    </h1>

    {
      hasEvents && (
        <nav class="catalog-rail event-rail" aria-label="Browse events by date">
          <div class="event-rail-section">
            <a
              class="event-rail-home"
              href="#events-upcoming"
              data-event-nav
              aria-current="page"
            >
              Upcoming
            </a>
            {upcomingYearGroups.length > 0 && (
              <ul class="event-archive event-archive-upcoming">
                {upcomingYearGroups.map(({ year, months }) => (
                  <li>
                    <details class="rail-disclosure" data-unfold open>
                      <summary>
                        <span
                          class="glyph-arrow glyph-arrow--disclosure"
                          data-arrow-glyph
                          aria-hidden="true"
                        ></span>
                        <span>{year}</span>
                      </summary>
                      <div class="rail-unfold">
                        <ul>
                          {months.map(({ month, label, events: monthEvents }) => (
                            <li>
                              <a
                                href={`#${monthAnchor("future", year, month)}`}
                                data-event-nav
                              >
                                {label} ({monthEvents.length})
                              </a>
                            </li>
                          ))}
                        </ul>
                      </div>
                    </details>
                  </li>
                ))}
              </ul>
            )}
          </div>

          {pastYearGroups.length > 0 && (
            <div class="event-rail-section event-rail-section--archive">
              <p class="event-rail-label">Archive</p>
              <ul class="event-archive event-archive-past">
                {pastYearGroups.map(({ year, months }) => (
                  <li>
                    <details class="rail-disclosure" data-unfold>
                      <summary>
                        <span
                          class="glyph-arrow glyph-arrow--disclosure"
                          data-arrow-glyph
                          aria-hidden="true"
                        ></span>
                        <span>{year}</span>
                      </summary>
                      <div class="rail-unfold">
                        <ul>
                          {months.map(({ month, label, events: monthEvents }) => (
                            <li>
                              <a
                                href={`#${monthAnchor("past", year, month)}`}
                                data-event-nav
                              >
                                {label} ({monthEvents.length})
                              </a>
                            </li>
                          ))}
                        </ul>
                      </div>
                    </details>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </nav>
      )
    }

    <div class="catalog-groups event-groups">
      <section
        class="event-panel event-panel--upcoming"
        id="events-upcoming"
        data-event-panel
        tabindex="-1"
        aria-labelledby="events-upcoming-heading"
      >
        <h2 id="events-upcoming-heading">Upcoming</h2>
        {
          hasUpcomingEvents ? (
            <>
              {upcomingYearGroups.map(({ year, months }) => (
                <section
                  class="event-year-group"
                  id={yearAnchor("future", year)}
                  aria-labelledby={`${yearAnchor("future", year)}-heading`}
                >
                  <h3 id={`${yearAnchor("future", year)}-heading`}>{year}</h3>
                  {months.map(({ month, label, events: monthEvents }) => (
                    <section
                      class="event-month-group"
                      id={monthAnchor("future", year, month)}
                      aria-labelledby={`${monthAnchor("future", year, month)}-heading`}
                    >
                      <h4 id={`${monthAnchor("future", year, month)}-heading`}>{label}</h4>
                      <ol class="catalog-list event-list">
                        {monthEvents.map((event) => (
                          <li data-source-file={`content/events/${event.id}/index.md`}>
                            <time
                              datetime={event.data.date}
                              data-i18n-date={event.data.date}
                            >
                              {formatDate(event.data.date, "en")}
                            </time>
                            <article class="entry-summary event-summary">
                              <h5>
                                <a href={`/events/${event.data.slug}/`}>
                                  {event.data.title}
                                </a>
                              </h5>
                              <p class="event-brief"><LocalizedText value={{ en: event.data.brief, zh: event.data.briefZh }} /></p>
                              <p class="event-meta">
                                {[event.data.time, event.data.venue, event.data.location]
                                  .filter(Boolean)
                                  .join(" / ")}
                              </p>
                            </article>
                          </li>
                        ))}
                      </ol>
                    </section>
                  ))}
                </section>
              ))}
            </>
          ) : (
            <p class="events-empty" data-i18n-key="events.noUpcoming">
              {translate("en", "events.noUpcoming")}
            </p>
          )
        }
      </section>

      {
        pastYearGroups.flatMap(({ year, months }) =>
          months.map(({ month, label, events: monthEvents }) => (
            <section
              class="event-panel event-panel--archive"
              id={monthAnchor("past", year, month)}
              data-event-panel
              hidden
              tabindex="-1"
              aria-labelledby={`${monthAnchor("past", year, month)}-heading`}
            >
              <p class="event-panel-kicker">{year}</p>
              <h2 id={`${monthAnchor("past", year, month)}-heading`}>
                {label}
              </h2>
              <ol class="catalog-list event-list">
                {monthEvents.map((event) => (
                  <li
                    class="event-list-item--past"
                    data-source-file={`content/events/${event.id}/index.md`}
                  >
                    <time
                      datetime={event.data.date}
                      data-i18n-date={event.data.date}
                    >
                      {formatDate(event.data.date, "en")}
                    </time>
                    <article class="entry-summary event-summary">
                      <h3>
                        <a href={`/events/${event.data.slug}/`}>
                          {event.data.title}
                        </a>
                      </h3>
                      <p class="event-brief"><LocalizedText value={{ en: event.data.brief, zh: event.data.briefZh }} /></p>
                      <p class="event-meta">
                        {[event.data.time, event.data.venue, event.data.location]
                          .filter(Boolean)
                          .join(" / ")}
                      </p>
                    </article>
                  </li>
                ))}
              </ol>
            </section>
          )),
        )
      }
    </div>
  </div>

  <script>
    const defaultPanelId = "events-upcoming";
    const panels = Array.from(
      document.querySelectorAll<HTMLElement>("[data-event-panel]"),
    );
    const panelIds = new Set(panels.map((panel) => panel.id));
    const navLinks = Array.from(
      document.querySelectorAll<HTMLAnchorElement>("[data-event-nav]"),
    );

    const hashId = () => decodeURIComponent(window.location.hash.slice(1));

    const resolvePanelId = () => {
      const requestedId = hashId();
      if (panelIds.has(requestedId)) return requestedId;
      if (requestedId.startsWith("events-future-")) return defaultPanelId;
      return defaultPanelId;
    };

    const syncEventPanel = (scroll = false) => {
      const requestedId = hashId();
      const panelId = resolvePanelId();
      const activeNavId =
        requestedId && (panelIds.has(requestedId) || requestedId.startsWith("events-future-"))
          ? requestedId
          : panelId;

      panels.forEach((panel) => {
        panel.hidden = panel.id !== panelId;
      });

      navLinks.forEach((link) => {
        const linkId = decodeURIComponent(link.hash.slice(1));
        const isCurrent = linkId === activeNavId;

        if (isCurrent) {
          link.setAttribute("aria-current", "page");
          link.closest("details")?.setAttribute("open", "");
        } else {
          link.removeAttribute("aria-current");
        }
      });

      if (!scroll) return;

      window.requestAnimationFrame(() => {
        const target =
          document.getElementById(requestedId) ?? document.getElementById(panelId);
        target?.scrollIntoView({ block: "start" });
        document.getElementById(panelId)?.focus({ preventScroll: true });
      });
    };

    navLinks.forEach((link) => {
      link.addEventListener("click", (event) => {
        const requestedId = decodeURIComponent(link.hash.slice(1));
        const canHandle =
          panelIds.has(requestedId) ||
          requestedId === defaultPanelId ||
          requestedId.startsWith("events-future-");

        if (!canHandle) return;

        event.preventDefault();
        if (window.location.hash !== link.hash) {
          history.pushState(null, "", link.hash);
        }
        syncEventPanel(true);
      });
    });

    syncEventPanel(Boolean(window.location.hash));
    window.addEventListener("popstate", () => syncEventPanel(true));
    window.addEventListener("hashchange", () => syncEventPanel(true));
  </script>
</BaseLayout>
