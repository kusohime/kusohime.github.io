---
// 中文：单个工具页。语言学工具仍是独立页面；作曲工具已并入主题合并页，
// 这里只生成一个跳转到 /tools/composition/<topic>/#tool-<slug> 的重定向，保留旧链接。
// English: One tool page. Linguistics tools keep their own page; Composition tools
// have moved into topic group pages, so this route redirects old per-tool URLs to
// /tools/composition/<topic>/#tool-<slug>.
// Caveat / 注意：分组映射在 src/config/toolTopics.ts；语言学工具不在其中，照常整页渲染。
// Caveat: The slug→topic map is src/config/toolTopics.ts; Linguistics slugs are not
// in it and render in full as before.
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { toolGroupLabel, translate } from "../../config/locales";
import { topicForSlug } from "../../config/toolTopics";
import "../../styles/tools.css";

import InterlinearGlosser from "../../components/tools/InterlinearGlosser.astro";
import KinshipCalculator from "../../components/tools/KinshipCalculator.astro";

const registry: Record<string, { component: any; file: string }> = {
  "interlinear-glosser": { component: InterlinearGlosser, file: "InterlinearGlosser.astro" },
  "kinship-calculator": { component: KinshipCalculator, file: "KinshipCalculator.astro" },
};

export async function getStaticPaths() {
  const tools = await getCollection("tools");
  return tools.map((tool) => {
    const topic = topicForSlug[tool.data.slug];
    const redirectTo = topic
      ? `/tools/composition/${topic}/#tool-${tool.data.slug}`
      : null;
    return { params: { slug: tool.data.slug }, props: { tool, redirectTo } };
  });
}

interface Props {
  tool: CollectionEntry<"tools">;
  redirectTo: string | null;
}

const { tool, redirectTo } = Astro.props;
const { Content } = redirectTo ? { Content: null as any } : await render(tool);
const entry = registry[tool.data.slug];
const Instrument = entry?.component;
const instrumentFile = entry ? `src/components/tools/${entry.file}` : null;
const statusKey =
  tool.data.status === "beta" ? "tools.statusBeta" : "tools.statusDataPending";

const refHtml = (text: string) =>
  text
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/\*([^*]+)\*/g, "<em>$1</em>");
---

{
  redirectTo ? (
    <BaseLayout title={tool.data.title} noindex>
      <p style="padding: var(--space-lg) 0;">
        This tool now lives in a workspace.{" "}
        <a href={redirectTo}>Continue →</a>
      </p>
      <script is:inline set:html={`location.replace(${JSON.stringify(redirectTo)});`} />
    </BaseLayout>
  ) : (
    <BaseLayout title={tool.data.title} description={tool.data.summary}>
      <article
        class="detail-page tool-page"
        data-source-file={`content/tools/${tool.id}/index.md`}
      >
        <header class="tool-header">
          <p class="tool-number">
            <span data-i18n-tool-group={tool.data.group}>
              {toolGroupLabel(tool.data.group, "en")}
            </span>
          </p>
          <h1>{tool.data.title}</h1>
          {tool.data.subtitle && <p class="tool-subtitle">{tool.data.subtitle}</p>}
          {tool.data.status !== "stable" && (
            <p class="tool-status" data-i18n-key={statusKey}>
              {translate("en", statusKey)}
            </p>
          )}
        </header>

        {Instrument && (
          <div
            data-source-file={instrumentFile}
            data-style-source="src/styles/tools.css"
          >
            <Instrument />
          </div>
        )}

        <details class="group-tool-notes tool-docs">
          <summary>
            <span data-i18n-key="tools.notes">{translate("en", "tools.notes")}</span>
          </summary>
          <div class="prose">
            <Content />
            {tool.data.references.length > 0 && (
              <>
                <h3 data-i18n-key="tools.references">
                  {translate("en", "tools.references")}
                </h3>
                <ul>
                  {tool.data.references.map((reference) => (
                    <li set:html={refHtml(reference)} />
                  ))}
                </ul>
              </>
            )}
          </div>
        </details>

        <p class="back-link">
          <a href="/tools/">
            <span
              class="glyph-arrow glyph-arrow--back"
              data-arrow-glyph
              aria-hidden="true"
            ></span>
            <span data-i18n-key="common.backTools">
              {translate("en", "common.backTools")}
            </span>
          </a>
        </p>
      </article>
    </BaseLayout>
  )
}
