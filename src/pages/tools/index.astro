---
// 中文：工具總覽頁。作曲工具按主題合併，連到各自的合併頁；語言學工具仍各自獨立。
// English: Tools index. Composition tools are grouped by topic and link to their
// grouped pages; Linguistics tools keep their own pages.
// Caveat / 注意：主題分組定義在 src/config/toolTopics.ts；此頁只是目錄。
// Caveat: Topic grouping lives in src/config/toolTopics.ts; this page is a catalogue.
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { toAnchor, toolGroups } from "../../config/contentTaxonomy";
import { toolGroupLabel, translate } from "../../config/locales";
import { topicsForGroup, toolTopicLabel } from "../../config/toolTopics";
import "../../styles/tools.css";

const tools = await getCollection("tools", ({ data }) => !data.hidden);
const bySlug = Object.fromEntries(tools.map((t) => [t.data.slug, t]));

const compositionTopics = topicsForGroup("Composition").map((topic) => ({
  topic,
  tools: topic.tools.map((slug) => bySlug[slug]).filter(Boolean),
}));

const linguisticsTools = tools
  .filter((tool) => tool.data.group === "Linguistics")
  .sort((a, b) => a.data.number - b.data.number);

const statusKey = (status: string) =>
  status === "beta" ? "tools.statusBeta" : "tools.statusDataPending";

const railGroups = [
  { group: "Composition" as const, count: compositionTopics.length, suffix: " topics" },
  { group: "Linguistics" as const, count: linguisticsTools.length, suffix: "" },
].filter((g) => g.count > 0);
---

<BaseLayout
  title="Tools"
  description="Calculators and reference tools for composition: rhythm, tuning, set theory, spectra, and performance resources."
>
  <div
    class="index-page tools-index"
    data-source-file="src/pages/tools/index.astro"
  >
    <h1 class="visually-hidden" data-i18n-key="nav.tools">
      {translate("en", "nav.tools")}
    </h1>

    <nav class="catalog-rail" aria-label="Browse tools by group">
      <ul>
        {
          railGroups.map(({ group, count }) => (
            <li>
              <a href={`#${toAnchor(group)}`}>
                <span data-i18n-tool-group={group}>
                  {toolGroupLabel(group, "en")}
                </span>{" "}
                ({count})
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="catalog-groups">
      <section
        class="category-group"
        id={toAnchor("Composition")}
        aria-labelledby="composition-heading"
      >
        <h2
          id="composition-heading"
          class="tool-group-heading"
          data-i18n-tool-group="Composition"
        >
          {toolGroupLabel("Composition", "en")}
        </h2>

        <div class="topic-list">
          {
            compositionTopics.map(({ topic, tools: topicTools }) => (
              <article class="topic-entry">
                <h3>
                  <a
                    href={`/tools/composition/${topic.id}/`}
                    data-i18n-tool-topic={topic.id}
                  >
                    {toolTopicLabel(topic.id, "en")}
                  </a>
                </h3>
                <p class="topic-blurb" data-i18n-tool-topic-blurb={topic.id}>
                  {topic.blurb.en}
                </p>
                <ul class="topic-members">
                  {topicTools.map((tool) => (
                    <li>
                      <a
                        href={`/tools/composition/${topic.id}/#tool-${tool.data.slug}`}
                      >
                        {tool.data.title}
                      </a>
                      {tool.data.status !== "stable" && (
                        <span
                          class="tool-status tool-status--inline"
                          data-i18n-key={statusKey(tool.data.status)}
                        >
                          {translate("en", statusKey(tool.data.status) as any)}
                        </span>
                      )}
                    </li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </section>

      {
        linguisticsTools.length > 0 && (
          <section
            class="category-group"
            id={toAnchor("Linguistics")}
            aria-labelledby="linguistics-heading"
          >
            <h2
              id="linguistics-heading"
              class="tool-group-heading"
              data-i18n-tool-group="Linguistics"
            >
              {toolGroupLabel("Linguistics", "en")}
            </h2>
            <ol class="tools-list">
              {linguisticsTools.map((tool) => (
                <li>
                  <article
                    class="tool-entry"
                    data-source-file={`content/tools/${tool.id}/index.md`}
                  >
                    <h3>
                      <a href={`/tools/${tool.data.slug}/`}>{tool.data.title}</a>
                    </h3>
                    <p>{tool.data.summary}</p>
                    {tool.data.status !== "stable" && (
                      <p
                        class="tool-status"
                        data-i18n-key={statusKey(tool.data.status)}
                      >
                        {translate("en", statusKey(tool.data.status) as any)}
                      </p>
                    )}
                  </article>
                </li>
              ))}
            </ol>
          </section>
        )
      }
    </div>
  </div>
</BaseLayout>
