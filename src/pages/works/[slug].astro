---
// 中文：根据作品 Markdown 生成单个作品详情页。
// English: Generates an individual work detail page from its Markdown file.
// Caveat / 注意：公开网址使用 frontmatter 中的 slug，而不是文件夹名称。
// Caveat: The public URL uses the frontmatter slug, not the folder name.
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LocalizedText from "../../components/LocalizedText.astro";
import Comments from "../../components/Comments.astro";
import PeerTubeEmbed from "../../components/PeerTubeEmbed.astro";
import {
  formatCommission,
  formatDate,
  formatDedication,
  formatDuration,
  formatPremiere,
  translate,
} from "../../config/locales";
import "../../styles/kanbun.css";

export async function getStaticPaths() {
  const works = await getCollection(
    "works",
    ({ data }) => import.meta.env.DEV || !data.draft,
  );

  return works.map((work) => ({
    params: { slug: work.data.slug },
    props: { work },
  }));
}

interface Props {
  work: CollectionEntry<"works">;
}

const { work } = Astro.props;
const { Content } = await render(work);
const {
  title,
  subtitle,
  subtitleZh,
  year,
  instrumentation,
  duration,
  dedication,
  commission,
  credits,
  premiere,
  recordingUrl,
  scoreUrl,
  video,
  image,
  imageAlt,
  description,
} = work.data;
---

<BaseLayout title={title} description={description} noindex={work.data.draft}>
  <article
    class="detail-page work-detail"
    data-source-file={`content/works/${work.id}/index.md`}
  >
    <header class="detail-header work-detail-header">
      {work.data.draft && <p class="draft-flag">Draft — not listed publicly</p>}
      <div class="work-title-line">
        <h1>{title}</h1>
        <p class="work-year">
          <time datetime={String(year)} data-i18n-date={String(year)}>
            {formatDate(year, "en")}
          </time>
        </p>
      </div>
      {subtitle && (
        <p><LocalizedText value={{ en: subtitle, zh: subtitleZh }} /></p>
      )}
      <p class="work-facts">
        <span><LocalizedText value={instrumentation} /></span>
        <span
          data-i18n-duration
          data-duration-minutes={duration.minutes}
          data-duration-continuous={String(duration.continuous)}
          data-duration-approximate={String(duration.approximate)}
        >
          {formatDuration(duration, "en")}
        </span>
      </p>

      {commission && (
        <p class="work-commission">
          <em
            data-i18n-commission
            data-commission-en={commission.en}
            data-commission-zh={commission.zh}
          >
            {formatCommission(commission, "en")}
          </em>
        </p>
      )}

      {
        (recordingUrl || scoreUrl) && (
          <nav class="resource-links" aria-label="Work resources">
            <ul>
              {recordingUrl && (
                <li>
                  <a href={recordingUrl} data-i18n-key="resource.recording">
                    {translate("en", "resource.recording")}
                  </a>
                </li>
              )}
              {scoreUrl && (
                <li>
                  <a href={scoreUrl} data-i18n-key="resource.score">
                    {translate("en", "resource.score")}
                  </a>
                </li>
              )}
            </ul>
          </nav>
        )
      }
    </header>

    {video && <PeerTubeEmbed video={video} fallbackTitle={title} />}

    {
      image && (
        <figure class="media-placeholder">
          <img src={image} alt={imageAlt ?? ""} width="1200" height="800" />
        </figure>
      )
    }

    <div class="prose work-notes">
      <Content />
    </div>

    {
      (dedication || credits || premiere) && (
        <footer class="work-credits">
          {dedication && (
            <p>
              <em
                data-i18n-dedication
                data-dedication-en={dedication.en}
                data-dedication-zh={dedication.zh}
              >
                {formatDedication(dedication, "en")}
              </em>
            </p>
          )}
          {credits?.map((credit) => (
            <p>
              <em>
                <span data-i18n-key="metadata.credits">
                  {translate("en", "metadata.credits")}
                </span>
                <span data-i18n-key="metadata.labelSeparator">
                  {translate("en", "metadata.labelSeparator")}
                </span>
                <LocalizedText value={credit} />
              </em>
            </p>
          ))}
          {premiere && (
            <p>
              <em
                data-i18n-premiere
                data-premiere-by-en={premiere.by.en}
                data-premiere-by-zh={premiere.by.zh}
                data-premiere-venue-en={premiere.venue?.en}
                data-premiere-venue-zh={premiere.venue?.zh}
                data-premiere-date={
                  premiere.date !== undefined ? String(premiere.date) : undefined
                }
              >
                {formatPremiere(premiere, "en")}
              </em>
            </p>
          )}
        </footer>
      )
    }

    {work.data.comments && <Comments collection="works" slug={work.data.slug} />}

    <p class="back-link">
      <a href="/works/">
        <span
          class="glyph-arrow glyph-arrow--back"
          data-arrow-glyph
          aria-hidden="true"
        ></span>
        <span data-i18n-key="common.backWorks">
          {translate("en", "common.backWorks")}
        </span>
      </a>
    </p>
  </article>
</BaseLayout>

<script>
  // Progressive enhancement for an embedded kanbun figure (only the saijōtai
  // work has one). Wires up the 疏/密 layout toggle, highlights 「…」 quotes in
  // the accent colour, and makes loanword readings flip to their source word.
  const embed = document.querySelector<HTMLElement>("[data-kanbun-embed]");
  const kanbun = embed?.querySelector<HTMLElement>(".kanbun");
  if (embed && kanbun) {
    // 疏排 (akigumi) ⇄ 密排 (betagumi)
    const toggles = embed.querySelectorAll<HTMLButtonElement>("[data-kb-layout]");
    toggles.forEach((btn) => {
      btn.addEventListener("click", () => {
        kanbun.classList.toggle("betagumi", btn.dataset.kbLayout === "dense");
        toggles.forEach((b) =>
          b.setAttribute("aria-pressed", String(b === btn)),
        );
      });
    });

    // Colour everything between 「 and 」 (a quote can span column breaks, so walk
    // the whole figure in source order rather than per column).
    const walker = document.createTreeWalker(kanbun, NodeFilter.SHOW_TEXT);
    let inQuote = false;
    let node: Node | null;
    while ((node = walker.nextNode())) {
      const text = node.textContent ?? "";
      if (text.includes("「")) inQuote = true;
      if (inQuote) node.parentElement?.classList.add("kb-quote");
      if (text.includes("」")) inQuote = false;
    }

    // Click a loanword reading to flip between its kana and its source word.
    const flips: Record<string, string> = {
      あすとら: "astra",
      へりおとろぷ: "heliotropism",
      りびど: "libido",
      じゅいさんす: "jouissance",
      だいなみっく: "dynamics",
    };
    kanbun.querySelectorAll<HTMLElement>("rt.furigana").forEach((rt) => {
      const orig = rt.textContent ?? "";
      const alt = flips[orig];
      if (!alt) return;
      rt.classList.add("kb-flip");
      rt.setAttribute("role", "button");
      rt.setAttribute("tabindex", "0");
      rt.setAttribute("aria-label", `${orig} — tap to read ${alt}`);
      rt.title = `${alt} ⇄ ${orig}`;
      const flip = () => {
        const showAlt = rt.textContent === orig;
        rt.textContent = showAlt ? alt : orig;
        rt.classList.toggle("kb-flipped", showAlt);
      };
      rt.addEventListener("click", flip);
      rt.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          flip();
        }
      });
    });
  }
</script>
