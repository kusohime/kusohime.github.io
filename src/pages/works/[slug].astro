---
// 中文：根据作品 Markdown 生成单个作品详情页。
// English: Generates an individual work detail page from its Markdown file.
// Caveat / 注意：公开网址使用 frontmatter 中的 slug，而不是文件夹名称。
// Caveat: The public URL uses the frontmatter slug, not the folder name.
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LocalizedText from "../../components/LocalizedText.astro";
import {
  formatDate,
  formatDuration,
  translate,
} from "../../config/locales";

export async function getStaticPaths() {
  const works = await getCollection("works");

  return works.map((work) => ({
    params: { slug: work.data.slug },
    props: { work },
  }));
}

interface Props {
  work: CollectionEntry<"works">;
}

const { work } = Astro.props;
const { Content } = await render(work);
const {
  title,
  subtitle,
  year,
  instrumentation,
  duration,
  dedication,
  commission,
  credits,
  premiere,
  recordingUrl,
  scoreUrl,
  image,
  imageAlt,
  description,
} = work.data;
---

<BaseLayout title={title} description={description}>
  <article
    class="detail-page work-detail"
    data-source-file={`content/works/${work.id}/index.md`}
  >
    <header class="detail-header work-detail-header">
      <div class="work-title-line">
        <h1>{title}</h1>
        <p class="work-year">
          <time datetime={String(year)} data-i18n-date={String(year)}>
            {formatDate(year, "en")}
          </time>
        </p>
      </div>
      {subtitle && <p>{subtitle}</p>}
      <p class="work-facts">
        <span><LocalizedText value={instrumentation} /></span>
        <span
          data-i18n-duration
          data-duration-minutes={duration.minutes}
          data-duration-continuous={String(duration.continuous)}
          data-duration-approximate={String(duration.approximate)}
        >
          {formatDuration(duration, "en")}
        </span>
      </p>

      {
        (recordingUrl || scoreUrl) && (
          <nav class="resource-links" aria-label="Work resources">
            <ul>
              {recordingUrl && (
                <li>
                  <a href={recordingUrl} data-i18n-key="resource.recording">
                    {translate("en", "resource.recording")}
                  </a>
                </li>
              )}
              {scoreUrl && (
                <li>
                  <a href={scoreUrl} data-i18n-key="resource.score">
                    {translate("en", "resource.score")}
                  </a>
                </li>
              )}
            </ul>
          </nav>
        )
      }
    </header>

    <figure class="media-placeholder">
      {
        image ? (
          <img src={image} alt={imageAlt ?? ""} width="1200" height="800" />
        ) : (
          <div role="img" aria-label="Media placeholder">
            Image or media placeholder
          </div>
        )
      }
      <figcaption>Image or media placeholder</figcaption>
    </figure>

    <div class="prose work-notes">
      <Content />
    </div>

    {
      (dedication || commission || credits || premiere) && (
        <footer class="work-credits">
          {dedication && (
            <p>
              <em>
                <span data-i18n-key="metadata.dedication">
                  {translate("en", "metadata.dedication")}
                </span>
                <span data-i18n-key="metadata.labelSeparator">
                  {translate("en", "metadata.labelSeparator")}
                </span>
                <LocalizedText value={dedication} />
              </em>
            </p>
          )}
          {commission && (
            <p>
              <em>
                <span data-i18n-key="metadata.commission">
                  {translate("en", "metadata.commission")}
                </span>
                <span data-i18n-key="metadata.labelSeparator">
                  {translate("en", "metadata.labelSeparator")}
                </span>
                <LocalizedText value={commission} />
              </em>
            </p>
          )}
          {credits?.map((credit) => (
            <p>
              <em>
                <span data-i18n-key="metadata.credits">
                  {translate("en", "metadata.credits")}
                </span>
                <span data-i18n-key="metadata.labelSeparator">
                  {translate("en", "metadata.labelSeparator")}
                </span>
                <LocalizedText value={credit} />
              </em>
            </p>
          ))}
          {premiere && (
            <p>
              <em>
                <span data-i18n-key="metadata.premiere">
                  {translate("en", "metadata.premiere")}
                </span>
                <span data-i18n-key="metadata.labelSeparator">
                  {translate("en", "metadata.labelSeparator")}
                </span>
                <LocalizedText value={premiere.details} />
                {premiere.date && (
                  <>
                    <span class="metadata-divider" aria-hidden="true"></span>
                    <time
                      datetime={String(premiere.date)}
                      data-i18n-date={String(premiere.date)}
                    >
                      {formatDate(premiere.date, "en")}
                    </time>
                  </>
                )}
              </em>
            </p>
          )}
        </footer>
      )
    }

    <p class="back-link">
      <a href="/works/">
        <span
          class="glyph-arrow glyph-arrow--back"
          data-arrow-glyph
          aria-hidden="true"
        ></span>
        <span data-i18n-key="common.backWorks">
          {translate("en", "common.backWorks")}
        </span>
      </a>
    </p>
  </article>
</BaseLayout>
