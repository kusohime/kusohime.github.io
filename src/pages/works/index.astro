---
// 中文：按类别整理并列出全部作品。
// English: Groups and lists all works by category.
// Caveat / 注意：类别顺序来自 config/contentTaxonomy.ts。
// Caveat: Category order comes from config/contentTaxonomy.ts.
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { toAnchor, workCategories } from "../../config/contentTaxonomy";
import {
  formatDate,
  translate,
  workCategoryLabel,
} from "../../config/locales";

const works = (await getCollection("works")).sort(
  (a, b) => a.data.order - b.data.order || b.data.year - a.data.year,
);

const worksByCategory = workCategories.map((category) => ({
  category,
  works: works.filter((work) => work.data.category === category),
}));
---

<BaseLayout
  title="Works"
  description="Selected compositions by Yixin Cui."
>
  <div
    class="index-page works-index"
    data-source-file="src/pages/works/index.astro"
  >
    <h1
      class="visually-hidden"
      data-i18n-key="nav.works"
    >
      {translate("en", "nav.works")}
    </h1>

    <nav class="catalog-rail" aria-label="Browse works by category">
      <ul>
        {
          worksByCategory.map(({ category, works: categoryWorks }) => (
            <li>
              <a href={`#${toAnchor(category)}`}>
                <span data-i18n-work-category={category}>
                  {workCategoryLabel(category, "en")}
                </span>{" "}
                ({categoryWorks.length})
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="catalog-groups category-groups">
      {
        worksByCategory.map(({ category, works: categoryWorks }) => (
          <section
            class="category-group"
            id={toAnchor(category)}
            aria-labelledby={`${toAnchor(category)}-heading`}
          >
            <h2
              id={`${toAnchor(category)}-heading`}
              data-i18n-work-category={category}
            >
              {workCategoryLabel(category, "en")}
            </h2>
            {categoryWorks.length > 0 ? (
              <ol class="catalog-list entry-list works-list dated-list">
                {categoryWorks.map((work) => (
                  <li>
                    <time
                      datetime={String(work.data.year)}
                      data-i18n-date={String(work.data.year)}
                    >
                      {formatDate(work.data.year, "en")}
                    </time>
                    <article
                      class="entry-summary work-summary"
                      data-source-file={`content/works/${work.id}/index.md`}
                    >
                      <div class="catalog-entry-line">
                        <h3>
                          <a href={`/works/${work.data.slug}/`}>
                            {work.data.title}
                          </a>
                        </h3>
                        {work.data.subtitle && (
                          <p class="catalog-entry-subtitle">{work.data.subtitle}</p>
                        )}
                      </div>
                    </article>
                  </li>
                ))}
              </ol>
            ) : (
              <p data-i18n-key="common.noWorks">
                {translate("en", "common.noWorks")}
              </p>
            )}
          </section>
        ))
      }
    </div>
  </div>
</BaseLayout>
