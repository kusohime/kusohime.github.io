---
// 中文：渲染文章标题页，并为同一文件夹中的章节自动生成目录。
// English: Renders a writing title page and auto-builds contents from its folder.
// Caveat / 注意：章节必须放在该文章的 chapters/ 文件夹中。
// Caveat: Chapters must remain inside that writing's chapters/ folder.
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Comments from "../../components/Comments.astro";
import CuiXiongReader from "../../components/CuiXiongReader.astro";
import SeriesDialogueReader from "../../components/SeriesDialogueReader.astro";
import { toAnchor } from "../../config/contentTaxonomy";
import WritingContentsRail from "../../components/WritingContentsRail.astro";
import { contentFolder } from "../../utils/contentPaths";
import { cjkLangFromText, dominantContentLang } from "../../utils/cjkLanguage";
import {
  formatDate,
  translate,
  writingTypeLabel,
} from "../../config/locales";
import "../../styles/igt.css";

export async function getStaticPaths() {
  const writings = await getCollection(
    "writings",
    ({ data }) => import.meta.env.DEV || !data.draft,
  );

  return writings.map((writing) => ({
    params: { slug: writing.data.slug },
    props: { writing },
  }));
}

interface Props {
  writing: CollectionEntry<"writings">;
}

const { writing } = Astro.props;
const { Content } = await render(writing);
// 中文：若同目录存在 index.zh.md，则正文按站点语言在英文主文与中文正文间切换。
// English: When a sibling index.zh.md exists, the body swaps between the English
// main body and the Chinese body by site locale (.lang-block).
const writingsZh = await getCollection("writingsZh");
const zhEntry = writingsZh.find((entry) => entry.id === writing.id);
const { Content: ContentZh } = zhEntry
  ? await render(zhEntry)
  : { Content: null as any };
const allChapters = await getCollection("writingChapters");
const writingFolder = contentFolder(writing.id);
const chapters = allChapters
  .filter((chapter) => contentFolder(chapter.id) === writingFolder)
  .sort((a, b) => a.data.order - b.data.order);

const { title, subtitle, date, displayDate, excerpt } = writing.data;
const dateLabel = displayDate ?? String(date);
const hasChapters = chapters.length > 0;
const writingTags = writing.data.tags;
const isTranslation = writingTags.includes("Translation");
// 诗歌正文不作段首缩进（样式见 global.css 的 .poetry-body）。
// Poetry bodies take no first-line indent (see .poetry-body in global.css).
const isPoetry = writingTags.includes("Poetry");
const isCuiXiong = writing.data.slug === "cui-xiong-pian";
const dialogueSeries = new Set(["脆熊篇", "本羣篇", "布鞋篇"]);
const seriesTitle = writing.data.series;
const isSeriesDialogue = Boolean(seriesTitle && dialogueSeries.has(seriesTitle));
const isBenQun = seriesTitle === "本羣篇";
const isImageLedSeries = isBenQun && writing.body.includes("/images/");
const seriesEntries = isSeriesDialogue
  ? (await getCollection(
      "writings",
      ({ data }) =>
        (import.meta.env.DEV || !data.draft) && data.series === seriesTitle,
    )).sort((a, b) => a.data.order - b.data.order)
  : [];
const isClairieres = writing.data.slug === "tian-jian-qing-che";
const contentLang = cjkLangFromText(
  [title, subtitle, excerpt].filter(Boolean).join(" "),
);
// 中文正文块的 lang 按其正文文字推断（简繁/日文）。
// The Chinese block's lang is inferred from its own body text (Hans/Hant/ja).
const zhBodyLang = zhEntry
  ? (cjkLangFromText(zhEntry.body ?? "") ?? "zh")
  : undefined;
// 中文：没有中文正文文件时，本页只有单语正文；按正文主导语言给出
// 「某语言不可用」的提示（随语言切换显示）。
// English: Without a Chinese body file the page is single-language; note which
// locale is unavailable, keyed to the body's dominant language.
const bodyLang = zhEntry ? undefined : dominantContentLang(writing.body ?? "");
const unavailableLanguages: ("en" | "zh")[] = bodyLang
  ? bodyLang === "en"
    ? ["zh"]
    : bodyLang === "zh"
      ? ["en"]
      : ["en", "zh"]
  : [];
---

<BaseLayout
  title={title}
  description={excerpt}
  noindex={writing.data.draft}
  unavailableLanguages={unavailableLanguages}
>
  <article
    class="detail-page writing-title-page"
    data-writing-slug={writing.data.slug}
    data-source-file={`content/writings/${writing.id}/index.md`}
  >
    {
      isSeriesDialogue ? (
        <SeriesDialogueReader
          writing={writing}
          entries={seriesEntries}
          contentLang={contentLang}
          imageLed={isImageLedSeries}
        >
          <div
            lang={contentLang}
            class:list={[
              "prose",
              "writing-body",
              "chicago-prose",
              {
                "cui-dialogue": !isBenQun,
                "poly-dialogue": isBenQun,
                "series-visual": isImageLedSeries,
              },
            ]}
          >
            <Content />
          </div>
        </SeriesDialogueReader>
      ) : isCuiXiong ? (
        <CuiXiongReader
          writing={writing}
          chapters={chapters}
          contentLang={contentLang}
        >
          <div
            lang={contentLang}
            class="prose writing-body chicago-prose cui-dialogue"
          >
            <Content />
          </div>
        </CuiXiongReader>
      ) : (
        <div class="writing-layout">
          <WritingContentsRail />
          <div class="writing-main">
            <header class="detail-header">
              {writing.data.draft && (
                <p class="draft-flag">Draft — not listed publicly</p>
              )}
              <div class="writing-title-line writing-title-line--detail">
                <h1 lang={contentLang}>{title}</h1>
                {isTranslation && (
                  <a
                    class="writing-tag writing-tag--translation"
                    href={`/writings/#writings-tag-${toAnchor("Translation")}`}
                    data-i18n-writing-type="Translation"
                  >
                    {writingTypeLabel("Translation", "en")}
                  </a>
                )}
              </div>
              {subtitle && <p lang={contentLang}>{subtitle}</p>}
              <p class="writing-metadata">
                <time datetime={String(date)} data-i18n-date={dateLabel}>
                  {formatDate(dateLabel, "en")}
                </time>
              </p>
            </header>

            <section class="writing-opening">
              <div
                lang={contentLang}
                class:list={[
                  "prose",
                  "chicago-prose",
                  {
                    "writing-body": !hasChapters,
                    "poetry-body": isPoetry,
                    leadcap: writing.data.dropcap,
                  },
                ]}
              >
                {
                  ContentZh ? (
                    <>
                      <div class="lang-block" data-lang="en" lang="en">
                        <Content />
                      </div>
                      <div class="lang-block" data-lang="zh" lang={zhBodyLang}>
                        <ContentZh />
                      </div>
                    </>
                  ) : (
                    <Content />
                  )
                }
              </div>
            </section>
          </div>
        </div>
      )
    }

    {
      isClairieres && (
        <script is:inline>
          (() => {
            const article = document.querySelector(
              '[data-writing-slug="tian-jian-qing-che"]',
            );
            const body = article?.querySelector(".writing-body");
            const toggle = article?.querySelector("[data-clairieres-pronoun-toggle]");
            if (!body || !toggle) return;

            const skipSelector =
              "[data-clairieres-pronoun-toggle], .footnotes, rt, script, style";
            const isLatin = (value) => /^[A-Za-z]$/.test(value ?? "");

            const shouldWrap = (text, index) =>
              text[index] === "L" &&
              !isLatin(text[index - 1]) &&
              !isLatin(text[index + 1]);

            const wrapPronounsInNode = (node) => {
              const text = node.nodeValue ?? "";
              if (!text.includes("L")) return;
              const fragment = document.createDocumentFragment();
              let cursor = 0;

              for (let index = 0; index < text.length; index += 1) {
                if (!shouldWrap(text, index)) continue;
                if (index > cursor) {
                  fragment.append(document.createTextNode(text.slice(cursor, index)));
                }
                const pronoun = document.createElement("span");
                pronoun.dataset.clairieresPronoun = "true";
                pronoun.textContent = "L";
                fragment.append(pronoun);
                cursor = index + 1;
              }

              if (cursor === 0) return;
              if (cursor < text.length) {
                fragment.append(document.createTextNode(text.slice(cursor)));
              }
              node.parentNode?.replaceChild(fragment, node);
            };

            const nodes = [];
            const walker = document.createTreeWalker(body, NodeFilter.SHOW_TEXT);
            while (walker.nextNode()) {
              const node = walker.currentNode;
              const parent = node.parentElement;
              if (!parent || parent.closest(skipSelector)) continue;
              nodes.push(node);
            }
            nodes.forEach(wrapPronounsInNode);

            const pronouns = Array.from(
              body.querySelectorAll("[data-clairieres-pronoun]"),
            );
            let showingShe = false;
            const flapTimers = new WeakMap();

            const localFlapText = (element, text) => {
              const existingTimer = flapTimers.get(element);
              if (existingTimer) window.clearTimeout(existingTimer);

              const fragment = document.createDocumentFragment();
              const accessibleText = document.createElement("span");
              accessibleText.className = "visually-hidden";
              accessibleText.textContent = text;
              fragment.append(accessibleText);

              let longestDelay = 0;
              Array.from(text).forEach((glyph, index) => {
                const patternedDelay = Math.min(index * 4, 110);
                const laneDelay = (index % 6) * 5;
                const jitter = Math.random() * 65;
                const delay = Math.round(patternedDelay + laneDelay + jitter);
                const flap = document.createElement("span");
                longestDelay = Math.max(longestDelay, delay);
                flap.className = "flap-glyph";
                flap.ariaHidden = "true";
                flap.textContent = glyph === " " ? "\u00a0" : glyph;
                flap.style.setProperty("--flap-delay", `${delay}ms`);
                flap.style.setProperty(
                  "--flap-lean",
                  `${(Math.random() * 4 - 2).toFixed(2)}deg`,
                );
                fragment.append(flap);
              });

              element.replaceChildren(fragment);
              element.dataset.flapping = "true";
              const timer = window.setTimeout(() => {
                element.textContent = text;
                delete element.dataset.flapping;
                flapTimers.delete(element);
              }, longestDelay + 190);
              flapTimers.set(element, timer);
            };

            const setAnimatedText = (element, text) => {
              const withFlap = window.ycSetFlapText;
              if (typeof withFlap === "function") {
                withFlap(element, text, true);
              } else {
                localFlapText(element, text);
              }
            };

            const syncToggle = () => {
              const label = showingShe
                ? "將譯文中的她切換回 L"
                : "將譯文中的 L 切換為她";
              toggle.setAttribute("aria-label", label);
              toggle.setAttribute("aria-pressed", String(showingShe));
              toggle.title = label;
            };

            toggle.addEventListener("click", (event) => {
              event.preventDefault();
              showingShe = !showingShe;
              const nextText = showingShe ? "她" : "L";
              pronouns.forEach((element) => setAnimatedText(element, nextText));
              syncToggle();
            });

            syncToggle();
          })();
        </script>
      )
    }

    {
      hasChapters && !isCuiXiong && (
        <nav class="writing-contents" aria-labelledby="contents-heading">
          <h2 id="contents-heading" data-i18n-key="common.contents">
            {translate("en", "common.contents")}
          </h2>
          <ol class={writing.data.numberedContents ? undefined : "unnumbered"}>
            {chapters.map((chapter) => (
              <li>
                <a
                  href={`/writings/${writing.data.slug}/${chapter.data.slug}/`}
                  lang={contentLang}
                >
                  {chapter.data.title}
                </a>
                {chapter.data.excerpt && <p lang={contentLang}>{chapter.data.excerpt}</p>}
              </li>
            ))}
          </ol>
        </nav>
      )
    }

    <footer class="writing-footer-tags" aria-label="Writing tags">
      {writingTags.map((tag) => (
        <a
          class:list={[
            "writing-tag",
            { "writing-tag--translation": tag === "Translation" },
          ]}
          href={`/writings/#writings-tag-${toAnchor(tag)}`}
          data-i18n-writing-type={tag}
        >
          {writingTypeLabel(tag, "en")}
        </a>
      ))}
    </footer>

    {writing.data.comments && <Comments collection="writings" slug={writing.data.slug} />}

    <nav class="back-link" aria-label="Footer navigation">
      <a href="/writings/">
        <span
          class="glyph-arrow glyph-arrow--back"
          data-arrow-glyph
          aria-hidden="true"
        ></span>
        <span data-i18n-key="common.backWritings">
          {translate("en", "common.backWritings")}
        </span>
      </a>
    </nav>
  </article>
</BaseLayout>
