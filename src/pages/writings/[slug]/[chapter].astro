---
// 中文：渲染分章文章的单个章节页面。
// English: Renders one chapter belonging to a multi-part writing.
// Caveat / 注意：父文章由共同的 content/writings 文件夹推断。
// Caveat: The parent writing is inferred from the shared content/writings folder.
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { contentFolder } from "../../../utils/contentPaths";
import { translate } from "../../../config/locales";

export async function getStaticPaths() {
  const [writings, chapters] = await Promise.all([
    getCollection("writings"),
    getCollection("writingChapters"),
  ]);

  return chapters.flatMap((chapter) => {
    const parentFolder = contentFolder(chapter.id);
    const writing = writings.find(
      (entry) => contentFolder(entry.id) === parentFolder,
    );

    if (!writing) return [];
    if (!import.meta.env.DEV && writing.data.draft) return [];

    return [{
      params: {
        slug: writing.data.slug,
        chapter: chapter.data.slug,
      },
      props: { writing, chapter },
    }];
  });
}

interface Props {
  writing: CollectionEntry<"writings">;
  chapter: CollectionEntry<"writingChapters">;
}

const { writing, chapter } = Astro.props;
const { Content } = await render(chapter);
const chapters = (await getCollection("writingChapters"))
  .filter((entry) => contentFolder(entry.id) === contentFolder(chapter.id))
  .sort((a, b) => a.data.order - b.data.order);
const currentIndex = chapters.findIndex((entry) => entry.id === chapter.id);
const previousChapter = currentIndex > 0 ? chapters[currentIndex - 1] : undefined;
const nextChapter =
  currentIndex >= 0 && currentIndex < chapters.length - 1
    ? chapters[currentIndex + 1]
    : undefined;
const isCuiXiong = writing.data.slug === "cui-xiong-pian";
const isBenQun = isCuiXiong && chapter.data.slug.startsWith("ben-qun");
const normalizedLanguage = writing.data.language.toLowerCase();
const contentLang = normalizedLanguage.includes("traditional")
  ? "zh-Hant-TW"
  : normalizedLanguage.includes("simplified") || normalizedLanguage.includes("chinese")
    ? "zh-Hans-CN"
    : undefined;
---

<BaseLayout
  title={`${chapter.data.title} | ${writing.data.title}`}
  description={chapter.data.excerpt ?? writing.data.excerpt}
  noindex={writing.data.draft}
>
  <article
    class="detail-page writing-chapter-page"
    data-writing-slug={writing.data.slug}
    data-source-file={`content/writings/${chapter.id}.md`}
  >
    <header class="detail-header">
      <p lang={contentLang}>{writing.data.title}</p>
      <h1 lang={contentLang}>{chapter.data.title}</h1>
    </header>

    <div
      lang={contentLang}
      class:list={[
        "prose",
        "writing-body",
        "chicago-prose",
        {
          "cui-dialogue": isCuiXiong && !isBenQun,
          "poly-dialogue": isBenQun,
        },
      ]}
    >
      <Content />
    </div>

    <nav class="guide-chapter-navigation" aria-label="Adjacent chapters">
      {
        previousChapter ? (
          <a href={`/writings/${writing.data.slug}/${previousChapter.data.slug}/`}>
            <span
              class="glyph-arrow glyph-arrow--back"
              data-arrow-glyph
              aria-hidden="true"
            ></span>
            <span lang={contentLang}>{previousChapter.data.title}</span>
          </a>
        ) : (
          <span></span>
        )
      }
      {
        nextChapter && (
          <a href={`/writings/${writing.data.slug}/${nextChapter.data.slug}/`}>
            <span lang={contentLang}>{nextChapter.data.title}</span>
            <span
              class="glyph-arrow glyph-arrow--forward"
              data-arrow-glyph
              aria-hidden="true"
            ></span>
          </a>
        )
      }
    </nav>

    <p class="back-link">
      <a href={`/writings/${writing.data.slug}/`}>
        <span
          class="glyph-arrow glyph-arrow--back"
          data-arrow-glyph
          aria-hidden="true"
        ></span>
        <span data-i18n-key="common.backContents">
          {translate("en", "common.backContents")}
        </span>
      </a>
    </p>
  </article>
</BaseLayout>
