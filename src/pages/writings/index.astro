---
// 中文：按文本类型整理并列出全部文章。
// English: Groups and lists all writings by type.
// Caveat / 注意：类型与显示顺序来自 config/contentTaxonomy.ts。
// Caveat: Types and their display order come from config/contentTaxonomy.ts.
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  toAnchor,
  writingTypes,
} from "../../config/contentTaxonomy";
import {
  formatDate,
  translate,
  writingTypeLabel,
} from "../../config/locales";
import { cjkLangFromContentLanguage } from "../../utils/cjkLanguage";

const writings = (
  await getCollection("writings", ({ data }) => !data.draft)
).sort((a, b) => a.data.order - b.data.order);

const writingGroups = writingTypes.map((type) => ({
  type,
  heading: writingTypeLabel(type, "en", "plural"),
  writings: writings.filter((writing) => writing.data.type === type),
})).filter(({ writings: groupedWritings }) => groupedWritings.length > 0);
---

<BaseLayout
  title="Writings"
  description="Translations, essays, fiction, blog entries, program notes, and other texts by Yixin Cui."
>
  <div
    class="index-page writings-index"
    data-source-file="src/pages/writings/index.astro"
  >
    <h1
      class="visually-hidden"
      data-i18n-key="nav.writings"
    >
      {translate("en", "nav.writings")}
    </h1>

    <nav class="catalog-rail" aria-label="Browse writings by type">
      <ul>
        {
          writingGroups.map(({ type, heading, writings: groupedWritings }) => (
            <li>
              <a href={`#${toAnchor(heading)}`}>
                <span
                  data-i18n-writing-type={type}
                  data-writing-type-form="plural"
                >
                  {heading}
                </span>{" "}
                ({groupedWritings.length})
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="catalog-groups writing-groups">
      {
        writingGroups.map(({ type, heading, writings: groupedWritings }) => (
          <section
            class="writing-group"
            id={toAnchor(heading)}
            aria-labelledby={`writing-type-${type.toLowerCase().replaceAll(" ", "-")}`}
          >
            <h2
              id={`writing-type-${type.toLowerCase().replaceAll(" ", "-")}`}
              data-i18n-writing-type={type}
              data-writing-type-form="plural"
            >
              {heading}
            </h2>
            <ul class="catalog-list dated-list">
              {groupedWritings.map((writing) => {
                const dateLabel = writing.data.displayDate ?? String(writing.data.date);
                const titleLang = cjkLangFromContentLanguage(
                  writing.data.language,
                  [
                    writing.data.title,
                    writing.data.subtitle,
                    writing.data.excerpt,
                  ].filter(Boolean).join(" "),
                );
                return (
                <li data-source-file={`content/writings/${writing.id}/index.md`}>
                  <time
                    datetime={String(writing.data.date)}
                    data-i18n-date={dateLabel}
                    data-i18n-date-format="short"
                  >
                    {formatDate(dateLabel, "en", "short")}
                  </time>
                  <a href={`/writings/${writing.data.slug}/`} lang={titleLang}>
                    {writing.data.title}
                  </a>
                  {writing.data.subtitle && (
                    <span class="writing-list-subtitle">
                      {writing.data.subtitle}
                    </span>
                  )}
                </li>
                );
              })}
            </ul>
          </section>
        ))
      }
    </div>
  </div>
</BaseLayout>
